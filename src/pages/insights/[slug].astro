  <style>
  /* ════════════════════════════════════════════════════════════
     ARTICLE READING PROGRESS BAR
     ════════════════════════════════════════════════════════════ */
  .art-prog{position:fixed;top:0;left:0;height:3px;width:0;background:var(--ag);z-index:90;transition:width .12s linear;box-shadow:0 0 12px rgba(79,142,247,.45)}

