  .art-by-av img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block}
  .art-by-fb{display:none;font-family:var(--fu);font-size:13px;font-weight:700;color:#fff;align-items:center;justify-content:center;width:100%;height:100%;background:var(--ag)}
