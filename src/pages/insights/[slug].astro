  </style>

  <style is:global>
  /* Internal vs external links (#artProse = markdown column) */
  #artProse a.content-int,
  #artProse a.art-int{
    color:#7BAEFF;
    font-weight:600;
    text-decoration-thickness:2px;
    text-underline-offset:4px;
    text-decoration-color:rgba(123,190,255,.55);
  }
  #artProse a.content-int:hover,
  #artProse a.art-int:hover{
    color:#B8D4FF;
    text-decoration-color:rgba(184,212,255,.85);
  }
  #artProse a.art-ext{
    text-decoration-color:rgba(79,142,247,.45);
  }
  html.light #artProse a.content-int,
  html.light #artProse a.art-int{
    color:var(--ac);
    text-decoration-color:rgba(37,84,214,.42);
  }
  </style>

  <script>
  // ─── Sidebar form mount time (anti-bot, matches /api/subscribe) ───
  const sidebarFormMount = document.getElementById('sidebarForm');
  if(sidebarFormMount) sidebarFormMount.dataset.mountedAt = String(Date.now());

  // ─── Article reading progress + TOC highlight (single scroll handler) ───
  const artProg = document.getElementById('artProg');
  const tocFill = document.getElementById('artTocProgFill');
  const article = document.querySelector('.art-prose') as HTMLElement|null;

  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.art-toc-link'));
  const headings = tocLinks.map(l => {
    const slug = l.dataset.toc || '';
    return {link: l, slug, el: document.getElementById(slug)};
  }).filter(h => h.el);

  function tickProg(){
    if(!article) return;
    const rect = article.getBoundingClientRect();
    const total = article.offsetHeight - window.innerHeight;
    const passed = Math.max(0, -rect.top);
    const pct = Math.max(0, Math.min(1, total > 0 ? passed/total : 0));
    if(artProg) artProg.style.width = (pct*100)+'%';
    if(tocFill) tocFill.style.width = (pct*100)+'%';
  }

  function activateToc(){
    if(!headings.length) return;
    let activeIdx = 0;
    const offset = 120;
    headings.forEach((h, i) => {
      const rect = h.el!.getBoundingClientRect();
      if(rect.top - offset <= 0) activeIdx = i;
    });
    headings.forEach((h, i) => h.link.classList.toggle('is-active', i === activeIdx));
  }

  let scrollBundled = false;
  function onArticleScroll(){
    if(scrollBundled) return;
    scrollBundled = true;
    requestAnimationFrame(()=>{
      tickProg();
      activateToc();
      scrollBundled = false;
    });
  }
  window.addEventListener('scroll', onArticleScroll, {passive:true});
  window.addEventListener('resize', onArticleScroll, {passive:true});
  onArticleScroll();

  // ─── Smooth scroll for TOC — Lenis when present ───
  tocLinks.forEach(l => {
    l.addEventListener('click', (e) => {
      const slug = l.dataset.toc || '';
      const tgt = document.getElementById(slug);
      if(!tgt) return;
      e.preventDefault();
      const lenis = (window as unknown as { __lenis?: { scrollTo: (t: HTMLElement, o?: { offset?: number }) => void } }).__lenis;
      if(lenis && typeof lenis.scrollTo === 'function'){
        lenis.scrollTo(tgt, { offset: -92 });
      } else {
        const top = tgt.getBoundingClientRect().top + window.scrollY - 92;
        window.scrollTo({ top, behavior: 'smooth' });
      }
      history.replaceState(null,'',`#${slug}`);
    });
  });

  // ─── Reveal on scroll ───
  const ro=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');ro.unobserve(e.target)}})},{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.rv').forEach(el=>ro.observe(el));

  // ─── Wrap tables if markdown escaped wrapper (legacy HTML) ───
  document.querySelectorAll('.art-prose table').forEach((table) => {
    if(table.closest('.art-table-wrap')) return;
    const wrap = document.createElement('div');
    wrap.className = 'art-table-wrap';
    table.replaceWith(wrap);
    wrap.appendChild(table);
  });

  // ─── External links in prose (internal previews: global Nav layer) ───
  document.querySelectorAll<HTMLAnchorElement>('.art-prose a[href]').forEach((a) => {
    const href = a.getAttribute('href') || '';
    if(!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
    try {
      const u = new URL(a.href, window.location.origin);
      const same = u.hostname.replace(/^www\./, '') === window.location.hostname.replace(/^www\./, '');
      if(!same && /^https?:\/\//i.test(href)) a.classList.add('art-ext');
    } catch { /* ignore */ }
  });


  // ─── Copy link button ───
  const copyBtn = document.getElementById('copyLinkBtn');
  const copyTxt = document.getElementById('copyLinkTxt');
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      if(copyTxt) copyTxt.textContent = 'Copied';
      copyBtn.classList.add('copied');
      setTimeout(()=>{
        if(copyTxt) copyTxt.textContent = 'Copy link';
        copyBtn.classList.remove('copied');
      }, 1800);
    } catch {}
  });

  // ─── Sidebar lead capture ───
  const sForm=document.getElementById('sidebarForm');
  const sEmail=document.getElementById('sidebarEmail') as HTMLInputElement|null;
  const sMsg=document.getElementById('sidebarMsg');
  const sBtnTxt=document.getElementById('sidebarBtnTxt');
  sForm?.addEventListener('submit',async e=>{
    e.preventDefault();
    const email=sEmail?.value.trim();
    if(!email)return;
    const honey=(document.getElementById('sidebarHoney') as HTMLInputElement|null)?.value?.trim()||'';
    const mountedAt=parseInt(sForm?.dataset.mountedAt||'0',10)||Date.now();
    const btn=sForm.querySelector('#sidebarBtn') as HTMLButtonElement|null;
    if(sBtnTxt)sBtnTxt.textContent='Sending...';
    if(btn)btn.disabled=true;
    if(sMsg){sMsg.textContent='';sMsg.className='art-nl-msg'}
    try{
      const res=await fetch('/api/subscribe',{
        method:'POST',
        headers:{'accept':'application/json','content-type':'application/json'},
        body:JSON.stringify({
          email,
          website:honey,
          mountedAt,
          leadSource:'blog-newsletter',
        }),
      });
      const data=await res.json().catch(()=>({})) as {ok?:boolean;error?:string};
      if(res.ok&&data.ok){
        if(sMsg){sMsg.textContent='You are in. Check your inbox.';sMsg.className='art-nl-msg ok'}
        if(sBtnTxt)sBtnTxt.textContent='Joined ✓';
        if(sEmail)sEmail.value='';
        if(typeof gtag==='function') gtag('event','sign_up',{event_category:'newsletter',event_label:'blog_sidebar'});
      } else {
        const errText=typeof data.error==='string'&&data.error?data.error:'Could not subscribe. Try again.';
        if(sMsg){sMsg.textContent=errText;sMsg.className='art-nl-msg err'}
        if(sBtnTxt)sBtnTxt.textContent='Join free';
      }
    }catch{
      if(sMsg){sMsg.textContent='Network error. Check your connection and try again.';sMsg.className='art-nl-msg err'}
      if(sBtnTxt)sBtnTxt.textContent='Join free';
    }finally{
      if(btn)btn.disabled=false;
    }
  });

  // ─── Code block enhancer ───
  // Wraps every <pre> in IDE-style chrome: traffic-light dots,
  // a language pill (extracted from the language-* class on <code>),
  // and a copy-to-clipboard button. Re-usable across every blog post.
  (function enhanceCodeBlocks(){
    const pres = document.querySelectorAll<HTMLPreElement>('.art-prose pre');
    if(!pres.length) return;

    const langMap: Record<string,string> = {
      js: 'JavaScript', javascript: 'JavaScript', ts: 'TypeScript', typescript: 'TypeScript',
      json: 'JSON', html: 'HTML', css: 'CSS', sh: 'Shell', bash: 'Bash',
      shell: 'Shell', py: 'Python', python: 'Python', md: 'Markdown',
      yml: 'YAML', yaml: 'YAML', tsx: 'TSX', jsx: 'JSX',
      txt: 'Plain text', plain: 'Plain text',
    };

    pres.forEach((pre) => {
      if(pre.dataset.cbEnhanced === '1') return;
      pre.dataset.cbEnhanced = '1';

      const code = pre.querySelector('code');
      if(!code) return;

      // Detect language from "language-xxx" class on <code>
      let lang = 'Code';
      const cls = code.className || '';
      const m = cls.match(/language-([a-z0-9]+)/i);
      if(m){
        const key = m[1].toLowerCase();
        lang = langMap[key] || key.toUpperCase();
      } else {
        // Heuristic: starts with "{" or has a lot of ":" and "," → JSON
        const txt = (code.textContent || '').trim();
        if(/^[\[{]/.test(txt) && /["{}\[\]]/.test(txt)) lang = 'JSON';
      }

      // Wrap the <pre> in a <figure class="cb-wrap"> and put the chrome
      // bar OUTSIDE the <pre>. Inserting it inside caused the bar to
      // inherit white-space:pre from <pre> + Shiki's inline styles,
      // collapsing the flex row into a vertical stack.
      const parent = pre.parentNode;
      if(!parent) return;

      const wrap = document.createElement('figure');
      wrap.className = 'cb-wrap';
      parent.insertBefore(wrap, pre);

      const bar = document.createElement('div');
      bar.className = 'cb-bar';
      bar.innerHTML = [
        '<span class="cb-dots"><span></span><span></span><span></span></span>',
        '<span class="cb-lang">' + lang + '</span>',
        '<span class="cb-spacer"></span>',
        '<button type="button" class="cb-copy" aria-label="Copy code">',
          '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>',
          '<span class="cb-copy-txt">Copy</span>',
        '</button>'
      ].join('');

      wrap.appendChild(bar);
      wrap.appendChild(pre);

      const btn = bar.querySelector<HTMLButtonElement>('.cb-copy');
      const btnTxt = bar.querySelector<HTMLElement>('.cb-copy-txt');
      btn?.addEventListener('click', async () => {
        const text = code.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          if(btnTxt) btnTxt.textContent = 'Copied';
          btn.classList.add('is-ok');
          setTimeout(() => {
            if(btnTxt) btnTxt.textContent = 'Copy';
            btn.classList.remove('is-ok');
          }, 1800);
        } catch {
          if(btnTxt) btnTxt.textContent = 'Failed';
          setTimeout(() => { if(btnTxt) btnTxt.textContent = 'Copy'; }, 1500);
        }
      });

      // ── Collapsible: if wrapped block > 480px, collapse the WRAP
      //    (so the chrome bar stays visible) and add a Show more
      //    button at the bottom. ──
      requestAnimationFrame(() => {
        const fullHeight = wrap.scrollHeight;
        if(fullHeight <= 480) return;

        wrap.classList.add('is-collapsible');
        const expand = document.createElement('button');
        expand.type = 'button';
        expand.className = 'cb-expand';
        expand.setAttribute('aria-expanded', 'false');
        expand.innerHTML = [
          '<span class="cb-expand-txt">Show more</span>',
          '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="m6 9 6 6 6-6"/></svg>'
        ].join('');
        wrap.appendChild(expand);

        const txt = expand.querySelector('.cb-expand-txt') as HTMLElement | null;
        expand.addEventListener('click', () => {
          const open = wrap.classList.toggle('is-open');
          expand.setAttribute('aria-expanded', String(open));
          if(txt) txt.textContent = open ? 'Show less' : 'Show more';
        });
      });
    });
  })();
  </script>
</Layout>
