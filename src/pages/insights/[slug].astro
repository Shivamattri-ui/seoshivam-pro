  .art-meta-dot{width:3px;height:3px;border-radius:50%;background:var(--bd)}
  .art-date,.art-read,.art-updated{font-family:var(--fm);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--wm);display:inline-flex;align-items:center;gap:6px}

  .art-title{
    font-family:var(--fd);
    font-size:clamp(34px,5.4vw,72px);
    font-weight:400;line-height:.98;letter-spacing:-.022em;
    color:var(--w);margin:0 0 24px;
  }

  /* TL;DR / direct answer (no label - clean for AI extraction) */
  .art-lead{
