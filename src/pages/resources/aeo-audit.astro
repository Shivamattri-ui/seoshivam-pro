<script>
// ─── AEO audit gate form ─────────────────────────────────────────────────────
(function () {
  const form = document.getElementById('aeo-audit-gate') as HTMLFormElement | null;
  if (!form) return;

  // Start mount timer when user focuses the email field
  const emailInput = form.querySelector('input[name="email"]') as HTMLInputElement | null;
  emailInput?.addEventListener('focus', () => {
    if (!form.dataset.mountedAt) form.dataset.mountedAt = String(Date.now());
  }, { once: true });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msgEl   = document.getElementById('aeo-gate-msg');
    const btnTxt  = form.querySelector('.aa-gate-btn-txt') as HTMLElement | null;
    const btn     = form.querySelector('.aa-gate-btn') as HTMLButtonElement | null;

    const email   = emailInput?.value.trim() || '';
    const honey   = (form.querySelector('input[name="website"]') as HTMLInputElement)?.value || '';
    const mountedAt = parseInt(form.dataset.mountedAt || '0', 10) || 0;

    if (!email) return;
    if (btnTxt) btnTxt.textContent = 'Sending...';
    if (btn) btn.disabled = true;
    if (msgEl) { msgEl.textContent = ''; msgEl.className = 'aa-gate-msg'; }

    try {
      const res  = await fetch('/api/resource-gate', {
        method: 'POST',
        headers: { accept: 'application/json', 'content-type': 'application/json' },
        body: JSON.stringify({
          email,
          website: honey,
          mountedAt,
          resourceId: form.dataset.resourceId || 'aeo-audit-80',
          resourceTitle: form.dataset.resourceTitle || '80-Point AEO Audit',
        }),
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok && data && data.ok) {
        if (msgEl) {
          msgEl.textContent = typeof data.message === 'string' ? data.message : 'Check your inbox.';
          msgEl.className = 'aa-gate-msg ok';
        }
        if (btnTxt) btnTxt.textContent = 'Done';
        if (emailInput) emailInput.value = '';
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'sign_up', { event_category: 'resource_download', event_label: 'aeo-audit-80' });
        }
      } else {
        const errText = typeof data.error === 'string' ? data.error : 'Request failed.';
        throw new Error(errText);
      }
    } catch (err) {
      if (msgEl) {
        msgEl.textContent = ((err as Error)?.message || 'Something went wrong. Email hello@seoshivam.pro');
        msgEl.className = 'aa-gate-msg err';
      }
      if (btnTxt) btnTxt.textContent = 'Download free';
      if (btn) btn.disabled = false;
    }
  });
})();
</script>
