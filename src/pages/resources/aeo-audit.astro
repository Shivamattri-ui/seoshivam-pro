---
import Layout from '../../layouts/Layout.astro';
import ContactCta from '../../components/ContactCta.astro';
import { SITE_ROUTE_META } from '../../lib/site-route-meta';

const meta = SITE_ROUTE_META['/resources/aeo-audit'];

// DigitalDocument + FAQPage schema for this page
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "DigitalDocument",
      "@id": "https://seoshivam.pro/downloads/aeo-audit-80.pdf",
      "name": "80-Point AEO Audit Checklist",
      "alternateName": "Answer Engine Optimization Audit",
      "description": "A structured 80-point audit covering every technical and content layer that determines whether AI engines cite your brand. Organized into 8 sections: bot access, entity schema, content architecture, technical foundation, Bing and Brave indexation, E-E-A-T signals, internal linking, and citation monitoring.",
      "url": "https://seoshivam.pro/downloads/aeo-audit-80.pdf",
      "encodingFormat": "application/pdf",
      "fileFormat": "PDF",
      "datePublished": "2025-01-01",
      "dateModified": "2026-05-01",
      "inLanguage": "en",
      "keywords": "AEO audit, answer engine optimization checklist, AI search visibility, ChatGPT citation, Perplexity citation, entity schema, robots.txt AI bots, Bing indexation, Brave Search, FAQPage schema, JSON-LD audit",
      "author": {
        "@type": "Person",
        "@id": "https://seoshivam.pro/#shivam",
        "name": "Shivam Attri",
        "url": "https://seoshivam.pro/about",
        "jobTitle": "AEO Specialist and SEO Strategist",
        "sameAs": [
          "https://www.linkedin.com/in/seoshivampro/",
          "https://twitter.com/seoshivampro"
        ]
      },
      "publisher": {
        "@type": "Organization",
        "@id": "https://seoshivam.pro/#org",
        "name": "seoshivam.pro",
        "url": "https://seoshivam.pro",
        "logo": {
          "@type": "ImageObject",
          "url": "https://seoshivam.pro/og-image.svg"
        }
      },
      "isPartOf": {
        "@type": "WebPage",
        "@id": "https://seoshivam.pro/resources/aeo-audit"
      }
    },
    {
      "@type": "WebPage",
      "@id": "https://seoshivam.pro/resources/aeo-audit",
      "name": "80-Point AEO Audit Checklist — Free Download",
      "url": "https://seoshivam.pro/resources/aeo-audit",
      "description": meta.description,
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://seoshivam.pro" },
          { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://seoshivam.pro/resources" },
          { "@type": "ListItem", "position": 3, "name": "80-Point AEO Audit", "item": "https://seoshivam.pro/resources/aeo-audit" }
        ]
      },
      "mainEntity": { "@id": "https://seoshivam.pro/downloads/aeo-audit-80.pdf" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an AEO audit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An AEO (Answer Engine Optimization) audit is a structured review of every technical and content factor that determines whether AI engines — ChatGPT, Perplexity, Claude, Google AI Overviews, and Microsoft Copilot — can find, understand, and cite your brand. It differs from an SEO audit by prioritizing bot access rules, entity schema completeness, citation-ready content structure, and Bing and Brave indexation alongside standard technical checks."
          }
        },
        {
          "@type": "Question",
          "name": "Who should run an 80-point AEO audit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Any brand that wants to appear in AI-generated answers rather than only in traditional search results. The audit is most urgent for B2B SaaS companies, HealthTech brands, and professional services firms whose buyers use ChatGPT, Perplexity, or Copilot for vendor research. If you have zero AI citations after 6 months of content publishing, this audit identifies exactly which of the 80 checks you are failing."
          }
        },
        {
          "@type": "Question",
          "name": "How long does it take to complete the AEO audit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A thorough pass through all 80 checks takes 3 to 4 hours for a single website. Sections 1 (bot access) and 4 (technical foundation) can be completed in under 30 minutes with the right tools. Sections 2 (entity schema) and 3 (content architecture) require deeper review and typically take 2 hours for a site with 20 to 50 pages. The audit is designed to be run as a workshop with a team."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between this AEO audit and a standard SEO audit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A standard SEO audit checks rankings, backlinks, page speed, and crawlability for Google. This AEO audit adds four layers a standard audit misses: explicit AI bot permissions in robots.txt (GPTBot, ClaudeBot, PerplexityBot, BraveBot), entity schema completeness for knowledge graph recognition, citation-ready content structure (answer-first paragraphs, FAQPage schema, specific data claims), and separate Bing and Brave Search indexation — both required for Copilot and Claude live-search citations."
          }
        },
        {
          "@type": "Question",
          "name": "How do I know if my site is blocking AI crawlers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Go to seoshivam.pro/tools/robots-txt-checker and enter your domain. The tool checks your robots.txt against 15 AI crawlers including GPTBot, ClaudeBot, PerplexityBot, BraveBot, and Bingbot. A blocked crawler means that AI engine cannot read your content. This is the most common reason for zero AI citations and is always the first check in Section 1 of the AEO audit."
          }
        }
      ]
    }
  ]
};

const faqs = [
  {
    q: "What is an AEO audit?",
    a: "An AEO audit reviews every technical and content factor that determines whether AI engines can find, understand, and cite your brand — covering bot access, entity schema, content structure, and cross-engine indexation."
  },
  {
    q: "Who should run this audit?",
    a: "Any brand targeting AI citation visibility. Most urgent for B2B SaaS, HealthTech, and professional services where buyers use ChatGPT, Perplexity, or Copilot for vendor research."
  },
  {
    q: "How long does it take?",
    a: "3 to 4 hours for a full pass. Sections 1 and 4 take under 30 minutes. Designed to run as a structured team workshop."
  },
  {
    q: "How is this different from a standard SEO audit?",
    a: "Standard SEO audits miss AI bot permissions, entity schema completeness, FAQPage schema, and separate Bing and Brave indexation — all required for AI engine citations."
  }
];

const sections = [
  {
    n: '01',
    title: 'AI Bot Access',
    count: 10,
    desc: 'Confirms every major AI crawler — GPTBot, ClaudeBot, PerplexityBot, BraveBot, Google-Extended, Bingbot, CCBot, and meta-externalagent — is explicitly allowed in robots.txt. Blocked bots cannot cite your content regardless of quality. This section is the first fix before any content or schema work.',
    checks: [
      'GPTBot explicitly allowed in robots.txt',
      'ClaudeBot explicitly allowed in robots.txt',
      'PerplexityBot explicitly allowed in robots.txt',
      'Bingbot explicitly allowed (required for Microsoft Copilot citations)',
      'BraveBot explicitly allowed (required for Claude live-search citations)',
      'Google-Extended explicitly allowed for AI Overviews training',
      'CCBot explicitly allowed',
      'meta-externalagent explicitly allowed (Meta AI)',
      'No crawl-budget configuration that throttles bot access',
      'sitemap.xml accessible and referenced in robots.txt',
    ],
  },
  {
    n: '02',
    title: 'Entity Schema',
    count: 15,
    desc: 'Validates your Organization and Person JSON-LD against the schema.org specification. AI engines use entity schema to understand who you are, what you do, and who you serve — independent of your page content. Missing or malformed schema is the most common reason a well-written brand gets zero citations.',
    checks: [
      'Organization JSON-LD present on homepage',
      '@id property uses a persistent anchor URL (#org)',
      'name, url, and description match actual site content',
      'logo property uses a stable, indexed image URL',
      'sameAs array includes LinkedIn, Twitter/X, and GitHub where applicable',
      'LinkedIn company profile URL in sameAs',
      'Person schema present for founder or primary author',
      'Person knowsAbout properties match service keywords',
      'founder relationship connects Organization to Person entity',
      'ContactPoint schema with contactType and email',
      'areaServed is specific — named countries, not just "global"',
      'hasOfferCatalog lists core services with name and description',
      'WebSite schema with SearchAction on homepage',
      'BreadcrumbList JSON-LD on all non-homepage pages',
      'No schema validation errors (passes Schema.org Markup Validator)',
    ],
  },
  {
    n: '03',
    title: 'Content Architecture for Citation',
    count: 15,
    desc: 'Reviews how content is structured for extraction by AI synthesis engines. Answer-first paragraphs, FAQPage schema, specific data claims, and structured list formats are the signals that make a page worth citing. Narrative prose that buries the answer is the most common content-side citation failure.',
    checks: [
      'First paragraph directly answers the page title as a question',
      'H2 headings phrased as questions on informational pages',
      'FAQPage JSON-LD present on all service pages',
      'FAQPage JSON-LD present on all blog posts with a FAQ section',
      'Article schema on every blog post with correct datePublished',
      'dateModified in Article schema reflects actual last-update date',
      'Author entity in Article schema links to Person schema @id',
      'HowTo schema on pages describing a step-by-step process',
      'TL;DR callout section on all long-form posts',
      'Answers formatted as numbered or bulleted lists — not prose paragraphs',
      'All factual claims include specific numbers (not "many" or "significantly")',
      'Comparison tables on pages targeting competitive queries',
      'Definition paragraph for every major concept introduced',
      'Blockquotes with attribution used for pulled quotes',
      'No content section longer than 3 sentences before a subheading',
    ],
  },
  {
    n: '04',
    title: 'Technical Foundation',
    count: 10,
    desc: 'Covers the Core Web Vitals, canonical configuration, and indexation signals that determine whether Google and AI engines crawl pages at full frequency. Pages with LCP above 2.5 seconds receive reduced crawl budget from Bingbot — the crawler behind Microsoft Copilot — making page speed directly tied to citation rate.',
    checks: [
      'LCP under 2.5 seconds on mobile (CrUX or PageSpeed Insights)',
      'CLS score under 0.1 on all key pages',
      'INP under 200ms on interactive pages',
      'HTTPS enforced with automatic HTTP-to-HTTPS redirect',
      'Self-referencing canonical tag on every indexed page',
      'No unintended noindex directives on target pages',
      'XML sitemap includes all published pages with lastmod dates',
      'robots.txt does not block Googlebot or any AI crawler',
      'No soft 404 pages returning 200 status',
      'Internal redirects resolve in a single hop — no redirect chains',
    ],
  },
  {
    n: '05',
    title: 'Bing and Brave Indexation',
    count: 10,
    desc: 'Microsoft Copilot performs a live Bing search for every query. Claude uses Brave Search for live queries. A site can rank position one on Google and still return zero results in Bing — two completely separate indexes. This section confirms both are properly set up and actively crawling your content.',
    checks: [
      'Bing Webmaster Tools account created and domain verified',
      'XML sitemap submitted to Bing Webmaster Tools',
      'Top 10 priority URLs submitted manually via Bing URL Submission',
      'site:yourdomain.com on Bing returns results near published page count',
      'Bing crawl error report reviewed — zero critical errors',
      'Bing Page Health check reviewed (LCP flagged and resolved)',
      'Brave Search indexes the site (site:yourdomain.com on Brave Search)',
      'BraveBot explicitly allowed in robots.txt',
      'Brave Search Webmaster submission completed at search.brave.com/webmaster',
      'Bing keyword performance data reviewed and documented monthly',
    ],
  },
  {
    n: '06',
    title: 'E-E-A-T and Citation Signals',
    count: 10,
    desc: 'Reviews the experience, expertise, authoritativeness, and trustworthiness signals that determine whether AI engines treat your content as a reliable source worth citing. Named methodology, original research, and credible external mentions are the durable citation signals — not keyword density.',
    checks: [
      'Author bio page exists with photo, credentials, and work history',
      'Author bio links to LinkedIn, publications, and professional profiles',
      'LinkedIn company page has complete "about" with product category and buyer description',
      'Founder publishing LinkedIn articles in the relevant category (minimum 4 per month)',
      'At least one piece of original research or proprietary data published',
      'Client results cited with industry, region, and metric type (NDA-compliant format)',
      'Named methodology or framework used for the core service',
      'External mentions of the brand on third-party indexed domains',
      'All outbound links point to authoritative, indexed sources',
      'No thin content pages — every indexed page has 400 or more words of original text',
    ],
  },
  {
    n: '07',
    title: 'Internal Linking and Topical Authority',
    count: 5,
    desc: 'Confirms the topical cluster structure that earns consistent AI citations across a subject. AI engines evaluate domain-level authority on a topic, not just individual page quality. A site that deeply covers one subject from multiple angles gets cited for that subject. Random blog posts about unrelated topics do not compound.',
    checks: [
      'Topical cluster structure documented — pillar pages and cluster posts mapped',
      'Every blog post links to at least one pillar page with keyword-specific anchor text',
      'No orphan pages — every indexed page has at least two internal links pointing to it',
      'Anchor text is 2 to 5 words and keyword-specific — no "click here" or raw URLs',
      'Maximum 3 clicks from homepage to any indexed page',
    ],
  },
  {
    n: '08',
    title: 'Citation Monitoring',
    count: 5,
    desc: 'Establishes the manual sampling cadence for tracking where your brand appears in AI-generated answers. There is no automated dashboard for this yet. Brands that monitor monthly identify citation gaps before they become competitive losses. Tracking is how you know which audit fixes are working.',
    checks: [
      'ChatGPT tested with top 15 buyer queries monthly — brand appearances documented',
      'Perplexity tested with top 15 buyer queries monthly — sources tab reviewed',
      'Microsoft Copilot tested with top 15 buyer queries — Bing citations checked',
      'Claude tested with top 15 buyer queries — Brave Search sources reviewed',
      'Google AI Overviews monitored weekly for branded and category queries',
    ],
  },
];
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical="https://seoshivam.pro/resources/aeo-audit"
  schema={schema}
>

<main class="aa-page">

  <!-- ─── Hero ───────────────────────────────────────────────────────────────── -->
  <section class="aa-hero container">
    <nav class="aa-breadcrumb rv" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">·</span>
      <a href="/resources">Resources</a>
      <span aria-hidden="true">·</span>
      <span aria-current="page">80-Point AEO Audit</span>
    </nav>

    <div class="hair left rv d1">FREE RESOURCE / AEO AUDIT CHECKLIST</div>

    <h1 class="aa-h1 rv d2">
      80 checks that determine<br>
      <em class="grad-anim">whether AI engines cite your brand.</em>
    </h1>

    <p class="aa-lead rv d3">
      Most brands are invisible in AI search not because their content is bad, but because they fail 20 to 40 of these checks silently. This audit covers every layer: bot permissions, entity schema, content structure, Bing and Brave indexation, E-E-A-T signals, and citation tracking. Run it as a workshop. Fix the failures in order. Start seeing citations within 30 to 90 days.
    </p>

    <div class="aa-meta rv d4">
      <span class="aa-pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
        PDF · 80 checks · 8 sections
      </span>
      <span class="aa-pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
        3 to 4 hrs to complete
      </span>
      <span class="aa-pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Free download
      </span>
    </div>
  </section>

  <!-- ─── Download gate ───────────────────────────────────────────────────────── -->
  <section class="aa-gate-section container">
    <div class="aa-gate-card rv">
      <div class="aa-gate-left">
        <div class="aa-gate-cover" aria-hidden="true">
          <div class="aa-gate-cover-inner">
            <span class="aa-gc-eyebrow">AEO AUDIT</span>
            <span class="aa-gc-num">80</span>
            <span class="aa-gc-label">Point Checklist</span>
            <span class="aa-gc-sub">seoshivam.pro</span>
          </div>
        </div>
      </div>
      <div class="aa-gate-right">
        <p class="aa-gate-kicker">GET THE FREE PDF</p>
        <h2 class="aa-gate-h2">Download the 80-Point AEO Audit</h2>
        <p class="aa-gate-desc">Enter your email and the download link lands in your inbox. Check Primary — it comes from hello@seoshivam.pro.</p>

        <form class="aa-gate-form" id="aeo-audit-gate" data-resource-id="aeo-audit-80" data-resource-title="80-Point AEO Audit" data-mounted-at="" novalidate>
          <div class="aa-honey" aria-hidden="true">
            <label>Leave blank<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
          </div>
          <div class="aa-gate-row">
            <input type="email" name="email" required maxlength="100" placeholder="your@email.com"
                   class="aa-gate-input" autocomplete="email"
                   aria-label="Email address">
            <button type="submit" class="aa-gate-btn">
              <span class="aa-gate-btn-txt">Download free</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
          <p class="aa-gate-msg" id="aeo-gate-msg" aria-live="polite"></p>
        </form>

        <p class="aa-gate-note">No spam. Unsubscribe any time.</p>
      </div>
    </div>
  </section>

  <!-- ─── What is AEO audit ─────────────────────────────────────────────────── -->
  <section class="aa-what container">
    <div class="aa-what-inner rv">
      <h2 class="sec-h">What this audit covers<br><em class="grad-anim">and why the order matters.</em></h2>
      <p class="aa-body">An AEO audit is not the same as an SEO audit. A standard SEO audit checks rankings, backlinks, and page speed for Google. This audit adds four layers a standard audit misses entirely: AI crawler permissions, entity schema completeness, citation-ready content structure, and cross-engine indexation for Bing and Brave Search.</p>
      <p class="aa-body">The audit is ordered by impact speed. Section 1 (bot access) produces the fastest result — unblocking a crawler can generate first citations within 30 days. Section 2 (entity schema) produces the most durable result — entity recognition compounds over time. Sections 3 through 8 produce the competitive moat that separates brands that get cited from brands that get paraphrased without attribution.</p>
    </div>
  </section>

  <!-- ─── 80 checks by section ─────────────────────────────────────────────── -->
  <section class="aa-sections container">
    <div class="hair left rv">ALL 80 CHECKS / ORGANIZED BY SECTION</div>
    <h2 class="sec-h rv d1">Every check in the audit,<br><em class="grad-anim">organized so you can act on them.</em></h2>

    <div class="aa-section-grid">
      {sections.map((sec, i) => (
        <article class={`aa-sec rv d${(i % 5) + 1}`}>
          <div class="aa-sec-head">
            <span class="aa-sec-n">{sec.n}</span>
            <div class="aa-sec-meta">
              <h3 class="aa-sec-title">{sec.title}</h3>
              <span class="aa-sec-count">{sec.count} checks</span>
            </div>
          </div>
          <p class="aa-sec-desc">{sec.desc}</p>
          <ol class="aa-checks">
            {sec.checks.map(c => (
              <li class="aa-check">
                <span class="aa-check-box" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </span>
                {c}
              </li>
            ))}
          </ol>
        </article>
      ))}
    </div>
  </section>

  <!-- ─── Who it's for ─────────────────────────────────────────────────────── -->
  <section class="aa-for container">
    <div class="hair left rv">WHO THIS IS FOR</div>
    <h2 class="sec-h rv d1">Built for practitioners,<br><em class="grad-anim">not for decoration.</em></h2>
    <div class="aa-for-grid rv d2">
      <div class="aa-for-item">
        <span class="aa-for-n">01</span>
        <h3>B2B SaaS founders and marketing leads</h3>
        <p>Running the audit yourself before hiring an agency. Use it to evaluate what you are told versus what is actually done.</p>
      </div>
      <div class="aa-for-item">
        <span class="aa-for-n">02</span>
        <h3>SEO specialists adding AEO to their practice</h3>
        <p>The audit maps directly to deliverables: robots.txt edits, schema additions, content rewrites. Use it as a client deliverable framework.</p>
      </div>
      <div class="aa-for-item">
        <span class="aa-for-n">03</span>
        <h3>Content and growth teams with zero AI citations</h3>
        <p>Six months of publishing with no citations means at least one structural failure. This audit identifies exactly which checks you are missing.</p>
      </div>
      <div class="aa-for-item">
        <span class="aa-for-n">04</span>
        <h3>Agencies building AEO services for clients</h3>
        <p>Use the 80 points as a scoping framework and a client-facing deliverable. Every check is a concrete task, not a recommendation.</p>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─────────────────────────────────────────────────────────────── -->
  <section class="aa-faq container">
    <div class="hair left rv">QUESTIONS ABOUT THE AUDIT</div>
    <h2 class="sec-h rv d1">Common questions<br><em class="grad-anim">answered before you ask.</em></h2>
    <div class="aa-faq-list rv d2">
      {faqs.map((faq, i) => (
        <details class="aa-faq-item">
          <summary class="aa-faq-q">
            <span>{faq.q}</span>
            <svg class="aa-faq-ico" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <p class="aa-faq-a">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ─── Related resources ────────────────────────────────────────────────── -->
  <section class="aa-related container">
    <div class="hair left rv">RELATED</div>
    <div class="aa-related-grid rv d1">
      <a href="/tools/robots-txt-checker" class="aa-rel-card" data-cursor="Check bots">
        <span class="aa-rel-tag">Free Tool</span>
        <h3>AI Bot Access Checker</h3>
        <p>Check if 15 AI crawlers can access your site. The fastest Section 1 check.</p>
        <span class="aa-rel-arrow">→</span>
      </a>
      <a href="/insights/schema-markup-for-ai-search" class="aa-rel-card" data-cursor="Read guide">
        <span class="aa-rel-tag">Guide</span>
        <h3>Schema Markup for AI Search</h3>
        <p>The complete JSON-LD implementation guide for Sections 2 and 3 of this audit.</p>
        <span class="aa-rel-arrow">→</span>
      </a>
      <a href="/services/aeo" class="aa-rel-card" data-cursor="See AEO work">
        <span class="aa-rel-tag">Service</span>
        <h3>Full AEO Implementation</h3>
        <p>If running the audit reveals gaps you want fixed, this is the full engagement.</p>
        <span class="aa-rel-arrow">→</span>
      </a>
    </div>
  </section>

  <ContactCta
    eyebrow="NEXT STEP"
    heading="Want the audit implemented,"
    headingEm="not just delivered."
    deck="If the audit reveals gaps, I can implement every fix — bot permissions, entity schema, content rewrites, Bing indexation, and citation tracking. Start with a free 1-page audit of where your brand stands right now."
    id="aeo-audit-cta"
    source="resources-aeo-audit"
  />

</main>
</Layout>

<style is:global>
.aa-page { padding-bottom: 0; }

/* ─── Hero ─────────────────────────────── */
.aa-breadcrumb {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--fm); font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
  color: var(--wd); margin-bottom: 32px;
}
.aa-breadcrumb a { color: var(--wd); text-decoration: none; transition: color .2s; }
.aa-breadcrumb a:hover { color: var(--ac); }

.aa-hero { padding-top: 80px; padding-bottom: 60px; }
.aa-h1 {
  font-family: var(--fu); font-size: clamp(36px, 5vw, 66px);
  font-weight: 400; letter-spacing: -.022em; line-height: .96;
  color: var(--w); margin: 24px 0 28px; max-width: 780px;
}
.aa-lead {
  font-family: var(--fu); font-size: clamp(16px, 1.5vw, 19px);
  color: var(--wd); line-height: 1.75; max-width: 660px; margin-bottom: 32px;
}
.aa-meta { display: flex; flex-wrap: wrap; gap: 10px; }
.aa-pill {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: var(--fm); font-size: 10px; font-weight: 600;
