  bytedance: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="#25F4EE" d="M9.4 8.7v9.5c0 1-.81 1.81-1.81 1.81s-1.81-.81-1.81-1.81.81-1.81 1.81-1.81c.18 0 .36.03.53.08V12.7c-.17-.02-.35-.04-.53-.04-3.06 0-5.55 2.49-5.55 5.55s2.49 5.55 5.55 5.55 5.55-2.49 5.55-5.55v-5.43c1.02.71 2.27 1.13 3.61 1.13v-3.74c-1.45 0-2.81-.69-3.65-1.81-.5-.66-.81-1.46-.91-2.32H9.4v3z" transform="translate(2 0)"/><path fill="#FE2C55" d="M11.4 6.7v9.5c0 1-.81 1.81-1.81 1.81s-1.81-.81-1.81-1.81.81-1.81 1.81-1.81c.18 0 .36.03.53.08V10.7c-.17-.02-.35-.04-.53-.04-3.06 0-5.55 2.49-5.55 5.55s2.49 5.55 5.55 5.55 5.55-2.49 5.55-5.55v-5.43c1.02.71 2.27 1.13 3.61 1.13V8.16c-1.45 0-2.81-.69-3.65-1.81-.5-.66-.81-1.46-.91-2.32H11.4v2.67z" transform="translate(2 0)"/></svg>',
};

const main = document.querySelector('.rtg-page');
if (!main) throw new Error('rtg page root not found');

const aiBots: AiBot[] = JSON.parse(main.getAttribute('data-bots') || '[]');
const presets: Preset[] = JSON.parse(main.getAttribute('data-presets') || '[]');

interface State {
  allowed: Set<string>;
  sitemap: string;
  paths: string[];
  delay: string;
  activePreset: string;
}
const state: State = {
  allowed: new Set<string>(aiBots.filter((b: AiBot) => b.defaultAllow).map((b: AiBot) => b.id)),
  sitemap: '',
  paths: [],
  delay: '',
  activePreset: 'recommended',
};

// ── Render bot list (controls) ──
const botsEl = document.getElementById('rtgBots');
function renderBots(): void {
  if (!botsEl) return;
  botsEl.innerHTML = aiBots.map((b: AiBot) => {
    const allowed = state.allowed.has(b.id);
    const icon = BRAND_ICONS[b.iconKey] || '';
    return `
      <label class="rtg-bot ${allowed ? 'is-allowed' : 'is-blocked'}" role="listitem">
        <span class="rtg-bot-icon" aria-hidden="true">${icon}</span>
        <span class="rtg-bot-meta">
          <span class="rtg-bot-name">
            ${b.name}
            <span class="rtg-bot-impact ${b.impact}">${b.impact}</span>
          </span>
          <span class="rtg-bot-engine">${b.company} · ${b.engine}</span>
        </span>
        <span class="rtg-tgl">
          <input type="checkbox" data-bot="${b.id}" ${allowed ? 'checked' : ''} aria-label="Allow ${b.name}" />
          <span class="rtg-tgl-track"></span>
        </span>
      </label>
    `;
  }).join('');

  botsEl.querySelectorAll('input[data-bot]').forEach((input) => {
    input.addEventListener('change', (e: Event) => {
      const target = e.target as HTMLInputElement | null;
      if (!target) return;
      const id = target.getAttribute('data-bot');
      if (!id) return;
      if (target.checked) state.allowed.add(id);
      else state.allowed.delete(id);
      state.activePreset = '';
      updatePresetUI();
      renderBots();
      generate();
    });
  });
}

// ── Render bot directory grid ──
const dirEl = document.getElementById('rtgDirGrid');
function renderDirectory(): void {
  if (!dirEl) return;
  dirEl.innerHTML = aiBots.map((b: AiBot) => {
    const icon = BRAND_ICONS[b.iconKey] || '';
    const tagClass = b.impact === 'critical' ? 'critical' : b.impact === 'high' ? 'high' : '';
    return `
      <article class="rtg-dir-card">
        <div class="rtg-dc-head">
          <span class="rtg-dc-icon" aria-hidden="true">${icon}</span>
          <div class="rtg-dc-names">
            <span class="rtg-dc-name">${b.name}</span>
            <span class="rtg-dc-engine">${b.company} · ${b.engine}</span>
          </div>
        </div>
        <p class="rtg-dc-pur">${b.purpose}</p>
        <div class="rtg-dc-foot">
          <span class="rtg-dc-tag ${tagClass}">${b.impact} impact</span>
          <span class="rtg-dc-ua">${b.userAgents[0]}</span>
        </div>
      </article>
    `;
  }).join('');
}

// ── Paths render ──
const pathsEl = document.getElementById('rtgPaths');
function renderPaths(): void {
  if (!pathsEl) return;
  pathsEl.innerHTML = state.paths.map((p: string, i: number) => `
    <div class="rtg-path">
      <code class="rtg-path-code">${escapeHtml(p)}</code>
      <button type="button" class="rtg-path-rm" data-path-rm="${i}" aria-label="Remove path ${escapeHtml(p)}">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
  `).join('');
  pathsEl.querySelectorAll('button[data-path-rm]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.getAttribute('data-path-rm') || '0', 10);
      state.paths.splice(idx, 1);
      renderPaths();
      generate();
    });
  });
}

function escapeHtml(s: string): string {
  const map: Record<string, string> = { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' };
  return String(s).replace(/[&<>"']/g, (m) => map[m] || m);
}

// ── Preset UI ──
function updatePresetUI(): void {
  document.querySelectorAll('[data-preset]').forEach((el) => {
    el.classList.toggle('is-active', el.getAttribute('data-preset') === state.activePreset);
  });
  const deck = document.getElementById('rtgPresetDeck');
  const active = presets.find((p: Preset) => p.id === state.activePreset);
  if (deck && active) deck.textContent = active.body;
  else if (deck && !state.activePreset) deck.textContent = 'Custom configuration. Toggle individual bots above to fine-tune.';
}

function applyPreset(id: string | null): void {
  if (!id) return;
  const preset = presets.find((p: Preset) => p.id === id);
  if (!preset) return;
  state.activePreset = id;
  state.allowed = new Set<string>(preset.bots);
  updatePresetUI();
  renderBots();
  generate();
}

document.querySelectorAll('[data-preset]').forEach(btn => {
  btn.addEventListener('click', () => {
    applyPreset(btn.getAttribute('data-preset'));
  });
});

document.querySelectorAll('[data-jump-preset]').forEach(btn => {
  btn.addEventListener('click', () => {
    applyPreset(btn.getAttribute('data-jump-preset'));
    document.getElementById('generator')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});

// ── Allow / Block all ──
document.getElementById('rtgAllowAll')?.addEventListener('click', () => {
  state.allowed = new Set<string>(aiBots.map((b: AiBot) => b.id));
  state.activePreset = 'allow-all';
  updatePresetUI();
  renderBots();
  generate();
});
document.getElementById('rtgBlockAll')?.addEventListener('click', () => {
  state.allowed = new Set<string>();
  state.activePreset = '';
  updatePresetUI();
  renderBots();
  generate();
});

// ── Sitemap ──
const sitemapInput = document.getElementById('rtgSitemap') as HTMLInputElement | null;
sitemapInput?.addEventListener('input', (e: Event) => {
  const t = e.target as HTMLInputElement | null;
  state.sitemap = (t?.value || '').trim();
  generate();
});

// ── Crawl delay ──
const delayInput = document.getElementById('rtgDelay') as HTMLInputElement | null;
delayInput?.addEventListener('input', (e: Event) => {
  const t = e.target as HTMLInputElement | null;
  state.delay = (t?.value || '').trim();
  generate();
});

// ── Add path ──
const pathInput = document.getElementById('rtgPathInput') as HTMLInputElement | null;
const addPathBtn = document.getElementById('rtgAddPath');
function addPath(): void {
  if (!pathInput) return;
  let v = (pathInput.value || '').trim();
  if (!v) return;
  if (!v.startsWith('/')) v = '/' + v;
  if (!v.endsWith('/')) v = v + '/';
  if (state.paths.indexOf(v) === -1) state.paths.push(v);
  pathInput.value = '';
  renderPaths();
  generate();
}
addPathBtn?.addEventListener('click', addPath);
pathInput?.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter') { e.preventDefault(); addPath(); } });

// ── Generate robots.txt ──
function buildRobotsTxt(): string {
  const lines: string[] = [];
  lines.push('# robots.txt generated by seoshivam.pro/tools/robots-txt-generator');
  lines.push('# ' + new Date().toISOString().slice(0,10) + ' · 15 AI crawlers + traditional');
  lines.push('');

  const blocked = aiBots.filter((b: AiBot) => !state.allowed.has(b.id));
  const allowed = aiBots.filter((b: AiBot) => state.allowed.has(b.id));

  if (allowed.length > 0) {
    lines.push('# Allowed AI crawlers');
    allowed.forEach((b: AiBot) => {
      b.userAgents.forEach((ua: string) => lines.push('User-agent: ' + ua));
      lines.push('Allow: /');
      state.paths.forEach((p: string) => lines.push('Disallow: ' + p));
      if (state.delay && /^\d+$/.test(state.delay) && parseInt(state.delay,10) > 0) {
        lines.push('Crawl-delay: ' + state.delay);
      }
      lines.push('');
    });
  }

  if (blocked.length > 0) {
    lines.push('# Blocked AI crawlers');
    blocked.forEach((b: AiBot) => {
      b.userAgents.forEach((ua: string) => lines.push('User-agent: ' + ua));
      lines.push('Disallow: /');
      lines.push('');
    });
  }

  // Wildcard fallback for remaining bots (search engines etc.)
  lines.push('# All other crawlers');
  lines.push('User-agent: *');
  if (state.paths.length > 0) {
    state.paths.forEach((p: string) => lines.push('Disallow: ' + p));
  } else {
    lines.push('Allow: /');
  }
  if (state.delay && /^\d+$/.test(state.delay) && parseInt(state.delay,10) > 0) {
    lines.push('Crawl-delay: ' + state.delay);
  }
  lines.push('');

  if (state.sitemap) {
    lines.push('Sitemap: ' + state.sitemap);
  }

  return lines.join('\n').replace(/\n{3,}/g, '\n\n').replace(/\n+$/, '\n');
}

function highlight(txt: string): string {
  return txt
    .split('\n')
    .map((line: string) => {
      if (line.startsWith('#')) return '<span class="rtg-tk-comment">' + escapeHtml(line) + '</span>';
      const m = line.match(/^([A-Za-z-]+):\s*(.*)$/);
      if (!m) return escapeHtml(line);
      const key = m[1];
      const val = m[2];
      let keyClass = 'rtg-tk-key';
      if (/^allow$/i.test(key)) keyClass = 'rtg-tk-allow';
      else if (/^disallow$/i.test(key)) keyClass = 'rtg-tk-disallow';
      return '<span class="' + keyClass + '">' + escapeHtml(key) + ':</span> <span class="rtg-tk-value">' + escapeHtml(val) + '</span>';
    })
    .join('\n');
}

const outputEl = document.getElementById('rtgOutput');
const metaEl = document.getElementById('rtgPvMeta');
function generate(): void {
  const txt = buildRobotsTxt();
  if (outputEl) outputEl.innerHTML = highlight(txt);
  if (metaEl) {
    const lineCount = txt.split('\n').filter((l: string) => l.trim()).length;
    metaEl.textContent = lineCount + (lineCount === 1 ? ' line' : ' lines');
  }
}

// ── Copy ──
document.getElementById('rtgCopy')?.addEventListener('click', () => {
  const txt = buildRobotsTxt();
  navigator.clipboard.writeText(txt).then(() => {
    const btnTxt = document.getElementById('rtgCopyTxt');
    if (btnTxt) {
      const orig = btnTxt.textContent;
      btnTxt.textContent = 'Copied';
      setTimeout(() => { btnTxt.textContent = orig || 'Copy file'; }, 1800);
    }
  }).catch(() => {});
});

// ── Download ──
document.getElementById('rtgDownload')?.addEventListener('click', () => {
  const txt = buildRobotsTxt();
  const blob = new Blob([txt], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'robots.txt';
  document.body.appendChild(a);
  a.click();
  setTimeout(() => {
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }, 0);
});

// Initial paint
applyPreset('recommended');
renderDirectory();
renderPaths();
</script>

</Layout>
