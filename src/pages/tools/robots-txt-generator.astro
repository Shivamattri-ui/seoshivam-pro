---
import Layout from '../../layouts/Layout.astro';
import { SITE_ROUTE_META } from '../../lib/site-route-meta';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FaqBlock from '../../components/FaqBlock.astro';
import ContactCta from '../../components/ContactCta.astro';

type BotImpact = 'critical' | 'high' | 'medium';

interface AiBot {
  id: string;
  name: string;
  company: string;
  engine: string;
  color: string;
  iconKey: string;
  userAgents: string[];
  purpose: string;
  impact: BotImpact;
  defaultAllow: boolean;
  group: 'citation' | 'training' | 'shopping' | 'social';
}

const aiBots: AiBot[] = [
  {
    id: 'gptbot',
    name: 'GPTBot',
    company: 'OpenAI',
    engine: 'ChatGPT',
    color: '#10A37F',
    iconKey: 'openai',
    userAgents: ['GPTBot'],
    purpose: 'OpenAI training crawler. Reads pages so ChatGPT can cite your brand when buyers ask vendor questions.',
    impact: 'critical',
    defaultAllow: true,
    group: 'training',
  },
  {
    id: 'oai-searchbot',
    name: 'OAI-SearchBot',
    company: 'OpenAI',
