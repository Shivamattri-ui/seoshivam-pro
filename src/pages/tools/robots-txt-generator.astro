.rtg-dc-tag.critical{color:var(--ac);background:var(--agl);border-color:rgba(79,142,247,.22)}
.rtg-dc-tag.high{color:#F59E0B;background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.22)}
.rtg-dc-ua{font-family:var(--fm);font-size:9px;color:var(--ac);background:var(--agl);border:1px solid rgba(79,142,247,.18);border-radius:4px;padding:2px 7px;line-height:1.3}

/* ═══════════════════════════════════════
   PRESET CARDS
═══════════════════════════════════════ */
.rtg-pre-sec{padding:clamp(72px,10vw,110px) 0}
.rtg-pre-hdr{margin-bottom:48px}
.rtg-pre-deck{font-family:var(--fu);font-size:clamp(14px,1.4vw,16px);color:var(--wd);line-height:1.75;max-width:620px;margin-top:16px}

.rtg-pre-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
.rtg-pre-card{background:var(--s1);border:1px solid var(--bd);border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:14px;position:relative;overflow:hidden}
.rtg-pre-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;opacity:.6}
.rtg-pre-card--blue::before{background:linear-gradient(90deg,var(--ac),#7BAEFF)}
.rtg-pre-card--green::before{background:linear-gradient(90deg,#22C55E,#16A34A)}
.rtg-pre-card--amber::before{background:linear-gradient(90deg,#F59E0B,#D97706)}
.rtg-pre-card--red::before{background:linear-gradient(90deg,#EF4444,#B91C1C)}

.rtg-pre-top{display:flex;align-items:center;justify-content:space-between;gap:12px}
.rtg-pre-badge{font-family:var(--fm);font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:4px 9px;border-radius:4px;font-weight:600}
.rtg-pre-badge--blue{color:var(--ac);background:var(--agl);border:1px solid rgba(79,142,247,.25)}
.rtg-pre-badge--green{color:#22C55E;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.25)}
.rtg-pre-badge--amber{color:#F59E0B;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25)}
.rtg-pre-badge--red{color:#EF4444;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25)}
.rtg-pre-count{font-family:var(--fm);font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:var(--wm)}

.rtg-pre-t{font-family:var(--fd);font-size:24px;font-weight:400;color:var(--w);margin:0;line-height:1.15;letter-spacing:-.02em}
.rtg-pre-d{font-family:var(--fu);font-size:13.5px;color:var(--wd);line-height:1.7;margin:0;flex:1}

.rtg-pre-apply{display:inline-flex;align-items:center;gap:8px;font-family:var(--fu);font-size:13px;font-weight:700;color:var(--ac);background:none;border:none;cursor:pointer;padding:0;align-self:flex-start;transition:gap .25s}
.rtg-pre-apply:hover{gap:12px}

/* ═══════════════════════════════════════
   COMMON MISTAKES
═══════════════════════════════════════ */
.rtg-mis-sec{padding:clamp(72px,10vw,110px) 0;background:var(--s1);border-top:1px solid var(--bd);border-bottom:1px solid var(--bd)}
.rtg-mis-hdr{margin-bottom:48px}
.rtg-mis-list{display:flex;flex-direction:column;max-width:840px;border:1px solid var(--bd);border-radius:16px;overflow:hidden;margin-bottom:24px}
.rtg-mis-row{display:flex;gap:24px;padding:28px 32px;border-bottom:1px solid var(--bd);background:var(--bg);transition:background .2s}
.rtg-mis-row:last-child{border-bottom:none}
.rtg-mis-row:hover{background:var(--s2)}
.rtg-mis-n{font-family:var(--fd);font-size:32px;font-weight:400;color:var(--wm);line-height:1;flex-shrink:0;width:48px;margin-top:2px}
.rtg-mis-t{font-family:var(--fu);font-size:15px;font-weight:700;color:var(--w);letter-spacing:-.01em;margin-bottom:8px}
.rtg-mis-d{font-family:var(--fu);font-size:14px;color:var(--wd);line-height:1.72;margin:0}
.rtg-mis-d code{font-family:var(--fm);font-size:12.5px;color:var(--ac);background:var(--agl);padding:1px 6px;border-radius:3px;border:1px solid rgba(79,142,247,.2)}
.rtg-mis-note{font-family:var(--fu);font-size:14px;color:var(--wd);line-height:1.7;max-width:680px}

/* ═══════════════════════════════════════
   FAQ
═══════════════════════════════════════ */
.rtg-faq-sec{padding:clamp(72px,10vw,110px) 0}

/* ═══════════════════════════════════════
   LIGHT MODE
═══════════════════════════════════════ */
html.light .rtg-tool{background:var(--s1)}
html.light .rtg-bot{background:var(--s2)}
html.light .rtg-bot-icon{background:var(--s1)}
html.light .rtg-input{background:var(--s2);color:var(--w)}
html.light .rtg-mini{background:var(--s2)}
html.light .rtg-preset{background:var(--s2)}
html.light .rtg-preview-stick{background:var(--s2)}
html.light .rtg-pv-code .rtg-tk-key{color:var(--ac)}
html.light .rtg-pv-foot,html.light .rtg-pv-actions,html.light .rtg-preview-head{background:var(--s3)}
html.light .rtg-why-card{background:var(--s1)}
html.light .rtg-dir-card{background:var(--s2)}
