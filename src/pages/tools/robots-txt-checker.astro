<script>
/* ── Page init: scroll progress, cursor, reveal observer ── */
const prog = document.getElementById('scrollProg');
window.addEventListener('scroll', () => {
  if (prog) {
    const s = document.documentElement;
    prog.style.width = (s.scrollTop / (s.scrollHeight - s.clientHeight) * 100) + '%';
  }
}, { passive: true });

const dot = document.getElementById('curDot');
const curRing = document.getElementById('curRing');
let mx = 0, my = 0, rx = 0, ry = 0;
window.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  if (dot) dot.style.transform = `translate(${mx - 4}px,${my - 4}px)`;
}, { passive: true });
(function loop() {
  if (curRing) { rx += (mx - rx - 16) * .12; ry += (my - ry - 16) * .12; curRing.style.transform = `translate(${rx}px,${ry}px)`; }
  requestAnimationFrame(loop);
})();
document.querySelectorAll('a,button').forEach(el => {
  el.addEventListener('mouseenter', () => { dot?.classList.add('hov'); curRing?.classList.add('hov'); });
  el.addEventListener('mouseleave', () => { dot?.classList.remove('hov'); curRing?.classList.remove('hov'); });
});
const ro = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); ro.unobserve(e.target); } });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.rv').forEach(el => ro.observe(el));

/* ══════════════════════════════════════════════════════════
   robots.txt checker — logic unchanged, display modernised
══════════════════════════════════════════════════════════ */
const BOTS = [
  { name: 'GPTBot',        engine: 'ChatGPT / OpenAI',        agents: ['gptbot'] },
  { name: 'ClaudeBot',     engine: 'Anthropic / Claude',       agents: ['claudebot', 'anthropic-ai', 'claude-web'] },
  { name: 'PerplexityBot', engine: 'Perplexity AI',            agents: ['perplexitybot'] },
  { name: 'Bingbot',       engine: 'Bing / Copilot',           agents: ['bingbot'] },
  { name: 'Googlebot',     engine: 'Google / AI Overviews',    agents: ['googlebot'] },
];

const CIRCUMFERENCE = 2 * Math.PI * 50; // r = 50 → C ≈ 314.16

/**
 * RFC-compliant robots.txt parser.
 * Groups by user-agent blocks. UA-specific beats wildcard.
 * Longest-matching path rule wins. Empty Disallow = allow all.
 */
function checkBotAccess(text: string, botUa: string): boolean {
  if (!text) return true;
  const lines = text.split(/\r?\n/);
  const groups: Array<{ agents: string[]; rules: Array<{ type: 'allow' | 'disallow'; path: string }> }> = [];
  let current: typeof groups[number] | null = null;
  let inUaBlock = false;

  for (const rawLine of lines) {
    const line = rawLine.replace(/#.*$/, '').trim();
    if (!line) continue;
    const colonIdx = line.indexOf(':');
    if (colonIdx === -1) continue;
    const key = line.slice(0, colonIdx).trim().toLowerCase();
    const value = line.slice(colonIdx + 1).trim();

    if (key === 'user-agent') {
      if (!inUaBlock || !current) { current = { agents: [], rules: [] }; groups.push(current); }
      current.agents.push(value.toLowerCase());
      inUaBlock = true;
    } else if (key === 'allow' || key === 'disallow') {
      if (!current) continue;
      current.rules.push({ type: key as 'allow' | 'disallow', path: value });
      inUaBlock = false;
    } else {
      inUaBlock = false;
    }
  }

  const ua = botUa.toLowerCase();
  let matchGroup = groups.find(g => g.agents.some(a => a === ua));
  if (!matchGroup) matchGroup = groups.find(g => g.agents.includes('*'));
  if (!matchGroup) return true;

  const testPath = '/';
  let bestMatch: { type: 'allow' | 'disallow'; len: number } | null = null;
  for (const rule of matchGroup.rules) {
    if (rule.path === '') {
      if (rule.type === 'disallow' && !bestMatch) bestMatch = { type: 'allow', len: 0 };
      continue;
    }
    if (testPath.startsWith(rule.path)) {
      const len = rule.path.length;
      if (!bestMatch || len > bestMatch.len || (len === bestMatch.len && rule.type === 'allow')) {
        bestMatch = { type: rule.type, len };
      }
    }
  }
  if (!bestMatch) return true;
  return bestMatch.type === 'allow';
}

async function fetchRobotsTxt(robotsUrl: string): Promise<string> {
  const attempts = [
    async () => { const r = await fetch(robotsUrl, { redirect: 'follow' }); if (!r.ok && r.status !== 404) throw new Error('direct ' + r.status); return r.status === 404 ? '' : await r.text(); },
    async () => { const r = await fetch(`https://corsproxy.io/?${encodeURIComponent(robotsUrl)}`); if (!r.ok && r.status !== 404) throw new Error('corsproxy ' + r.status); return r.status === 404 ? '' : await r.text(); },
    async () => { const r = await fetch(`https://api.allorigins.win/raw?url=${encodeURIComponent(robotsUrl)}`); if (!r.ok) throw new Error('allorigins ' + r.status); return await r.text(); },
  ];
  let lastErr: any = null;
  for (const a of attempts) { try { return await a(); } catch (e) { lastErr = e; } }
  throw lastErr || new Error('All proxies failed');
}

document.getElementById('rtcCheckBtn')?.addEventListener('click', async () => {
  const urlInput  = document.getElementById('rtcUrl') as HTMLInputElement;
  const resultsEl = document.getElementById('rtcResults');
  const errorEl   = document.getElementById('rtcError');
  const btnTxt    = document.getElementById('rtcBtnTxt');

  let url = urlInput.value.trim();
  if (!url) return;
  url = url.replace(/^https?:\/\//i, '').replace(/\/.*$/, '').trim();
  if (!url) return;
  const fullUrl = 'https://' + url;

  if (btnTxt) btnTxt.textContent = 'Checking...';
  if (resultsEl) resultsEl.style.display = 'none';
  if (errorEl) errorEl.style.display = 'none';

  try {
    const robotsUrl  = new URL('/robots.txt', fullUrl).href;
    const robotsTxt  = await fetchRobotsTxt(robotsUrl);

    const botsEl        = document.getElementById('rtcBots');
    const rawEl         = document.getElementById('rtcRaw');
    const fixEl         = document.getElementById('rtcFix');
    const fixCodeEl     = document.getElementById('rtcFixCode');
    const resultUrlEl   = document.getElementById('rtcResultUrl');
    const scoreEl       = document.getElementById('rtcScore');
    const verdictEl     = document.getElementById('rtcScoreVerdict');
    const ringFill      = document.getElementById('rtcRingFill') as SVGCircleElement | null;

    if (resultUrlEl) resultUrlEl.textContent = robotsUrl;
    if (rawEl) rawEl.textContent = robotsTxt || '(empty robots.txt — all bots allowed by default)';

    const results = BOTS.map(b => {
      let allowed = true;
      for (const agent of b.agents) { if (!checkBotAccess(robotsTxt, agent)) { allowed = false; break; } }
      return { ...b, allowed };
    });

    const allowedCount = results.filter(r => r.allowed).length;
    const pct = allowedCount / 5;
    const dashOffset = CIRCUMFERENCE * (1 - pct);
    const ringColor = allowedCount === 5 ? '#22C55E' : allowedCount >= 3 ? '#F59E0B' : '#EF4444';
    const verdictText = allowedCount === 5 ? 'Full access' : allowedCount >= 3 ? 'Partial access' : 'Mostly blocked';

    /* Score number */
    if (scoreEl) { scoreEl.textContent = String(allowedCount); scoreEl.style.color = ringColor; }

    /* Verdict label */
    if (verdictEl) { verdictEl.textContent = verdictText; verdictEl.style.color = ringColor; }

    /* Animate ring */
    if (ringFill) {
      ringFill.style.stroke = ringColor;
      ringFill.style.transition = 'none';
      ringFill.style.strokeDashoffset = String(CIRCUMFERENCE);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          ringFill.style.transition = `stroke-dashoffset 1.1s cubic-bezier(.4,0,.2,1), stroke .35s ease`;
          ringFill.style.strokeDashoffset = String(dashOffset);
        });
      });
    }

    /* Bot cards */
    if (botsEl) {
      botsEl.innerHTML = results.map(r => `
        <div class="rtc-bot ${r.allowed ? 'allowed' : 'blocked'}">
          <div class="rtc-bot-left">
            <div class="rtc-bot-ic ${r.allowed ? 'allowed' : 'blocked'}" aria-hidden="true">
              ${r.allowed
                ? `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`
                : `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>`}
            </div>
            <div>
              <div class="rtc-bot-name">${r.name}</div>
              <div class="rtc-bot-engine">${r.engine}</div>
            </div>
          </div>
          <div class="rtc-bot-status ${r.allowed ? 'allowed' : 'blocked'}" aria-label="${r.name} is ${r.allowed ? 'allowed' : 'blocked'}">${r.allowed ? 'Allowed' : 'Blocked'}</div>
        </div>`).join('');
    }

    /* Fix recommendation */
    const blockedBots = results.filter(r => !r.allowed);
    if (blockedBots.length > 0 && fixEl && fixCodeEl) {
      fixEl.style.display = 'block';
      fixCodeEl.textContent = blockedBots.map(b => `User-agent: ${b.name}\nAllow: /`).join('\n\n');
    } else if (fixEl) {
      fixEl.style.display = 'none';
    }

    if (resultsEl) resultsEl.style.display = 'block';

  } catch (err) {
    if (errorEl) {
      const msg = (err as Error)?.message || '';
      errorEl.textContent = `Could not fetch robots.txt for ${url}. ${msg ? 'Reason: ' + msg + '. ' : ''}Try a different domain, or check if the site is publicly accessible.`;
      errorEl.style.display = 'block';
    }
  }

  if (btnTxt) btnTxt.textContent = 'Check access';
});

/* Raw toggle */
document.getElementById('rtcRawToggle')?.addEventListener('click', () => {
  const raw = document.getElementById('rtcRaw');
  const btn = document.getElementById('rtcRawToggle') as HTMLButtonElement | null;
  if (!raw || !btn) return;
  const visible = raw.style.display !== 'none';
  raw.style.display = visible ? 'none' : 'block';
  btn.textContent = visible ? 'View raw robots.txt ↓' : 'Hide raw robots.txt ↑';
  btn.setAttribute('aria-expanded', String(!visible));
});

/* Copy fix code */
document.getElementById('rtcCopyBtn')?.addEventListener('click', () => {
  const code = document.getElementById('rtcFixCode')?.textContent || '';
  navigator.clipboard.writeText(code).then(() => {
    const btn = document.getElementById('rtcCopyBtn');
    if (btn) { btn.textContent = 'Copied'; setTimeout(() => { btn.textContent = 'Copy'; }, 2000); }
  });
});

/* Enter key in URL field */
(document.getElementById('rtcUrl') as HTMLInputElement)?.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter') (document.getElementById('rtcCheckBtn') as HTMLButtonElement)?.click();
});
</script>
</Layout>
