    }
    html.light .art-au-soc-threads { filter: none; opacity: 0.82; }
    .art-au-socials a:hover .art-au-soc-threads { filter: invert(1) brightness(1.2); opacity: 1; }
    html.light .art-au-socials a:hover .art-au-soc-threads { filter: none; opacity: 1; }

    .art-au-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      box-sizing: border-box;
      font-family: var(--fu), sans-serif;
      font-size: 13px;
      font-weight: 700;
      padding: 12px 16px;
      border-radius: 999px;
      color: #fff;
      text-decoration: none;
      background: var(--ag);
      background-size: 220% 100%;
      animation: resAuCtaShift 6s linear infinite;
      transition: filter 0.25s, box-shadow 0.25s;
      box-shadow: 0 4px 18px rgba(79, 142, 247, 0.2);
    }
    .art-au-cta:hover { filter: brightness(1.05); box-shadow: 0 6px 22px rgba(79, 142, 247, 0.26); }
    .art-au-cta:focus-visible { outline: 2px solid var(--ac); outline-offset: 3px; }
    .art-au-socials a:focus-visible { outline: 2px solid var(--ac); outline-offset: 2px; }

    @media (prefers-reduced-motion: reduce) {
      .art-au-hero-sweep { animation: none; opacity: 0.2; }
      .art-au-cta { animation: none; background-size: 100% 100%; }
    }

    /* Newsletter card */
    .art-nl-card {
      background: var(--s1);
      border: 1px solid var(--bd);
      border-radius: 16px;
      padding: 22px 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .art-nl-tag {
      font-family: var(--fm);
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ac);
      display: flex;
      align-items: center;
      gap: 7px;
      margin: 0;
    }
    .art-nl-h {
      font-family: var(--fd);
      font-size: clamp(22px, 2.2vw, 28px);
      font-weight: 400;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--w);
      margin: 0;
    }
    .art-nl-h em { font-style: italic; }
    .art-nl-deck {
      font-family: var(--fu);
      font-size: 13px;
      line-height: 1.65;
      color: var(--wd);
      margin: 0;
    }
    .art-nl-field {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 2px;
    }
    .art-nl-inp {
      width: 100%;
      box-sizing: border-box;
      background: var(--s2);
      border: 1px solid var(--bd);
      border-radius: 10px;
      padding: 12px 14px;
      font-family: var(--fu);
      font-size: 13px;
      color: var(--w);
      outline: none;
      transition: border-color 0.2s, background 0.2s;
    }
    .art-nl-inp::placeholder { color: var(--wm); }
    .art-nl-inp:focus { border-color: var(--ac); background: var(--s3); }
    .art-nl-btn { width: 100%; justify-content: center; font-size: 13px; padding: 12px 16px; }
    .art-nl-msg {
      font-family: var(--fm);
      font-size: 9px;
      letter-spacing: 0.06em;
      color: var(--wm);
      margin: 0;
      min-height: 14px;
    }
    .art-nl-msg.ok { color: var(--green); }
    .art-nl-msg.err { color: #EF4444; }
    .art-nl-note {
      font-family: var(--fm);
      font-size: 9px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--wm);
      margin: 0;
    }
    .art-nl-divider {
      height: 1px;
      background: var(--bd);
      margin: 4px 0 2px;
    }
    .art-nl-stack-l {
      font-family: var(--fu);
      font-size: 12px;
      line-height: 1.55;
      color: var(--wd);
      margin: 0;
    }
    .art-nl-logos {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }
    .art-nl-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      aspect-ratio: 1;
      border-radius: 10px;
      border: 1px solid var(--bd);
      background: var(--s2);
      padding: 10px;
      transition: border-color 0.2s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .art-nl-logo:hover { border-color: rgba(79, 142, 247, 0.45); transform: translateY(-2px); }
    .art-nl-logo img { width: 24px; height: 24px; object-fit: contain; display: block; }
    .art-nl-logo.is-dark img { filter: brightness(0) invert(1); opacity: 0.9; }
    html.light .art-nl-logo.is-dark img { filter: none; opacity: 0.88; }
    .art-nl-quote {
      margin: 0;
      padding: 14px 0 0;
      border-top: 1px solid var(--bd);
    }
    .art-nl-quote p {
      font-family: var(--fd);
      font-style: italic;
      font-size: 14px;
      line-height: 1.55;
      color: var(--wd);
      margin: 0;
    }
    .art-nl-quote a {
      color: var(--ac);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: rgba(79, 142, 247, 0.45);
    }
    .art-nl-quote a:hover { color: #B8D4FF; }

    .art-hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; opacity: 0; pointer-events: none; }
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }

    .rs-faq-sec {
      padding: 0 0 80px;
    }

    @media (max-width: 1024px) {
      .res-layout {
        grid-template-columns: 1fr;
      }
      .res-side-col {
        position: static;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 16px;
      }
      .res-side-col .art-au-card,
      .res-side-col .art-nl-card {
        flex: 1 1 320px;
      }
    }
    @media (max-width: 640px) {
      .res-side-col { flex-direction: column; }
    }
    @media (max-width: 640px) {
      .res-panel-mid {
        grid-template-columns: 1fr;
      }
      .res-ic {
        width: 44px;
        height: 44px;
      }
      .res-form-row {
        flex-direction: column;
      }
      .res-btn {
        width: 100%;
      }
      .res-panel-meta {
        justify-content: flex-start;
      }
      .res-panel-hd {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>

  <script>
    const prog = document.getElementById('scrollProg');
    window.addEventListener(
      'scroll',
      () => {
        if (prog) {
          const s = document.documentElement;
          prog.style.width = (s.scrollTop / (s.scrollHeight - s.clientHeight)) * 100 + '%';
        }
      },
      { passive: true },
    );

    const markStart = (f: HTMLFormElement) => {
      if (!f.dataset.mountedAt) f.dataset.mountedAt = String(Date.now());
    };

    // ─── Sidebar newsletter (mirrors /insights/[slug] form) ───
    const sForm = document.getElementById('sidebarForm') as HTMLFormElement | null;
    if (sForm) sForm.dataset.mountedAt = String(Date.now());
    const sEmail = document.getElementById('sidebarEmail') as HTMLInputElement | null;
    const sMsg = document.getElementById('sidebarMsg');
    const sBtnTxt = document.getElementById('sidebarBtnTxt');
    sForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = sEmail?.value.trim();
      if (!email) return;
      const honey = (document.getElementById('sidebarHoney') as HTMLInputElement | null)?.value?.trim() || '';
      const mountedAt = parseInt(sForm?.dataset.mountedAt || '0', 10) || Date.now();
      const btn = sForm.querySelector('#sidebarBtn') as HTMLButtonElement | null;
      if (sBtnTxt) sBtnTxt.textContent = 'Sending...';
      if (btn) btn.disabled = true;
      if (sMsg) {
        sMsg.textContent = '';
        sMsg.className = 'art-nl-msg';
      }
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { accept: 'application/json', 'content-type': 'application/json' },
          body: JSON.stringify({
            email,
            website: honey,
            mountedAt,
            leadSource: 'resources-newsletter',
          }),
        });
        const data = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };
        if (res.ok && data.ok) {
          if (sMsg) {
            sMsg.textContent = 'You are in. Check your inbox.';
            sMsg.className = 'art-nl-msg ok';
          }
          if (sBtnTxt) sBtnTxt.textContent = 'Joined ✓';
          if (sEmail) sEmail.value = '';
        } else {
          const errText = typeof data.error === 'string' && data.error ? data.error : 'Could not subscribe. Try again.';
          if (sMsg) {
            sMsg.textContent = errText;
            sMsg.className = 'art-nl-msg err';
          }
          if (sBtnTxt) sBtnTxt.textContent = 'Join free';
        }
      } catch {
        if (sMsg) {
          sMsg.textContent = 'Network error. Check your connection and try again.';
          sMsg.className = 'art-nl-msg err';
        }
        if (sBtnTxt) sBtnTxt.textContent = 'Join free';
      } finally {
        if (btn) btn.disabled = false;
      }
    });

    document.querySelectorAll('.res-form').forEach((node) => {
      if (!(node instanceof HTMLFormElement)) return;
      const f = node;
      const emailEl = f.querySelector('.res-input');
      const btn = f.querySelector('.res-btn');
      if (emailEl instanceof HTMLInputElement) {
        emailEl.addEventListener('focus', () => markStart(f), { passive: true });
        emailEl.addEventListener('input', () => markStart(f), { passive: true });
      }
      btn?.addEventListener('focus', () => markStart(f), { passive: true });

      f.addEventListener('submit', async (e) => {
        e.preventDefault();
        const emailInput = f.querySelector('.res-input');
        const hp = f.querySelector('.res-hp');
        const msgEl = f.parentElement?.querySelector('.res-form-msg');
        const btnTxt = f.querySelector('.res-btn-txt');
        const resourceId = f.dataset.resourceId || '';
        const resourceTitle = f.dataset.resourceTitle || '';
        const email = emailInput instanceof HTMLInputElement ? emailInput.value.trim() : '';
        const website = hp instanceof HTMLInputElement ? hp.value : '';
        const mountedAt = parseInt(f.dataset.mountedAt || '0', 10) || 0;
        if (!email) return;
        if (btnTxt) btnTxt.textContent = 'Sending...';
        if (msgEl) {
          msgEl.textContent = '';
          msgEl.className = 'res-form-msg';
        }
        try {
          const res = await fetch('/api/resource-gate', {
            method: 'POST',
            headers: { accept: 'application/json', 'content-type': 'application/json' },
            body: JSON.stringify({ email, website, mountedAt, resourceId, resourceTitle }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data && data.ok) {
            if (msgEl) {
              msgEl.textContent = typeof data.message === 'string' ? data.message : 'Check your inbox.';
              msgEl.className = 'res-form-msg ok';
            }
            if (btnTxt) btnTxt.textContent = 'Sent';
            if (emailInput instanceof HTMLInputElement) emailInput.value = '';
            f.dataset.mountedAt = '';
            if (typeof gtag === 'function') gtag('event', 'sign_up', { event_category: 'resource_download', event_label: resourceId || 'unknown' });
          } else {
            const errText = typeof data.error === 'string' ? data.error : 'Request failed.';
            throw new Error(errText);
          }
        } catch (err) {
          if (msgEl) {
            const fallback = 'Something went wrong. Email shivamattri27@gmail.com';
            const detail = err instanceof Error && err.message && err.message !== 'fail' ? err.message : fallback;
            msgEl.textContent = detail.length > 420 ? fallback : detail;
            msgEl.className = 'res-form-msg err';
          }
          if (btnTxt) btnTxt.textContent = 'Request download';
        }
      });
    });
  </script>
</Layout>
