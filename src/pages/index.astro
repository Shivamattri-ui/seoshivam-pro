function runSERP(){
  const posEl=document.getElementById('srRank');const dEl=document.getElementById('srDelta');
  if(!posEl||!dEl)return;
  const rankEl=posEl;const deltaEl=dEl;
  const start=48,end=3,dur=4500;const s=performance.now();
  function step(now:number){
    const p=Math.min((now-s)/dur,1),ease=1-Math.pow(1-p,2);
    const pos=Math.round(start-ease*(start-end));
    rankEl.textContent=String(pos);
    if(pos<start)deltaEl.textContent=`↑${start-pos}`;
    if(p<1)requestAnimationFrame(step);
    else setTimeout(()=>{
      gsap.to(rankEl,{opacity:0,duration:0.3,onComplete:()=>{rankEl.textContent='48';deltaEl.textContent='—';gsap.to(rankEl,{opacity:1,duration:0.3});setTimeout(runSERP,1500);}});
    },3000);
  }
  requestAnimationFrame(step);
}
