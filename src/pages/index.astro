// ── Count up ──
function countUp(el:Element,end:number,suf:string,dur=1400){
  const isF=String(end).includes('.');
  const s=performance.now();
  (function step(now){
    const p=Math.min((now-s)/dur,1),ease=1-Math.pow(1-p,3),v=end*ease;
    el.textContent=(isF?v.toFixed(1):Math.floor(v).toLocaleString())+suf;
    if(p<1)requestAnimationFrame(step);
  })(performance.now());
}
const coObs=new IntersectionObserver((e)=>{
  e.forEach(en=>{
    if(en.isIntersecting&&(en.target as HTMLElement).dataset.count){
      countUp(en.target,parseFloat((en.target as HTMLElement).dataset.count||'0'),(en.target as HTMLElement).dataset.suf||'');
      coObs.unobserve(en.target);
    }
  });
},{threshold:0.5});
document.querySelectorAll('[data-count]').forEach(el=>coObs.observe(el));
 
