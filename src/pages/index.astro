.pseo-tile{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;padding:5px 10px;border-radius:6px;border:1px solid var(--bd);background:var(--bg);color:var(--wd);animation:pseoTile 4s ease-in-out infinite}
