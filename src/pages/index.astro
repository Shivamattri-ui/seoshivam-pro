.pd-schema-badge{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;color:var(--green);background:rgba(34,197,94,.06);border-top:1px solid rgba(34,197,94,.12);padding:8px 14px}

