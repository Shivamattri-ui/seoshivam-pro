const opTermBody = document.getElementById('opTermBody');
if (opTermBody) {
  const opEntries: {t:string; b:string; a:string; cite?:boolean}[] = [
    {t:'11:42:08', b:'GPTBot',          a:'crawled /insights/what-is-aeo'},
    {t:'11:42:14', b:'PerplexityBot',   a:'cited seoshivam.pro for "AEO checklist"', cite:true},
    {t:'11:42:21', b:'ClaudeBot',       a:'fetched /services/aeo'},
    {t:'11:42:33', b:'Google-Extended', a:'indexed FAQPage schema'},
    {t:'11:42:48', b:'GPTBot',          a:'cited seoshivam.pro in answer', cite:true},
    {t:'11:43:02', b:'OAI-SearchBot',   a:'crawled /work'},
    {t:'11:43:15', b:'anthropic-ai',    a:'fetched /insights/schema-markup-for-ai-search'},
    {t:'11:43:29', b:'Bingbot',         a:'indexed Person + WebSite JSON-LD'},
    {t:'11:43:42', b:'PerplexityBot',   a:'cited seoshivam.pro for "AEO vs SEO"', cite:true},
    {t:'11:43:55', b:'CCBot',           a:'crawled /insights/google-ai-overviews-optimization'},
  ];
  let opIdx = 0;
  const pushOpEntry = ()=>{
    const e = opEntries[opIdx % opEntries.length];
    const row = document.createElement('div');
    row.className = 'op-term-row' + (e.cite ? ' otr-cite' : '');
    const time = document.createElement('span'); time.className='otr-time'; time.textContent=e.t;
    const bot  = document.createElement('span'); bot.className='otr-bot';   bot.textContent=e.b;
    const act  = document.createElement('span'); act.className='otr-act';   act.textContent=(e.cite?'▸ ':'')+e.a;
    row.appendChild(time); row.appendChild(bot); row.appendChild(act);
    opTermBody.appendChild(row);
    while (opTermBody.children.length > 7) opTermBody.removeChild(opTermBody.firstChild as Node);
    opIdx++;
  };
  for (let i = 0; i < 4; i++) pushOpEntry();
  let opTermInt: ReturnType<typeof setInterval> | null = setInterval(pushOpEntry, 3200);
  // Pause when offscreen to save CPU
  const opVis = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if (e.isIntersecting && !opTermInt) opTermInt = setInterval(pushOpEntry, 3200);
      else if (!e.isIntersecting && opTermInt) { clearInterval(opTermInt); opTermInt = null; }
    });
  }, {threshold: 0});
  opVis.observe(opTermBody);
}

// ── Magnetic CTA buttons (subtle hover attraction) ──
document.querySelectorAll<HTMLElement>('.op-cta-mag').forEach(btn=>{
  let raf = 0;
  btn.addEventListener('mousemove',(e)=>{
    const r = btn.getBoundingClientRect();
    const dx = ((e.clientX - r.left) / r.width - 0.5) * 10;
    const dy = ((e.clientY - r.top) / r.height - 0.5) * 8;
    cancelAnimationFrame(raf);
    raf = requestAnimationFrame(()=>{ btn.style.transform = `translate(${dx}px,${dy}px)`; });
  });
  btn.addEventListener('mouseleave',()=>{
    cancelAnimationFrame(raf);
    btn.style.transform = '';
  });
});

