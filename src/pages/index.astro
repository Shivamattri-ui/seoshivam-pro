// ── Process timeline: scroll-LINKED spine fill (continuous, bidirectional, premium) ──
(function procTimelineInit(){
  const flow = document.querySelector<HTMLElement>('[data-proc-flow]');
  const fill = document.getElementById('procSpineFill');
  if (!flow || !fill) return;
  const steps = Array.from(flow.querySelectorAll<HTMLElement>('.proc-step'));
  if (!steps.length) return;

  // Smooth interpolation for buttery-smooth scroll feel
  let targetProgress = 0;
  let currentProgress = 0;
  let rafId = 0;

  const compute = ()=>{
    const flowRect = flow.getBoundingClientRect();
    const vh = window.innerHeight;
    // Trigger zone: spine starts filling when section top hits 70% viewport,
    // finishes when section bottom hits 30% viewport
    const startY = vh * 0.7;
    const endY = vh * 0.3;
    const span = (flowRect.height) - (startY - endY);
    if (span <= 0) return;
    const traveled = startY - flowRect.top;
    targetProgress = Math.max(0, Math.min(1, traveled / span));

    // Light up steps based on which markers have crossed viewport midline
    const markerOffset =
      window.innerWidth <= 480 ? 40 : window.innerWidth <= 768 ? 42 : 48;
    steps.forEach((step)=>{
      const stepRect = step.getBoundingClientRect();
      const markerY = stepRect.top + markerOffset;
      const lit = markerY < vh * 0.62;
      step.classList.toggle('in', lit);
    });
  };

  const tick = ()=>{
    // Lerp toward target for silky smooth motion
    currentProgress += (targetProgress - currentProgress) * 0.12;
    if (Math.abs(targetProgress - currentProgress) < 0.0008) {
      currentProgress = targetProgress;
    }
    fill.style.transform = `scaleY(${currentProgress})`;
    rafId = requestAnimationFrame(tick);
  };

  const onScroll = ()=>{ compute(); };

  // Start animation loop
  compute();
  currentProgress = targetProgress;
  fill.style.transform = `scaleY(${currentProgress})`;
  rafId = requestAnimationFrame(tick);

  window.addEventListener('scroll', onScroll, {passive:true});
  window.addEventListener('resize', ()=>{ compute(); }, {passive:true});

  // Pause animation when section is well off-screen to save CPU
  const visObs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if (e.isIntersecting) {
        if (!rafId) rafId = requestAnimationFrame(tick);
      } else {
        if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
      }
    });
  }, {rootMargin:'200px 0px 200px 0px'});
  visObs.observe(flow);
})();

// ── Interactive Case File viewer (tab switching + sliding underline) ──
(function caseFileInit(){
  const file = document.querySelector<HTMLElement>('[data-case-file]');
  if (!file) return;
  const tabs = Array.from(file.querySelectorAll<HTMLButtonElement>('.case-tab'));
  const panels = Array.from(file.querySelectorAll<HTMLElement>('.case-panel'));
  const rule = file.querySelector<HTMLElement>('#caseTabRule');
  if (!tabs.length || !panels.length || !rule) return;

  const positionRule = (tab: HTMLButtonElement) => {
    const wrap = tab.parentElement as HTMLElement;
    const wrapRect = wrap.getBoundingClientRect();
    const tabRect = tab.getBoundingClientRect();
    const x = tabRect.left - wrapRect.left + wrap.scrollLeft;
    rule.style.width = `${tabRect.width}px`;
    rule.style.transform = `translateX(${x}px)`;
  };

  const activate = (idx: number) => {
    tabs.forEach((t,i)=>{
      const on = i === idx;
      t.classList.toggle('active', on);
      t.setAttribute('aria-selected', String(on));
    });
    panels.forEach((p,i)=>{
      p.classList.toggle('active', i === idx);
    });
    const active = tabs[idx];
    if (active) positionRule(active);
  };

  tabs.forEach((tab,i)=>{
    tab.addEventListener('click', ()=>activate(i));
    // Hover preview: slide rule to hovered tab without switching
    tab.addEventListener('mouseenter', ()=>positionRule(tab));
  });
  // On mouseleave from tab strip, snap rule back to active
  const tabStrip = tabs[0]?.parentElement;
  tabStrip?.addEventListener('mouseleave', ()=>{
    const active = file.querySelector<HTMLButtonElement>('.case-tab.active');
    if (active) positionRule(active);
  });

  // Initial position (after fonts/layout settle)
  const initRule = ()=>{
    const active = file.querySelector<HTMLButtonElement>('.case-tab.active') || tabs[0];
    if (active) positionRule(active);
  };
  initRule();
  // Re-position on resize + after fonts load (handles late layout shift)
  window.addEventListener('resize', initRule, {passive:true});
  if ((document as any).fonts && (document as any).fonts.ready) {
    (document as any).fonts.ready.then(initRule);
  }
  // Reposition once section scrolls into view (handles initial off-screen layout)
  const visObs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if (e.isIntersecting) initRule(); });
  }, {threshold:0.05});
  visObs.observe(file);
})();
