.pseo-url{font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--green);word-break:break-all;line-height:1.5;padding:11px 14px;background:var(--bg);border:1px solid var(--bds);border-radius:8px;display:flex;align-items:center;gap:8px}
