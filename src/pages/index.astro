// ── Score form + lead form — routes through /api/subscribe (server-side key) ──
function markSubStart(form: HTMLFormElement) {
  if (!form.dataset.mountedAt || form.dataset.mountedAt === '0') {
    form.dataset.mountedAt = String(Date.now());
  }
}

async function postSubscribe(
  email: string,
  leadSource: string,
  website = '',
  mountedAt = 0,
): Promise<boolean> {
  try {
    const res = await fetch('/api/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, leadSource, website, mountedAt }),
    });
    const data = await res.json().catch(() => ({}));
    return (data as { ok?: boolean }).ok === true;
  } catch { return false; }
}

