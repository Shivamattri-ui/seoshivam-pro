.gads-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.gads-m{background:var(--bg);border:1px solid var(--bd);border-radius:10px;padding:11px 12px;display:flex;flex-direction:column;gap:4px}
