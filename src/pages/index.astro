---
import Layout from '../layouts/Layout.astro';
import { SITE_ROUTE_META } from '../lib/site-route-meta';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactCta from '../components/ContactCta.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);
const featuredPost = recentPosts.find(p => p.data.featured) || recentPosts[0];
const sidePosts = recentPosts.filter(p => p.id !== featuredPost?.id).slice(0, 4);

const catLabelsHome: Record<string,string> = {
  aeo: 'AEO',
  seo: 'SEO',
  'ai-search': 'AI Search',
  'web-design': 'Web Design',
};

// All client names withheld under NDA. Industries shown instead so
// the proof of breadth still lands without exposing any brand.
const clients = [
  'DAV Media','Dance Icons','Mibbles',
  'JMJ Creations','ChemicalX','Secure CAM',
  'RPS Logistics','Essence','Hotel White Stone',
  'YADS - By Yogi Arts','Handskart','Mittal Builders',
];
 
// No custom schema: let Layout emit the correct defaultSchema (Person + Organization + WebSite).
// FAQPage is emitted as a standalone script co-located with the visible FAQ section below.
---
 
<Layout title={SITE_ROUTE_META['/'].title} description={SITE_ROUTE_META['/'].description}>
 
<Nav />
 
<!-- Fixed backgrounds -->
<div class="grid-bg"></div>
<div class="rays-wrap">{Array.from({length:12}).map((_,i)=><div class="ray" style={`--i:${i}`}></div>)}</div>
<div class="scroll-prog" id="scrollProg"></div>
<div class="cur-dot" id="curDot"></div>
<div class="cur-ring" id="curRing"></div>

<main id="main-content">

<!-- ═══════════ 01 HERO — OPERATOR'S EDITORIAL ═══════════ -->
<section class="op-hero" id="hero">
  <div class="container">

    <!-- Top strip: file marker + working location + live clock -->
    <div class="op-strip rv">
      <span class="stamp">FILE/001 &middot; INDEX</span>
      <span class="op-meta hide-mob">India <span class="op-arrow">&rarr;</span> Worldwide</span>
      <span class="op-spacer"></span>
      <span class="op-clock" id="opClock" aria-live="off">
        <span class="opc-time">--:--:--</span>
        <span class="opc-zone">IST &middot; GMT+5:30</span>
      </span>
    </div>

    <!-- Editorial displaced headline + marginalia -->
    <div class="op-h-wrap">
      <h1 class="op-h">
        <span class="op-line op-line-1 rv d1">Founders</span>
        <span class="op-line op-line-2 rv d2">building <span class="grad-anim">in the dark.</span></span>
        <span class="op-line op-line-3 rv d3"><em>AI sees you</em> now.</span>
      </h1>

      <aside class="op-marg marg rv d4">
        Filed by <a href="/about" class="ilink-muted" style="font-style:normal;font-family:var(--fu);font-weight:700;font-size:11px;letter-spacing:.06em;color:var(--w)">SHIVAM ATTRI</a>.
        An operator's notebook on AEO, SEO, and AI&#8209;visible web design, written for B2B SaaS founders done playing yesterday's game.
      </aside>
    </div>

    <!-- Lead deck + live indexing terminal -->
    <div class="op-sub-grid rv d5">
      <div class="op-lead">
        <p class="op-deck">
          You are spending on ads because organic never compounded.
          <strong>That is not an SEO problem. That is an <a href="/services/aeo" class="ilink">AI visibility problem</a>.</strong>
          I build <a href="/insights/topical-authority-saas-playbook" class="ilink">content systems</a> and <a href="/services/web-design" class="ilink">AI-visible websites</a> that make AI engines cite you before your competitor knows the game changed.
        </p>
        <div class="op-cta-row">
          <a href="#tool" class="btn-p mag op-cta-mag">Check AI score &middot; 60s</a>
          <a href="/work" class="btn-s mag op-cta-mag">See real results &rarr;</a>
        </div>
      </div>

      <!-- Live indexing terminal: real AI bot activity feel -->
      <div class="op-term scan" aria-hidden="true">
        <div class="op-term-bar">
          <div class="op-term-dots"><span></span><span></span><span></span></div>
          <span class="op-term-title">live_index.log</span>
          <span class="tick">Live</span>
        </div>
        <div class="op-term-body" id="opTermBody"></div>
      </div>
    </div>

    <!-- Bottom: editorial pull statement (replaces 4-stat SaaS row) -->
    <div class="op-pull rv d6">
      <div class="op-pull-num">
        <span class="grad-anim">63 &rarr; 1,010</span>
      </div>
      <div class="op-pull-meta">
        <div class="stamp dim">CASE 001 &middot; HEALTHTECH SAAS &middot; INDIA &middot; 30 DAYS &middot; ZERO AD SPEND</div>
        <p class="op-pull-text">
          One client. Organic clicks compounding from below the noise floor into category-defining traffic.
          <a href="/work" class="op-pull-link">Read the case file &rarr;</a>
        </p>
      </div>
    </div>

  </div>
</section>
 
<!-- ═══════════ MARQUEE ═══════════ -->
<div class="mq-wrap">
  <div class="mq-fl"></div><div class="mq-fr"></div>
  <p class="mq-label">Brands worked with: India · US · UK · EU · AU</p>
  <div class="mq-track">
    {[...clients,...clients].map(n=><span class="mq-i">{n}</span>)}
  </div>
</div>
 
<!-- ═══════════ 02 PROBLEM ═══════════ -->
<!-- ═══════════ 02 MANIFESTO — editorial spread, no cards ═══════════ -->
<section class="man-sec" id="problem">
  <div class="container">
    <header class="man-hdr rv">
      <div class="hair left">REALITY &middot; APR 2026 / NUMBERS THAT FORCED THIS WORK</div>
      <h2 class="man-h">Search changed.<br><em class="grad-anim">Most SEO did not.</em></h2>
    </header>

    <!-- Asymmetric editorial spread — big stat dominates, two recede -->
    <div class="man-spread">
      <article class="man-stat man-stat-1 rv d1" data-stat>
        <span class="man-tag">SOURCE / SPARKTORO &middot; 2024</span>
        <div class="man-num grad-anim" data-count="63" data-suf="%">0%</div>
        <p class="man-text">
          of Google searches now end <strong>without a click.</strong>
          AI Overviews answer before the user reaches a single website.
        </p>
        <span class="man-rule"></span>
      </article>

      <article class="man-stat man-stat-2 rv d2" data-stat>
        <span class="man-tag">SOURCE / OPENAI &middot; NOV 2024</span>
        <div class="man-num grad-anim" data-count="200" data-suf="M+">0M+</div>
        <p class="man-text">
          weekly ChatGPT users searching for <strong>vendor recommendations</strong>, without opening Google at all.
        </p>
        <span class="man-rule"></span>
      </article>

      <article class="man-stat man-stat-3 rv d3" data-stat>
        <span class="man-tag">SOURCE / SEMRUSH &middot; 2024</span>
        <div class="man-num grad-anim" data-count="47" data-suf="%">0%</div>
        <p class="man-text">
          of informational searches now trigger a <strong>Google AI Overview.</strong>
          Up from 11% at launch in May 2023.
        </p>
        <span class="man-rule"></span>
      </article>
    </div>

    <!-- Editorial pull quote (replaces manifesto card) -->
    <blockquote class="man-pull rv d4">
      <p class="man-pull-body">
        Google AI Overviews, ChatGPT, and Perplexity are replacing the moment a buyer decides who to trust. If your content is not structured to be cited by these engines, you are invisible at the exact moment it matters most.
      </p>
      <cite class="man-pull-cite">
        <span class="grad-anim">Traditional SEO gets you to page one. AEO gets you into the answer.</span>
      </cite>
    </blockquote>
  </div>
</section>

<!-- ═══════════ 03 CASE FILE — interactive viewer, no cards ═══════════ -->
<section class="case-sec" id="results">
  <div class="container">
    <header class="case-hdr rv">
      <div class="hair left">CASE FILES / GSC VERIFIED &middot; CLIENT NAMES WITHHELD UNDER NDA</div>
      <h2 class="case-h">Numbers from<br><em>real work.</em></h2>
    </header>

    <!-- Single interactive case file with 3 tabs -->
    <div class="case-file" data-case-file>
      <div class="case-tabs" role="tablist" aria-label="Case studies">
        <button class="case-tab active" role="tab" data-case="0" aria-selected="true">
          <span class="case-tab-num">001</span>
          <span class="case-tab-name">HealthTech SaaS</span>
          <span class="case-tab-meta">India &middot; 30 days</span>
        </button>
        <button class="case-tab" role="tab" data-case="1" aria-selected="false">
          <span class="case-tab-num">002</span>
          <span class="case-tab-name">Health Tech</span>
          <span class="case-tab-meta">US &middot; Q4 YoY</span>
        </button>
        <button class="case-tab" role="tab" data-case="2" aria-selected="false">
          <span class="case-tab-num">003</span>
          <span class="case-tab-name">B2B Services</span>
          <span class="case-tab-meta">Organic leads</span>
        </button>
        <span class="case-tab-rule" id="caseTabRule" aria-hidden="true"></span>
      </div>

      <div class="case-stage" id="caseStage">

        <!-- Case 001 -->
        <article class="case-panel active" data-panel="0">
          <div class="case-panel-grid">
            <div class="case-num-col">
              <div class="case-num-tag">CLICK GROWTH</div>
              <div class="case-num-big grad-anim" data-count="16" data-suf="&times;">16&times;</div>
              <div class="case-num-sub">in 30 days &middot; zero ad spend</div>
            </div>
            <div class="case-narr">
              <p class="case-narr-deck">
                Entity-first content architecture, schema rebuild, and answer-first restructure. <strong>Organic compounding from below the noise floor into the engine of growth.</strong>
              </p>
              <p class="case-narr-body">
                Took the site from technical debt with no semantic structure to a properly indexed entity. Six pieces of pillar content, 11 cluster posts, and a single page that dominates an entire intent cluster.
              </p>
            </div>
          </div>
          <div class="case-metrics">
            <div class="case-m"><span class="case-m-l">Organic clicks</span><span class="case-m-v"><span class="cmf">63</span> <span class="cmar">&rarr;</span> <span class="cmt grad-anim">1,010</span></span></div>
            <div class="case-m"><span class="case-m-l">Impressions</span><span class="case-m-v"><span class="cmf">5.95K</span> <span class="cmar">&rarr;</span> <span class="cmt grad-anim">127K</span></span></div>
            <div class="case-m"><span class="case-m-l">Avg position</span><span class="case-m-v"><span class="cmf">48.5</span> <span class="cmar">&rarr;</span> <span class="cmt grad-anim">31.5</span></span></div>
            <div class="case-m"><span class="case-m-l">Duration</span><span class="case-m-v"><span class="cmt">30 days</span></span></div>
          </div>
          <footer class="case-foot">
            <span class="case-stamp">SOURCE / GOOGLE SEARCH CONSOLE &middot; 2024-2025</span>
            <span class="case-verified"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> Screenshots on request</span>
          </footer>
        </article>

        <!-- Case 002 -->
        <article class="case-panel" data-panel="1">
          <div class="case-panel-grid">
            <div class="case-num-col">
              <div class="case-num-tag">IMPRESSION SCALE</div>
              <div class="case-num-big grad-anim" data-count="3" data-suf="&times;">3&times;</div>
              <div class="case-num-sub">held position while expanding</div>
            </div>
            <div class="case-narr">
              <p class="case-narr-deck">
                AEO layer added on top of a mature SEO foundation. <strong>20+ tracked AI engine citations</strong> across ChatGPT, Perplexity, and Google AI Overviews in a single quarter.
              </p>
              <p class="case-narr-body">
                Health Tech operating in a regulated US category. Built FAQPage schema across 30+ pages, restructured pillars by patient intent, and instrumented citation tracking so we knew exactly when AI engines started picking us up.
              </p>
            </div>
          </div>
          <div class="case-metrics">
            <div class="case-m"><span class="case-m-l">Impressions</span><span class="case-m-v"><span class="cmf">94.8K</span> <span class="cmar">&rarr;</span> <span class="cmt grad-anim">300K</span></span></div>
            <div class="case-m"><span class="case-m-l">Clicks</span><span class="case-m-v"><span class="cmf">6.53K</span> <span class="cmar">&rarr;</span> <span class="cmt grad-anim">11.2K</span></span></div>
            <div class="case-m"><span class="case-m-l">Avg position</span><span class="case-m-v"><span class="cmt">held 13-14</span></span></div>
            <div class="case-m"><span class="case-m-l">AI citations</span><span class="case-m-v"><span class="cmt grad-anim">20+</span></span></div>
          </div>
          <footer class="case-foot">
            <span class="case-stamp">SOURCE / GOOGLE SEARCH CONSOLE &middot; 2025</span>
            <span class="case-verified"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> Screenshots on request</span>
          </footer>
        </article>

        <!-- Case 003 -->
        <article class="case-panel" data-panel="2">
          <div class="case-panel-grid">
            <div class="case-num-col">
              <div class="case-num-tag">ORGANIC LEADS</div>
              <div class="case-num-big grad-anim" data-count="4.7" data-suf="&times;">4.7&times;</div>
              <div class="case-num-sub">paid dependency down 40%</div>
            </div>
            <div class="case-narr">
              <p class="case-narr-deck">
                Topical authority rebuild plus schema implementation across the funnel. <strong>First month of revenue driven purely by organic</strong> in the company's history.
              </p>
              <p class="case-narr-body">
                B2B services category with strong category competition. Compounding strategy: top-10 keywords expanded 5x, organic leads 4.7x, and paid ad spend reduced because organic finally started carrying its weight.
              </p>
            </div>
          </div>
          <div class="case-metrics">
            <div class="case-m"><span class="case-m-l">Top-10 keywords</span><span class="case-m-v"><span class="cmf">40</span> <span class="cmar">&rarr;</span> <span class="cmt grad-anim">220</span></span></div>
            <div class="case-m"><span class="case-m-l">Organic leads / mo</span><span class="case-m-v"><span class="cmf">15</span> <span class="cmar">&rarr;</span> <span class="cmt grad-anim">70+</span></span></div>
            <div class="case-m"><span class="case-m-l">Paid dependency</span><span class="case-m-v"><span class="cmt grad-anim">-40%</span></span></div>
            <div class="case-m"><span class="case-m-l">Duration</span><span class="case-m-v"><span class="cmt">60 days</span></span></div>
          </div>
          <footer class="case-foot">
            <span class="case-stamp">SOURCE / GSC + CRM DATA &middot; 2024</span>
            <span class="case-verified"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> Screenshots on request</span>
          </footer>
        </article>

      </div>
    </div>
  </div>
</section>
 
<!-- ═══════════ 04 SERVICES (sticky card stack) ═══════════ -->
<section class="svc-sec" id="services">
  <div class="container">
    <div class="rv" style="margin-bottom:56px">
      <div class="label">What I do</div>
      <h2 class="sec-h" style="margin-top:14px">Built for where<br><em>search is going.</em></h2>
    </div>
  </div>

  <!-- Sticky card stack — cards slide over each other on scroll -->
  <div class="svc-cards-wrap">
    <!-- Card 1: AEO -->
    <div class="svc-card" id="svc1">
      <div class="svc-card-inner">
        <div class="svc-content">
          <div class="svc-num">01 / Core Service</div>
          <h3 class="svc-title">AEO + AI Search Visibility</h3>
          <p class="svc-desc">Entity architecture, technical crawl fixes, and answer-first content that gets your brand cited in ChatGPT, Perplexity, Claude, and Google AI Overviews. A system built across 30+ brands in the US, UK, EU, and Australia, not a tactic checklist.</p>
          <div class="svc-tags">
            <span class="tag-chip">AI Citation Tracking</span><span class="tag-chip">Entity Schema</span>
            <span class="tag-chip">Answer-First Content</span><span class="tag-chip">Technical Architecture</span>
            <span class="tag-chip">6 AI Engines</span>
          </div>
          <a href="/services/aeo" class="btn-s" style="margin-top:24px">Learn more →</a>
        </div>
        <div class="svc-visual">
          <div class="aio-demo" id="aioDemo">
            <div class="aio-search">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5C5954" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <span>best aeo specialist for b2b saas</span>
            </div>
            <div class="aio-box">
              <div class="aio-header">
                <div class="aio-badge">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#4F8EF7" stroke-width="2" stroke-linecap="round"/></svg>
                  AI Overview
                </div>
                <div class="aio-sources"><span class="aio-src">seoshivam.pro</span><span class="aio-src">+3 sources</span></div>
              </div>
              <p class="aio-text" id="aioText"></p>
              <div class="aio-cite"><div class="aio-cite-chip"><span class="adot" style="width:5px;height:5px"></span>seoshivam.pro · cited source</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 2: SEO -->
    <div class="svc-card" id="svc2">
      <div class="svc-card-inner">
        <div class="svc-content">
          <div class="svc-num">02 / Foundation</div>
          <h3 class="svc-title">SEO Strategy & Architecture</h3>
          <p class="svc-desc">Technical audits, content architecture, keyword and entity mapping, on-page execution, and topical authority systems. The compounding organic channel that outlasts any ad budget.</p>
          <div class="svc-tags">
            <span class="tag-chip">Technical SEO</span><span class="tag-chip">Content Architecture</span>
            <span class="tag-chip">Programmatic SEO</span><span class="tag-chip">Core Web Vitals</span>
            <span class="tag-chip">Internal Linking</span>
          </div>
          <a href="/services/seo" class="btn-s" style="margin-top:24px">Learn more →</a>
        </div>
        <div class="svc-visual">
          <div class="serp-demo" id="serpDemo">
            <div class="serp-sb">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#5C5954" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <span class="serp-q" id="serpQ">aeo specialist for saas brands</span>
            </div>
            <div class="serp-rows">
              <div class="serp-row target-row">
                <div class="sr-rank" id="srRank">48</div>
                <div class="sr-info"><div class="sr-url">seoshivam.pro</div><div class="sr-title">AEO Specialist for SaaS: Shivam Attri</div></div>
                <div class="sr-delta" id="srDelta">--</div>
              </div>
              <div class="serp-row"><div class="sr-rank dim">12</div><div class="sr-info"><div class="sr-url dim">competitor-seo.com</div><div class="sr-title dim">SEO Services for B2B</div></div></div>
              <div class="serp-row"><div class="sr-rank dim">15</div><div class="sr-info"><div class="sr-url dim">another-agency.io</div><div class="sr-title dim">B2B SEO Strategy</div></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 3: Web Design -->
    <div class="svc-card" id="svc3">
      <div class="svc-card-inner">
        <div class="svc-content">
          <div class="svc-num">03 / Build</div>
          <h3 class="svc-title">AI-Visible Web Design</h3>
          <p class="svc-desc">Webflow, Framer, Astro, and WordPress sites structured for AI crawlability from day one. Schema markup, semantic HTML, bot-accessible architecture, and design that converts international buyers.</p>
          <div class="svc-tags">
            <span class="tag-chip">Webflow</span><span class="tag-chip">Framer</span>
            <span class="tag-chip">Astro</span><span class="tag-chip">WordPress</span>
            <span class="tag-chip">Schema Markup</span><span class="tag-chip">Next.js</span>
          </div>
          <a href="/services/web-design" class="btn-s" style="margin-top:24px">Learn more →</a>
        </div>
        <div class="svc-visual">
          <div class="platform-demo" id="platformDemo">
            <div class="pd-tabs">
              {['Webflow','Framer','Astro','WordPress'].map((p,i)=>(
                <button class={`pd-tab${i===0?' act':''}`} data-platform={p}>{p}</button>
              ))}
            </div>
            <div class="pd-screen" id="pdScreen">
              <div class="pd-browser">
                <div class="pd-bbar"><div class="pd-bdots"><span></span><span></span><span></span></div><div class="pd-burl" id="pdUrl">webflow.seoshivam.pro</div></div>
                <div class="pd-bcanvas" id="pdCanvas">
                  <div class="pd-nav-ph"></div><div class="pd-hero-ph"></div>
                  <div class="pd-cards-ph"><div></div><div></div><div></div></div>
                </div>
                <div class="pd-schema-badge">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                  Schema validated · AI-ready
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scale & ops: same sticky stack + interactive demos as core services -->
  <div class="container svc-more-hdr">
    <div class="hair left">ALSO AVAILABLE / SCALE, TEMPLATES, AUTOMATION</div>
    <p class="svc-more-deck rv">Same operator rigour on paid intent, programmatic page systems, and workflow automation. Each block scrolls like the core services above, with a live preview on the right.</p>
  </div>

  <div class="svc-cards-wrap svc-cards-wrap--more" id="services-more">
    <div class="svc-card" id="svc4">
      <div class="svc-card-inner">
        <div class="svc-content">
          <div class="svc-num">04 / Paid</div>
          <h3 class="svc-title">Google Ads & Search</h3>
          <p class="svc-desc">Paid search that actually converts. Keyword intent mapping, ad structure, landing page alignment, and conversion tracking. Qualified leads, not just traffic.</p>
          <div class="svc-tags">
            <span class="tag-chip">Google Ads</span><span class="tag-chip">PPC Strategy</span><span class="tag-chip">CRO</span>
          </div>
          <a href="/contact" class="btn-s" style="margin-top:24px" data-cursor="Discuss paid search">Discuss paid search →</a>
        </div>
        <div class="svc-visual">
          <div class="gads-demo" id="gadsDemo">
            <div class="gads-head">
              <span class="gads-badge">Google Ads</span>
              <span class="gads-camp">Search · SaaS pipeline</span>
            </div>
