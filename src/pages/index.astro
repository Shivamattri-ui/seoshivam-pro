let currentQ=0;const answers:number[]=[];
 
function buildQuiz(){
  const wrap=document.getElementById('quizSteps');if(!wrap)return;
  wrap.innerHTML='';
  QUIZ.forEach((q,qi)=>{
    const step=document.createElement('div');
    step.className=`q-step${qi===0?' act':''}`;
    step.id=`qs${qi}`;
    step.innerHTML=`
      <div class="q-eye">Question ${qi+1} of ${QUIZ.length}</div>
      <div class="q-q">${q.q}</div>
      <div class="q-opts">
        ${q.opts.map((o,oi)=>`
          <div class="q-opt" data-qi="${qi}" data-oi="${oi}" data-val="${o.val}">
            <div class="q-icon">${ICONS[o.icon]||''}</div>
            <div class="q-txt">${o.label}</div>
          </div>`).join('')}
      </div>
      <div class="q-nav">
        <span class="q-prog">${Math.round((qi/QUIZ.length)*100)}% complete</span>
        <button class="btn-p qnext" data-next="${qi+1}" disabled style="opacity:.4;cursor:not-allowed;padding:11px 24px;font-size:13px">
          ${qi<QUIZ.length-1?'Next →':'Get my score →'}
        </button>
      </div>`;
    wrap.appendChild(step);
  });
 
  wrap.addEventListener('click',(e)=>{
    const opt=(e.target as Element).closest('.q-opt') as HTMLElement|null;
    if(opt){
      const qi=parseInt(opt.dataset.qi||'0'),val=parseInt(opt.dataset.val||'0');
      opt.closest('.q-opts')?.querySelectorAll('.q-opt').forEach(o=>o.classList.remove('sel'));
      opt.classList.add('sel');answers[qi]=val;
      const btn=opt.closest('.q-step')?.querySelector('.qnext') as HTMLButtonElement|null;
      if(btn){btn.disabled=false;btn.style.opacity='1';btn.style.cursor='pointer';}
    }
    const btn=(e.target as Element).closest('.qnext') as HTMLButtonElement|null;
    if(btn&&!btn.disabled){
      const next=parseInt(btn.dataset.next||'0');
      // Update progress bar
      const fill=document.getElementById('quizProgFill');
      if(fill)fill.style.width=Math.round((next/QUIZ.length)*100)+'%';
      if(next<QUIZ.length){
        document.querySelectorAll('.q-step').forEach(s=>s.classList.remove('act'));
        document.getElementById(`qs${next}`)?.classList.add('act');
      } else showScore();
    }
  });
}
 
function showScore(){
  const total=Math.min(answers.reduce((a,b)=>a+(b||0),0),100);
  document.getElementById('quizWrap')!.style.display='none';
  const sw=document.getElementById('scoreWrap')!;sw.style.display='block';
  const circle=document.getElementById('scoreCircle');
  if(!(circle instanceof SVGCircleElement))return;
  setTimeout(()=>{circle.style.strokeDashoffset=String(352-(total/100)*352);},100);
  const numEl=document.getElementById('scoreNum')!;
  let c=0;const id=setInterval(()=>{c=Math.min(c+total/60,total);numEl.textContent=String(Math.round(c));if(c>=total)clearInterval(id);},25);
  const VERDICTS:[number,string,string[]][]=[
    [25,'AI engines do not know you exist yet.',[
      'Implement JSON-LD schema immediately — Person, Organization, FAQPage at minimum.',
      'Update robots.txt to allow GPTBot, ClaudeBot, and PerplexityBot explicitly.',
      'Restructure top 5 pages with answer-first formatting and embedded FAQs.',
    ]],
    [50,'Partially visible. Competitors have the edge.',[
      'Add FAQPage schema to every blog post and service page.',
      'Update content monthly with fresh statistics and cited sources.',
      'Build topical authority clusters — not individual disconnected pages.',
    ]],
    [75,'On the radar. Not yet the answer.',[
      'Expand schema to HowTo and Speakable types for full AI coverage.',
      'Test AI citation across all major platforms monthly and track changes.',
      'Add authoritative external citations to boost content authority signals.',
    ]],
    [100,"Strong foundation. Let's make you the default answer.",[
      'Layer Speakable schema for voice search and AI assistant coverage.',
      'Build a 30-day content refresh cadence for key pages.',
      'Expand brand mentions across authoritative third-party publications.',
    ]],
  ];
  const [,verdict,recs]=VERDICTS.find(([max])=>total<=max)||VERDICTS[VERDICTS.length-1];
  document.getElementById('scoreVerdict')!.textContent=verdict;
  document.getElementById('scoreRecs')!.innerHTML=recs.map(r=>`<li class="score-rec"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4F8EF7" stroke-width="2.5" style="flex-shrink:0;margin-top:2px"><polyline points="9 18 15 12 9 6"/></svg>${r}</li>`).join('');
}
 
