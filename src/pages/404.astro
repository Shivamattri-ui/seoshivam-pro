---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 · Not Found | seoshivam.pro"
  description="This page does not exist. Not indexed. Not cited. Not found. Even AI cannot help here."
  canonical="https://seoshivam.pro/404"
>
  <Nav />

  <main class="e4-main">
    <div class="e4-inner">

      <div class="e4-term-bar">
        <span class="e4-dot" style="background:#EF4444"></span>
        <span class="e4-dot" style="background:#F59E0B"></span>
        <span class="e4-dot" style="background:#22C55E"></span>
        <span class="e4-path">~ seoshivam.pro / [redacted]</span>
      </div>

      <div class="e4-glitch" data-text="404" aria-hidden="true">404</div>

      <div class="e4-log" id="e4Log">
        <p class="e4-l cmd">$ crawl --url /[this-page] --depth 1</p>
        <p class="e4-l err">✗ HTTP 404: page_not_found</p>
        <p class="e4-l cmd">$ check_index --google --bing --all-bots</p>
        <p class="e4-l dim">indexed: false</p>
        <p class="e4-l dim">impressions: 0</p>
        <p class="e4-l dim">ai_citations: 0</p>
        <p class="e4-l dim">schema_valid: irrelevant</p>
        <p class="e4-l cmd">$ ask --ai chatgpt "what is at this URL"</p>
        <p class="e4-l dim">"A compelling article on [hallucinated topic]." — Nice try.</p>
        <p class="e4-l err">✗ audit complete: nothing to optimise. page does not exist.</p>
      </div>

      <h1 class="e4-h1">This page is not indexed.<br><em class="grad-anim">Not ranked. Not cited. Not found.</em></h1>
      <p class="e4-sub">Even 7 years of AEO cannot fix a URL that leads nowhere. Whatever you were looking for, it is not here.</p>

      <div class="e4-actions">
        <button class="e4-try" id="e4TryBtn" type="button">
          <span class="e4-try-icon">⟳</span> Try to index this page anyway
        </button>
        <a href="/" class="btn-p e4-home" data-cursor="Go home">Back to homepage</a>
      </div>

      <div class="e4-result" id="e4Result" aria-live="polite"></div>

      <nav class="e4-nav" aria-label="Helpful pages">
        <div class="hair left">OR GO SOMEWHERE REAL</div>
        <div class="e4-links">
          <a href="/services/aeo">AEO Services</a>
          <a href="/work">Case Studies</a>
          <a href="/insights">Insights</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </div>
      </nav>

    </div>
  </main>

  <Footer />
</Layout>

<style>
.e4-main {
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 24px 80px;
}
.e4-inner {
  max-width: 680px;
  width: 100%;
}

/* Terminal bar */
.e4-term-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--s1);
  border: 1px solid var(--bd);
  border-radius: 8px 8px 0 0;
  padding: 10px 16px;
  margin-bottom: 0;
}
.e4-dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  display: inline-block;
}
.e4-path {
  font-family: var(--fm);
  font-size: 11px;
  color: var(--wm);
  letter-spacing: 0.08em;
  margin-left: 8px;
}

/* Glitch 404 */
.e4-glitch {
  font-family: var(--fm);
  font-size: clamp(96px, 18vw, 180px);
  font-weight: 500;
  letter-spacing: -0.04em;
  line-height: 1;
  color: var(--w);
  position: relative;
  display: inline-block;
  margin: 32px 0 0;
  animation: e4glitch 4s infinite;
}
.e4-glitch::before,
.e4-glitch::after {
  content: attr(data-text);
  position: absolute;
  inset: 0;
  overflow: hidden;
}
.e4-glitch::before {
  color: var(--ac);
  animation: e4gb 4s infinite;
  clip-path: polygon(0 20%, 100% 20%, 100% 40%, 0 40%);
  transform: translateX(-3px);
}
.e4-glitch::after {
  color: #EF4444;
  animation: e4ga 4s infinite;
  clip-path: polygon(0 60%, 100% 60%, 100% 80%, 0 80%);
  transform: translateX(3px);
}
@keyframes e4glitch {
  0%, 90%, 100% { transform: none; }
  92% { transform: skewX(-2deg) translateX(2px); }
  94% { transform: skewX(1deg) translateX(-2px); }
  96% { transform: none; }
}
@keyframes e4gb {
  0%, 89%, 100% { opacity: 0; }
  90%, 95% { opacity: 0.8; transform: translateX(-4px); }
}
@keyframes e4ga {
  0%, 87%, 100% { opacity: 0; }
  88%, 93% { opacity: 0.7; transform: translateX(4px); }
}

/* Terminal log */
.e4-log {
  background: var(--s1);
  border: 1px solid var(--bd);
  border-top: none;
  border-radius: 0 0 8px 8px;
  padding: 16px 20px;
  margin-bottom: 40px;
  overflow: hidden;
}
.e4-l {
  font-family: var(--fm);
  font-size: 12px;
  line-height: 1.9;
  margin: 0;
  letter-spacing: 0.04em;
}
.e4-l.cmd { color: var(--ac); }
.e4-l.err { color: #EF4444; }
.e4-l.dim { color: var(--wm); padding-left: 16px; }
.e4-l.ok  { color: #22C55E; }

/* Heading */
.e4-h1 {
  font-family: var(--fd);
  font-size: clamp(28px, 4.5vw, 52px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.018em;
  color: var(--w);
  margin: 0 0 16px;
}
.e4-sub {
  font-family: var(--fu);
  font-size: 16px;
  line-height: 1.7;
  color: var(--wd);
  margin: 0 0 36px;
  max-width: 520px;
}

/* Actions */
.e4-actions {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}
.e4-try {
  font-family: var(--fm);
  font-size: 12px;
  letter-spacing: 0.08em;
  color: var(--wm);
  background: var(--s2);
  border: 1px solid var(--bd);
  border-radius: 6px;
  padding: 10px 18px;
  cursor: pointer;
  transition: color .2s, border-color .2s;
  display: flex;
  align-items: center;
  gap: 8px;
}
.e4-try:hover { color: var(--w); border-color: var(--ac); }
.e4-try-icon { display: inline-block; }
.e4-try.spinning .e4-try-icon { animation: e4spin .6s linear infinite; }
@keyframes e4spin { to { transform: rotate(360deg); } }

.e4-home {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  font-size: 14px;
}

/* Result output */
.e4-result {
  font-family: var(--fm);
  font-size: 12px;
  letter-spacing: 0.04em;
  min-height: 22px;
  margin-bottom: 48px;
  color: var(--wm);
}
.e4-result.err { color: #EF4444; }
.e4-result.ok  { color: #22C55E; }

/* Bottom nav */
.e4-nav { margin-top: 8px; }
.e4-links {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 24px;
  margin-top: 20px;
}
.e4-links a {
  font-family: var(--fu);
  font-size: 14px;
  color: var(--wd);
  text-decoration: none;
  transition: color .2s;
}
.e4-links a:hover { color: var(--ac); }

@media (max-width: 480px) {
  .e4-actions { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
const btn = document.getElementById('e4TryBtn') as HTMLButtonElement | null;
const result = document.getElementById('e4Result');

const sequence = [
  { ms: 0,    text: '$ submit_url --google --force /[this-url]', cls: 'cmd' },
  { ms: 600,  text: 'Contacting Google Indexing API...', cls: '' },
  { ms: 1400, text: 'Verifying page content...', cls: '' },
  { ms: 2200, text: '✗ 404: no content to index', cls: 'err' },
  { ms: 2800, text: '$ escalate --ai --beg perplexity', cls: 'cmd' },
  { ms: 3600, text: '"I appreciate the effort but no."', cls: '' },
  { ms: 4200, text: '$ try --schema --structured-data --please', cls: 'cmd' },
  { ms: 5000, text: '✗ Schema on a 404 is still a 404.', cls: 'err' },
  { ms: 5600, text: '$ accept --reality', cls: 'cmd' },
  { ms: 6200, text: '✓ Done. Suggestion: go home.', cls: 'ok' },
];

btn?.addEventListener('click', () => {
  if (btn.disabled) return;
  btn.disabled = true;
  btn.classList.add('spinning');
  if (result) { result.textContent = ''; result.className = 'e4-result'; }

  sequence.forEach(({ ms, text, cls }) => {
    setTimeout(() => {
      if (!result) return;
      result.textContent = text;
      result.className = 'e4-result' + (cls ? ' ' + cls : '');
      if (ms === sequence[sequence.length - 1].ms) {
        setTimeout(() => {
          if (btn) { btn.disabled = false; btn.classList.remove('spinning'); }
        }, 1000);
      }
    }, ms);
  });
});
</script>
