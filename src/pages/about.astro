        <span>LinkedIn</span>
      </a>
      <a href="https://www.instagram.com/seoshivam.pro/" target="_blank" rel="noopener noreferrer" class="ab-soc" aria-label="Instagram">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        <span>Instagram</span>
      </a>
      <a href="https://www.threads.com/@seoshivam.pro" target="_blank" rel="noopener noreferrer" class="ab-soc" aria-label="Threads">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.473 12.01v-.017c.027-3.579.877-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.594 12c.022 3.086.713 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.642-2.045 1.037-1.143 1.674-2.834 1.893-5.032A5.557 5.557 0 0 0 17.8 14c-1.322 1.498-3.114 2.272-5.322 2.272-1.614 0-3.073-.436-4.157-1.248-1.22-.914-1.882-2.22-1.882-3.87 0-1.65.75-3.005 2.11-3.837 1.197-.73 2.754-1.065 4.56-.996.712.028 1.395.1 2.05.21V6.56c0-1.855-1.218-2.953-3.354-2.953-1.32 0-2.58.509-3.584 1.432l-1.381-1.528C7.97 2.492 9.8 1.806 11.9 1.806c1.62 0 2.977.45 3.933 1.3.884.788 1.35 1.927 1.35 3.3v.666c.35.057.692.126 1.02.205l-.001.033c.002.154.003.31.003.466 0 2.455-.689 4.419-2.05 5.843-1.38 1.444-3.3 2.181-5.553 2.181A7.9 7.9 0 0 1 7.3 14.63c-1.354-.91-2.09-2.195-2.09-3.63 0-2.968 2.298-4.974 5.72-4.974 1.018 0 1.99.181 2.88.53V4.96c-.874-.122-1.79-.184-2.73-.184z"/></svg>
