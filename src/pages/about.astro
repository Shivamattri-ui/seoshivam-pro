        const target=parseFloat(match[1]);
        let start=0;const dur=1200;const step=16;
        const inc=target/(dur/step);
        const timer=setInterval(()=>{
          start=Math.min(start+inc,target);
          const rest=txt.replace(/^[\d.]+/,target%1===0?Math.round(start).toString():start.toFixed(1));
          el.textContent=rest;
          if(start>=target)clearInterval(timer);
        },step);
      }
      co.unobserve(el);
    }
  });
},{threshold:0.5});
vals.forEach(el=>co.observe(el));

// ── Founder quote word-by-word unblur ──
const fqText=document.getElementById('fqText');
const fqAttr=document.getElementById('fqAttr');
if(fqText){
  const qWords=fqText.querySelectorAll('.qw');
  const fqObs=new IntersectionObserver(entries=>{
    if(entries[0].isIntersecting){
      qWords.forEach((w,i)=>{
        setTimeout(()=>{
          const el=w as HTMLElement;
          el.style.filter='blur(0)';
          el.style.opacity='1';
          el.style.transform='translateY(0)';
        },i*55);
      });
      setTimeout(()=>{fqAttr?.classList.add('visible')},qWords.length*55+300);
      fqObs.disconnect();
    }
  },{threshold:0.3});
  fqObs.observe(fqText);
}

// ── Nav scroll behaviour ──
const nav=document.getElementById('mainNav');
let last=0,tick=false;
window.addEventListener('scroll',()=>{
  if(!tick){
    requestAnimationFrame(()=>{
      const sy=window.scrollY;
      nav?.classList.toggle('sc',sy>40);
      if(sy>last&&sy>200) nav?.classList.add('hidden');
      else nav?.classList.remove('hidden');
      last=sy;tick=false;
    });
    tick=true;
  }
},{passive:true});

// ── Count-up animation for any [data-target] or [data-bl-target] ──
(function(){
  function pickValueEl(el: HTMLElement): HTMLElement | null {
    return el.querySelector<HTMLElement>('.ab-doss-row-val, .ab-bl-mega-val, .ab-bl-side-num, [data-val]');
  }

  function getNum(el: HTMLElement, attr: string): number {
    return parseFloat(el.getAttribute(attr) || '0');
  }
  function getStr(el: HTMLElement, attr: string): string {
    return el.getAttribute(attr) || '';
  }

  function animateCount(el: HTMLElement, targetAttr: string, suffixAttr: string, prefix = ''){
    const valueEl = pickValueEl(el);
    if(!valueEl) return;
    const valueNode = valueEl;
    const target = getNum(el, targetAttr);
    const suffix = getStr(el, suffixAttr);
    const duration = 1500;
    const startTime = performance.now();
    function frame(now: number){
      const t = Math.min(1, (now - startTime) / duration);
      const eased = 1 - Math.pow(1 - t, 3);
      const current = target * eased;
      const formatted = target % 1 === 0 ? Math.round(current).toString() : current.toFixed(1);
      valueNode.innerHTML = prefix + formatted + suffix;
      if(t < 1) requestAnimationFrame(frame);
      else valueNode.innerHTML = prefix + (target % 1 === 0 ? target.toString() : target.toFixed(1)) + suffix;
    }
    requestAnimationFrame(frame);
  }

  // Observe both old data-target and new data-bl-target
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting){
        const el = e.target as HTMLElement;
        if(el.hasAttribute('data-target')){
          animateCount(el, 'data-target', 'data-suffix');
        } else if(el.hasAttribute('data-bl-target')){
          // Build-Log: prefix "<" if suffix is "hr"
          const suff = el.getAttribute('data-bl-suffix') || '';
          const prefix = suff === 'hr' ? '<' : '';
          animateCount(el, 'data-bl-target', 'data-bl-suffix', prefix);
        }
        obs.unobserve(el);
      }
    });
  }, {threshold: 0.4});

  document.querySelectorAll<HTMLElement>('[data-target], [data-bl-target]').forEach(t => obs.observe(t));

  // Build-Log bars: trigger fill on scroll
  const barObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting){
        e.target.classList.add('in');
        barObs.unobserve(e.target);
      }
    });
  }, {threshold: 0.3});
  document.querySelectorAll<HTMLElement>('[data-bl-bar]').forEach(b => barObs.observe(b));
})();

// ── Career timeline: scroll-linked spine, year nav, focus states ──
(function abTimelineInit(){
  const root = document.querySelector<HTMLElement>('[data-ab-tl]');
  const flow = document.querySelector<HTMLElement>('[data-ab-tl-flow]');
  const fill = document.getElementById('abTlSpineFill');
    if (!root || !flow || !fill) return;

  const steps = Array.from(flow.querySelectorAll<HTMLElement>('.ab-tl-step'));
  const navBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('.ab-tl-nav-btn'));
  if (!steps.length) return;

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let activeIdx = 0;
  let targetProgress = 0;
  let currentProgress = 0;
  let rafId = 0;

  const setActive = (idx: number, scroll = true) => {
    const clamped = Math.max(0, Math.min(idx, steps.length - 1));
    activeIdx = clamped;
    steps.forEach((step, i) => {
      step.classList.toggle('is-active', i === clamped);
    });
    navBtns.forEach((btn, i) => {
      const on = i === clamped;
      btn.classList.toggle('is-active', on);
      btn.setAttribute('aria-current', on ? 'true' : 'false');
    });
    if (scroll) {
      const target = steps[clamped];
      const lenis = (window as unknown as { __lenis?: { scrollTo: (t: HTMLElement, o?: { offset?: number }) => void } }).__lenis;
      if (lenis && typeof lenis.scrollTo === 'function') {
        lenis.scrollTo(target, { offset: -100 });
      } else {
        const top = target.getBoundingClientRect().top + window.scrollY - 100;
        window.scrollTo({ top, behavior: reduced ? 'auto' : 'smooth' });
      }
    }
  };

  navBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.tlIndex || '0', 10);
      setActive(idx, true);
    });
  });

  steps.forEach((step, i) => {
    step.addEventListener('mouseenter', () => {
      if (!step.classList.contains('is-active')) step.classList.add('is-hover');
    });
    step.addEventListener('mouseleave', () => step.classList.remove('is-hover'));
    step.addEventListener('click', () => setActive(i, false));
  });

  const compute = () => {
    const flowRect = flow.getBoundingClientRect();
    const vh = window.innerHeight;
    const startY = vh * 0.72;
    const endY = vh * 0.28;
    const span = flowRect.height - (startY - endY);
    if (span > 0) {
      const traveled = startY - flowRect.top;
      targetProgress = Math.max(0, Math.min(1, traveled / span));
    }

    const markerOffset = window.innerWidth <= 640 ? 36 : 40;
    let bestIdx = 0;
    let bestDist = Infinity;
    steps.forEach((step, i) => {
      const rect = step.getBoundingClientRect();
      const markerY = rect.top + markerOffset;
      const lit = markerY < vh * 0.58;
      step.classList.toggle('is-lit', lit);
      const dist = Math.abs(markerY - vh * 0.42);
      if (dist < bestDist) {
        bestDist = dist;
        bestIdx = i;
      }
    });
    if (bestIdx !== activeIdx) setActive(bestIdx, false);
  };

  const tick = () => {
    if (!reduced) {
      currentProgress += (targetProgress - currentProgress) * 0.12;
      if (Math.abs(targetProgress - currentProgress) < 0.0008) currentProgress = targetProgress;
    } else {
      currentProgress = targetProgress;
    }
    fill.style.transform = `scaleY(${currentProgress})`;
    rafId = requestAnimationFrame(tick);
  };

  const onScroll = () => compute();

  compute();
  currentProgress = targetProgress;
  fill.style.transform = `scaleY(${currentProgress})`;
  rafId = requestAnimationFrame(tick);
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });

  const visObs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        if (!rafId) rafId = requestAnimationFrame(tick);
      } else if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = 0;
      }
    });
  }, { rootMargin: '200px 0px 200px 0px' });
  visObs.observe(flow);

  setActive(0, false);
})();
</script>

