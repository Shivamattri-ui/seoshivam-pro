  "@graph": [
    {
      "@type": "Person",
      "@id": "https://seoshivam.pro/#shivam",
      "name": "Shivam Attri",
      "alternateName": ["seoshivam", "seoshivampro"],
      "jobTitle": "AEO Specialist, SEO Strategist, AI-Visible Web Designer",
      "description": "Shivam Attri is an AEO and SEO specialist with 7+ years of experience helping B2B SaaS founders and growing brands get cited by ChatGPT, Perplexity, and Google AI Overviews. Based in India, serving clients across the US, UK, EU, and Australia.",
      "url": "https://seoshivam.pro",
      "image": {
        "@type": "ImageObject",
        "url": "https://seoshivam.pro/images/shivam-attri.jpg",
        "width": 800,
        "height": 800,
        "caption": "Shivam Attri — AEO Specialist and SEO Strategist"
      },
      "sameAs": [
        "https://www.linkedin.com/in/seoshivampro/",
        "https://www.instagram.com/seoshivam.pro/",
        "https://www.threads.com/@seoshivam.pro",
        "https://substack.com/@seoshivampro",
        "https://www.reddit.com/r/aiseovisibility/"
      ],
      "address": {
