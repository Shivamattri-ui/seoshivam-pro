.ab-hero-label::before{display:none}

.ab-name {
  font-family:'Instrument Serif',Georgia,serif;
  font-size:clamp(68px,11vw,136px);
  font-weight:400;
  letter-spacing:-.02em;
  line-height:.9;
  color:var(--w);
  margin-bottom:24px;
  display:flex;
  align-items:baseline;
  gap:0.1em;
  flex-wrap:wrap;
  justify-content:center;
}
.ab-name-s {
  font-family:'Syne',sans-serif;
  font-weight:800;
  font-style:normal;
  color:var(--w);
  letter-spacing:-.04em;
}
.ab-name-e {
  font-family:'Instrument Serif',serif;
  font-style:italic;
  font-weight:400;
  background:var(--ag);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}

.ab-chips {
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  justify-content:center;
  margin-bottom:28px;
}
.ab-chip {
  font-family:'JetBrains Mono',monospace;
  font-size:9px;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--wd);
  padding:5px 14px;
  border:1px solid var(--bd);
  border-radius:999px;
  background:var(--s1);
}
.ab-chip-dot {
  width:4px;height:4px;border-radius:50%;background:var(--bd);
}

.ab-hero-sub {
  font-family:'Instrument Serif',serif;
  font-size:clamp(18px,2.2vw,26px);
  font-weight:400;
  color:var(--wd);
  line-height:1.55;
  max-width:640px;
  margin:0 auto 40px;
}
.ab-hero-sub .ub-accent {
  color:var(--w);
  font-style:italic;
}

.ab-hero-socials {
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
  justify-content:center;
}
.ab-soc {
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-family:'JetBrains Mono',monospace;
  font-size:9px;
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--wm);
  padding:7px 14px;
  border:1px solid var(--bd);
  border-radius:999px;
  transition:border-color .2s,color .2s,background .2s;
}
.ab-soc svg{flex-shrink:0;opacity:.7}
.ab-soc:hover {
  border-color:var(--ac);
  color:var(--w);
  background:var(--agl);
}
.ab-soc:hover svg{opacity:1}

.ab-scroll-hint {
  position:absolute;
  bottom:32px;left:50%;
  transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  z-index:2;
}
.ab-scroll-line {
  width:1px;height:40px;
  background:linear-gradient(to bottom,var(--ac),transparent);
  animation:scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse {0%,100%{opacity:.4;transform:scaleY(.6);transform-origin:top}50%{opacity:1;transform:scaleY(1)}}
.ab-scroll-lbl {
  font-family:'JetBrains Mono',monospace;
  font-size:8px;letter-spacing:.2em;text-transform:uppercase;
  color:var(--wm);
}

/* Unblur animation */
@keyframes unblur {
  from{filter:blur(12px);opacity:0;transform:translateY(6px)}
  to{filter:blur(0);opacity:1;transform:translateY(0)}
}
/* Mobile: skip blur (GPU-heavy), opacity+slide only */
@keyframes unblur-mobile {
  from{opacity:0;transform:translateY(6px)}
  to{opacity:1;transform:translateY(0)}
}
.ub {
  display:inline;
  opacity:0;
  animation:unblur 0.8s cubic-bezier(.16,1,.3,1) forwards;
  animation-delay:calc(var(--ud,0s) + 0.2s);
}
@media(max-width:768px){
  .ub{animation-name:unblur-mobile}
}

/* ═══════════ BENTO GRID ═══════════ */
.ab-bento-sec {
  background:var(--s1);
  padding:0 0 110px;
  position:relative;z-index:1;
}
.ab-bento {
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  grid-template-rows:280px 260px auto;
  gap:16px;
}
.ab-card {
  background:var(--bg);
  border:1px solid var(--bd);
  border-radius:20px;
  overflow:hidden;
  position:relative;
  transition:border-color .3s,transform .3s;
}
.ab-card:hover{border-color:rgba(79,142,247,.3)}

/* Photo card */
.ab-photo-card {
  grid-column:1;
  grid-row:1/3;
  /* rows 1 and 2 — quote takes row 3 */
  display:flex;
  flex-direction:column;
}
.ab-photo-inner {
  flex:1;
  position:relative;
  overflow:hidden;
  background:var(--s2);
}
.ab-photo {
  width:100%;height:100%;
  object-fit:cover;
  object-position:top center;
  transition:transform .5s ease;
  position:relative;z-index:1;
}
.ab-photo-card:hover .ab-photo{transform:scale(1.03)}
.ab-photo-init {
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  z-index:0;
}
.ab-pi-s {
  font-family:'Syne',sans-serif;
  font-size:clamp(60px,8vw,100px);
  font-weight:800;
  color:var(--s4);
  letter-spacing:-.04em;
}
.ab-pi-a {
  font-family:'Instrument Serif',serif;
  font-style:italic;
  font-size:clamp(68px,9vw,110px);
  background:var(--ag);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  opacity:.4;
}
.ab-photo-foot {
  padding:16px 20px;
  border-top:1px solid var(--bd);
  display:flex;
  align-items:center;
  justify-content:space-between;
  background:var(--s1);
  flex-shrink:0;
}
.ab-pf-name {
  font-family:'Syne',sans-serif;
  font-size:13px;font-weight:700;
  color:var(--w);letter-spacing:-.01em;
}
.ab-pf-loc {
  display:flex;align-items:center;gap:4px;
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--wm);
  margin-top:2px;
}
.ab-avail-pill {
  display:flex;align-items:center;gap:6px;
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--green);
  padding:4px 10px;
  border:1px solid rgba(34,197,94,.25);
  border-radius:999px;
  background:rgba(34,197,94,.06);
  white-space:nowrap;
  flex-shrink:0;
}

/* Stat cards */
.ab-stat-card {
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:24px;
  background:var(--s1);
}
.ab-sc-tag {
  font-family:'JetBrains Mono',monospace;
  font-size:8px;letter-spacing:.12em;text-transform:uppercase;
  color:var(--wm);
  margin-bottom:auto;
  padding-top:4px;
}
.ab-sc-n {
  font-family:'Instrument Serif',serif;
  font-size:clamp(52px,6vw,72px);
  font-weight:400;
  line-height:.9;
  margin-bottom:4px;
}
.ab-sc-l {
  font-family:'Syne',sans-serif;
  font-size:14px;font-weight:700;
  letter-spacing:-.01em;
  color:var(--w);
  margin-bottom:2px;
}
.ab-sc-sub {
  font-size:11px;color:var(--wm);line-height:1.4;
  font-family:'JetBrains Mono',monospace;
  letter-spacing:.03em;
}
.ab-sc-gsc {
  display:inline-flex;align-items:center;gap:4px;
  margin-top:10px;
  font-family:'JetBrains Mono',monospace;
  font-size:8px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--green);
  background:rgba(34,197,94,.07);
  border:1px solid rgba(34,197,94,.2);
  padding:3px 8px;border-radius:999px;
  width:fit-content;
}
.ab-sc-gsc--blue {
  color:var(--ac);
  background:var(--agl);
  border-color:rgba(79,142,247,.25);
}

/* Quote card */
.ab-quote-card {
  grid-column:1/4;
  grid-row:3;
  background:var(--s2);
  display:flex;flex-direction:column;justify-content:center;
  padding:32px 36px;
}
.ab-qc-qm {
  font-family:'Instrument Serif',serif;
  font-size:80px;font-weight:400;
  color:var(--ac);
  line-height:.7;
  margin-bottom:12px;
  opacity:.4;
}
.ab-qc-text {
  font-family:'Instrument Serif',serif;
  font-size:clamp(16px,1.6vw,20px);
  font-style:italic;
  color:var(--wd);
  line-height:1.6;
  flex:1;
  margin-bottom:20px;
}
.ab-qc-attr {
  display:flex;align-items:center;gap:12px;
  padding-top:16px;border-top:1px solid var(--bd);
}
.ab-qc-av {
  width:36px;height:36px;border-radius:50%;
  background:var(--ag);
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-size:11px;font-weight:700;
  color:#fff;flex-shrink:0;
}
.ab-qc-name {font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--w)}
.ab-qc-role {font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--wm)}

/* Bento background / tech card */
.ab-qc-eyebrow{
  font-family:'JetBrains Mono',monospace;
  font-size:8px;letter-spacing:.2em;text-transform:uppercase;
  color:var(--ac);margin-bottom:16px;
}
.ab-qc-degree{margin-bottom:16px}
.ab-qc-deg-label{
  font-family:'Syne',sans-serif;font-size:16px;font-weight:700;
  color:var(--w);letter-spacing:-.01em;margin-bottom:4px;
}
.ab-qc-deg-sub{
  font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--wm);
}
.ab-qc-skills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
.ab-qcs{
  font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--ac);padding:3px 9px;
  background:var(--agl);border:1px solid rgba(79,142,247,.2);border-radius:4px;
  transition:background .2s,border-color .2s;cursor:default;
}
.ab-qcs:hover{background:rgba(79,142,247,.18);border-color:rgba(79,142,247,.4)}
.ab-qc-caption{
  font-family:'Instrument Serif',serif;
  font-size:clamp(14px,1.3vw,17px);
  font-style:italic;color:var(--wd);line-height:1.65;
  margin-top:auto;padding-top:16px;border-top:1px solid var(--bd);
}

@media(max-width:1024px){
  .ab-bento{grid-template-columns:1fr 1fr;grid-template-rows:auto}
  .ab-photo-card{grid-column:1/3;grid-row:1;min-height:320px}
  .ab-photo-inner{min-height:240px}
  .ab-quote-card{grid-column:1/3;grid-row:auto}
}
@media(max-width:600px){
  .ab-bento{grid-template-columns:1fr;grid-template-rows:auto}
  .ab-photo-card{grid-column:1;grid-row:auto;min-height:280px}
  .ab-photo-inner{min-height:200px}
  .ab-quote-card{grid-column:1;grid-row:auto}
  .ab-stat-card{min-height:160px}
}

/* ═══════════ ORIGIN STORY (editorial essay) ═══════════ */
.ab-story-sec{background:var(--bg);padding:100px 0;position:relative;z-index:1}

.ab-st-hdr{
  max-width:780px;
  margin:0 auto 64px;
  text-align:center;
  display:flex;flex-direction:column;align-items:center;gap:18px;
}
.ab-st-hdr .hair{justify-content:center}
.ab-st-h{
  font-family:var(--fd);
  font-size:clamp(38px,5.5vw,80px);
  font-weight:400;line-height:.96;letter-spacing:-.025em;
  color:var(--w);margin:0;
}
.ab-st-h em{font-style:italic}
.ab-st-deck{
  font-family:var(--fu);
  font-size:15px;color:var(--wd);
  line-height:1.7;margin:0;max-width:520px;
}

/* Single-column essay (no imbalanced 2-column) */
.ab-st-essay{
  max-width:720px;
  margin:0 auto;
  font-family:var(--fu);
}

.ab-st-lead{
  font-family:var(--fd);
  font-size:clamp(22px,2.4vw,30px);
  font-style:italic;
  color:var(--w);
  line-height:1.45;
  letter-spacing:-.012em;
  margin:0 0 36px;
  position:relative;
  padding-top:16px;
}
.ab-st-lead::before{
  content:'';position:absolute;top:0;left:0;
  width:48px;height:2px;
  background:linear-gradient(90deg,var(--ac) 0%,var(--ac2) 100%);
  border-radius:2px;
}

.ab-st-p{
  font-family:var(--fu);
  font-size:17px;
  color:var(--wd);
  line-height:1.85;
  margin:0 0 24px;
}
.ab-st-p strong{
  color:var(--w);
  font-weight:600;
  font-family:var(--fd);
  font-style:italic;
  font-size:1.08em;
  letter-spacing:-.01em;
}

/* Pull quote — magazine treatment */
.ab-st-pull{
  position:relative;
  margin:48px -32px;
  padding:40px 56px 36px;
  border-top:1px solid var(--bd);
  border-bottom:1px solid var(--bd);
  text-align:center;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(79,142,247,.06) 0%, transparent 60%);
}
.ab-st-pull-mark{
  display:block;
  font-family:var(--fd);font-style:italic;
  font-size:64px;line-height:.6;
  color:var(--ac);opacity:.55;
  margin-bottom:8px;
}
.ab-st-pull-q{
  font-family:var(--fd);
  font-size:clamp(24px,3vw,36px);
  font-style:italic;font-weight:400;
  color:var(--w);
  line-height:1.18;letter-spacing:-.018em;
  margin:0 0 16px;
}
.ab-st-pull-attr{
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--fm);font-size:9.5px;font-weight:600;
  letter-spacing:.18em;text-transform:uppercase;
  color:var(--ac);
}
.ab-st-pull-attr::before{
  content:'';display:inline-block;width:24px;height:1px;background:var(--ac);
}

/* Career timeline (contained, matches homepage process pattern) */
.ab-tl-sec{
  width:100%;
  max-width:880px;
  margin:56px auto 48px;
  padding-top:48px;
  border-top:1px solid var(--bd);
}
.ab-tl-hdr{margin-bottom:28px;display:flex;flex-direction:column;gap:12px}
.ab-tl-deck{
  font-family:var(--fu);font-size:14px;color:var(--wm);
  margin:0;max-width:40ch;line-height:1.6;
}

.ab-tl-nav{margin-bottom:32px}
.ab-tl-nav-track{
  display:flex;flex-wrap:wrap;gap:8px;
}
.ab-tl-nav-btn{
  font-family:var(--fm);font-size:10px;font-weight:600;
  letter-spacing:.1em;text-transform:uppercase;
  color:var(--wd);
  padding:8px 14px;border-radius:999px;
  border:1px solid var(--bd);
  background:var(--s1);
  cursor:pointer;
  transition:border-color .2s,color .2s,background .2s;
}
.ab-tl-nav-btn:hover{border-color:rgba(79,142,247,.4);color:var(--w);background:var(--agl)}
.ab-tl-nav-btn.is-active,
.ab-tl-nav-btn[aria-current='true']{
  color:var(--ac);
  border-color:rgba(79,142,247,.45);
  background:var(--agl);
}

.ab-tl-flow{
  position:relative;
  padding-left:56px;
  min-width:0;
}
.ab-tl-spine{
  position:absolute;left:18px;top:0;bottom:0;
  width:2px;background:var(--bd);border-radius:2px;overflow:hidden;
}
.ab-tl-spine-fill{
  position:absolute;inset:0;
  background:linear-gradient(180deg,var(--ac) 0%,var(--ac2) 100%);
  transform:scaleY(0);transform-origin:top center;
  will-change:transform;
}

.ab-tl-step{
  position:relative;
  padding:0 0 28px;
  scroll-margin-top:100px;
}
.ab-tl-step:last-child{padding-bottom:0}

.ab-tl-marker{
  position:absolute;
  left:-44px;
  top:28px;
  width:18px;height:18px;
  display:flex;align-items:center;justify-content:center;
  z-index:2;
}
.ab-tl-marker-dot{
  width:10px;height:10px;border-radius:50%;
  background:var(--bd);
  border:2px solid var(--bg);
  transition:background .35s,transform .35s,box-shadow .35s;
}
.ab-tl-step.is-lit .ab-tl-marker-dot{
  background:var(--ac);
  box-shadow:0 0 0 4px var(--agl);
}
.ab-tl-step.is-active .ab-tl-marker-dot{
  background:#fff;
  border-color:var(--ac);
  transform:scale(1.15);
  box-shadow:0 0 0 4px var(--ac),0 0 14px rgba(79,142,247,.45);
}

.ab-tl-card{
  padding:22px 24px;
  border-radius:16px;
  border:1px solid var(--bd);
  background:var(--s1);
  transition:border-color .3s,opacity .3s;
  opacity:.75;
}
.ab-tl-step.is-lit .ab-tl-card{opacity:.9}
.ab-tl-step.is-active .ab-tl-card{
  opacity:1;
  border-color:rgba(79,142,247,.4);
  box-shadow:0 16px 48px rgba(0,0,0,.2);
}
html.light .ab-tl-step.is-active .ab-tl-card{box-shadow:0 12px 36px rgba(26,23,20,.08)}

.ab-tl-card-meta{
  display:flex;align-items:center;justify-content:space-between;
  gap:12px;flex-wrap:wrap;margin-bottom:10px;
}
.ab-tl-card-yr{
  font-family:var(--fd);font-size:clamp(28px,3vw,40px);
  font-style:italic;font-weight:400;line-height:1;letter-spacing:-.02em;
}
.ab-tl-card-tag{
  font-family:var(--fm);font-size:9px;font-weight:600;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--ac);
  padding:4px 10px;border-radius:999px;
  border:1px solid rgba(79,142,247,.28);background:var(--agl);
}
.ab-tl-card-title{
  font-family:var(--fu);font-size:17px;font-weight:700;
  color:var(--w);letter-spacing:-.012em;line-height:1.35;
  margin:0 0 10px;
}
.ab-tl-card-body{
  font-family:var(--fu);font-size:15px;color:var(--wd);
  line-height:1.72;margin:0;
}

@media(max-width:768px){
  .ab-tl-sec{margin:40px auto 32px;padding-top:36px}
  .ab-tl-flow{padding-left:48px}
  .ab-tl-spine{left:14px}
  .ab-tl-marker{left:-36px;top:24px}
  .ab-tl-nav-track{flex-wrap:nowrap;overflow-x:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch}
  .ab-tl-nav-btn{flex:0 0 auto}
}
@media(prefers-reduced-motion:reduce){
  .ab-tl-card,.ab-tl-marker-dot{transition-duration:.01s}
}

/* Skill stack — horizontal flow */
.ab-st-stack{
  margin-top:40px;padding-top:32px;
  border-top:1px solid var(--bd);
}
.ab-st-stack-eye{
  display:inline-flex;align-items:center;
  font-family:var(--fm);font-size:9px;font-weight:600;
  letter-spacing:.18em;text-transform:uppercase;
  color:var(--ac);
  margin-bottom:18px;
}
.ab-st-stack-eye::before{content:'';display:inline-block;width:24px;height:1px;background:var(--ac);margin-right:10px}
.ab-st-stack-tags{display:flex;flex-wrap:wrap;gap:6px}
.ab-st-stack-tag{
  font-family:var(--fm);font-size:10px;font-weight:500;letter-spacing:.06em;
  color:var(--wd);
  padding:6px 12px;border-radius:999px;
  border:1px solid var(--bd);
  background:transparent;
  transition:color .25s,border-color .25s,background .25s,transform .35s cubic-bezier(.16,1,.3,1);
  animation:abStTagIn .5s cubic-bezier(.16,1,.3,1) backwards;
  animation-delay:calc(.03s * var(--ti));
}
.ab-st-stack-tag:hover{color:var(--ac);border-color:rgba(79,142,247,.45);background:var(--agl);transform:translateY(-2px)}
@keyframes abStTagIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

@media(max-width:680px){
  .ab-story-sec{padding:64px 0}
  .ab-st-pull{margin:36px -16px;padding:28px 24px 24px}
}

/* Differentiators — NO card boxes */
.ab-st-diffs{
  display:grid;
  grid-template-columns:repeat(3,1fr);
}
.ab-std{
  padding:0 48px 0 0;
  border-right:1px solid var(--bd);
  margin-right:48px;
}
.ab-std:last-child{border-right:none;margin-right:0;padding-right:0}
.ab-std-num{
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.16em;text-transform:uppercase;
  color:var(--ac);margin-bottom:16px;
}
.ab-std-icon{display:block;margin-bottom:16px;opacity:.8}
.ab-std-title{
  font-family:'Syne',sans-serif;
  font-size:15px;font-weight:700;
  color:var(--w);letter-spacing:-.01em;
  margin-bottom:10px;line-height:1.3;
}
.ab-std-desc{font-size:13px;color:var(--wm);line-height:1.75}

@media(max-width:1024px){.ab-st-body{grid-template-columns:1fr;gap:48px}}
@media(max-width:768px){
  .ab-st-diffs{grid-template-columns:1fr}
  .ab-std{border-right:none;border-bottom:1px solid var(--bd);margin-right:0;padding-right:0;padding-bottom:36px;margin-bottom:36px}
  .ab-std:last-child{border-bottom:none;padding-bottom:0;margin-bottom:0}
}

/* ═══════════ FOUNDER QUOTE (word unblur animation) ═══════════ */
.ab-fq-sec{
  background:linear-gradient(180deg,var(--s1) 0%,var(--bg) 100%);
  position:relative;
  padding:110px 0 100px;
  overflow:hidden;
}
.ab-fq-orb{
  position:absolute;pointer-events:none;border-radius:50%;
  filter:blur(100px);
}
.ab-fq-orb-1{
  width:600px;height:600px;
  top:-150px;left:-150px;
  background:radial-gradient(ellipse,rgba(79,142,247,0.06) 0%,transparent 70%);
  animation:orbFloat 14s ease-in-out infinite;
}
.ab-fq-orb-2{
  width:500px;height:500px;
  bottom:-120px;right:-120px;
  background:radial-gradient(ellipse,rgba(26,58,143,0.05) 0%,transparent 70%);
  animation:orbFloat 14s ease-in-out infinite reverse;
  animation-delay:-7s;
}
@keyframes orbFloat{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,-30px)}}

.ab-fq-deco{
  position:absolute;
  top:0;left:50%;
  transform:translateX(-50%);
  font-family:'Instrument Serif',serif;
  font-size:clamp(180px,28vw,360px);
  font-style:italic;
  line-height:1;
  color:var(--ac);
  opacity:0.025;
  pointer-events:none;
  user-select:none;
  z-index:0;
}

.ab-fq-wrap{
  max-width:940px;margin:0 auto;
  text-align:center;
  position:relative;z-index:1;
}

.ab-fq-pill{display:flex;justify-content:center;margin-bottom:52px}
.ab-fq-tag{
  display:inline-flex;align-items:center;gap:8px;
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.2em;text-transform:uppercase;
  color:var(--ac);
  padding:7px 18px;
  border:1px solid rgba(79,142,247,.25);
  border-radius:999px;
  background:var(--agl);
}

.ab-fq-text{
  font-family:'Instrument Serif',serif;
  font-size:clamp(26px,3.8vw,54px);
  font-weight:400;
  font-style:italic;
  color:var(--w);
  line-height:1.35;
  margin:0 0 64px;
  border:none;
  word-spacing:.04em;
}
.qw{
  display:inline-block;
  filter:blur(10px);
  opacity:0;
  transform:translateY(10px);
  transition:filter .6s cubic-bezier(.16,1,.3,1),opacity .6s cubic-bezier(.16,1,.3,1),transform .6s cubic-bezier(.16,1,.3,1);
}
.qw-hl{
  background:var(--ag);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}

/* Author pill — redesigned */
.ab-fq-author{
  display:inline-flex;
  align-items:center;
  gap:14px;
  background:var(--s2);
  border:1px solid var(--bd);
  border-radius:999px;
  padding:8px 20px 8px 8px;
  opacity:0;
  transform:translateY(20px);
  transition:opacity .7s ease,transform .7s ease,border-color .3s,background .3s;
  cursor:default;
}
.ab-fq-author.visible{opacity:1;transform:translateY(0)}
.ab-fq-author:hover{border-color:rgba(79,142,247,.45);background:var(--s3)}

.ab-fq-av-wrap{
  position:relative;
  width:52px;height:52px;
  flex-shrink:0;
  border-radius:50%;
}
.ab-fq-av-spin{
  position:absolute;
  inset:-2px;
  border-radius:50%;
  background:conic-gradient(#4F8EF7 0deg,#1A3A8F 180deg,#4F8EF7 360deg);
  animation:spinGrad 2.5s linear infinite;
  z-index:0;
}
@keyframes spinGrad{to{transform:rotate(360deg)}}
.ab-fq-av-inner{
  position:absolute;
  inset:2px;
  border-radius:50%;
  overflow:hidden;
  background:var(--s3);
  z-index:1;
  display:flex;align-items:center;justify-content:center;
}
.ab-fq-av-img{
  width:100%;height:100%;
  object-fit:cover;object-position:top center;
  display:block;
}
.ab-fq-av-fb{
  display:none;
  align-items:center;justify-content:center;
  width:100%;height:100%;
  font-family:'Syne',sans-serif;font-size:12px;font-weight:700;
  color:#fff;
  background:var(--ag);
  border-radius:50%;
}

.ab-fq-info{text-align:left}
.ab-fq-name{
  font-family:'Syne',sans-serif;
  font-size:13px;font-weight:700;
  color:var(--w);letter-spacing:-.01em;
  line-height:1.2;
}
.ab-fq-role{
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--wm);margin-top:3px;
}
.ab-fq-sep{color:var(--bd);margin:0 3px}

.ab-fq-avail{
  display:flex;align-items:center;gap:6px;
  margin-left:4px;padding-left:14px;
  border-left:1px solid var(--bd);
  font-family:'JetBrains Mono',monospace;
  font-size:8px;letter-spacing:.12em;text-transform:uppercase;
  color:var(--green);
  flex-shrink:0;
}

/* ═══════════ RESULTS ═══════════ */
.ab-results-sec{background:var(--bg);padding:80px 0}
.ab-res-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:48px}
.ab-res-card {
  background:var(--s1);border:1px solid var(--bd);
  border-radius:20px;padding:32px;
  position:relative;overflow:hidden;
  transition:border-color .25s,transform .25s;
}
.ab-res-card::before {
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--ag);
  transform:scaleX(0);transform-origin:left;
  transition:transform .5s cubic-bezier(.16,1,.3,1);
}
.ab-res-card:hover{border-color:rgba(79,142,247,.35);transform:translateY(-5px)}
.ab-res-card:hover::before{transform:scaleX(1)}

.ab-rc-head {
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:24px;
}
.ab-rc-tag {
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--ac);
  background:var(--agl);
  border:1px solid rgba(79,142,247,.2);
  padding:4px 10px;border-radius:999px;
}
.ab-rc-gsc {
  font-family:'JetBrains Mono',monospace;
  font-size:8px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--green);
}
.ab-rc-metrics{display:flex;flex-direction:column;gap:16px;margin-bottom:16px}
.ab-rc-val {
  font-family:'Instrument Serif',serif;
  font-size:clamp(26px,2.5vw,34px);
  font-weight:400;line-height:1;
  margin-bottom:4px;
}
.ab-rc-lbl {
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--wm);
}
.ab-rc-method{font-size:12px;color:var(--wd);line-height:1.65;margin-bottom:16px}
.ab-rc-bar{height:3px;background:var(--s3);border-radius:2px;overflow:hidden}
.ab-rc-fill{height:100%;background:var(--ag);border-radius:2px;width:var(--pct)}

.ab-cite-strip {
  background:var(--s1);border:1px solid var(--bd);
  border-radius:16px;padding:24px 32px;
  display:flex;align-items:center;gap:32px;
  flex-wrap:wrap;
}
.ab-cs-label {
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--wd);
  flex-shrink:0;
}
.ab-cs-platforms{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.ab-cs-p {
  display:flex;align-items:center;gap:8px;
  font-family:'Syne',sans-serif;font-size:13px;font-weight:600;
  color:var(--wd);
}
.ab-cs-icon{width:16px;height:16px;object-fit:contain;opacity:.7}

@media(max-width:900px){
  .ab-res-grid{grid-template-columns:1fr}
  .ab-cite-strip{flex-direction:column;align-items:flex-start;gap:16px}
}

/* ═══════════ TESTIMONIALS (shared with homepage) ═══════════ */
.ab-testi{background:var(--s1);padding-bottom:80px}
.tmi-wrap{position:relative;overflow:hidden;padding:8px 0}
.tmi-fade-l,.tmi-fade-r{position:absolute;top:0;bottom:0;width:180px;z-index:2;pointer-events:none}
.tmi-fade-l{left:0;background:linear-gradient(90deg,var(--s1) 30%,transparent)}
.tmi-fade-r{right:0;background:linear-gradient(270deg,var(--s1) 30%,transparent)}
.tmi-row{overflow:hidden}
.tmi-track{display:flex;gap:16px;width:max-content;animation:tmiL 55s linear infinite}
.tmi-rev{animation:tmiR 55s linear infinite}
.tmi-wrap:hover .tmi-track{animation-play-state:paused}
@keyframes tmiL{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes tmiR{from{transform:translateX(-50%)}to{transform:translateX(0)}}
.tc{background:var(--bg);border:1px solid var(--bd);border-radius:20px;padding:28px;width:360px;flex-shrink:0;transition:border-color .25s,transform .25s;display:flex;flex-direction:column;gap:16px}
.tc:hover{border-color:var(--ac);transform:translateY(-4px)}
.tc-stars{color:#F59E0B;font-size:11px;letter-spacing:3px}
.tc-q{font-family:'Instrument Serif',serif;font-size:14px;font-style:italic;color:var(--wd);line-height:1.75;flex:1}
.tc-author{display:flex;align-items:center;gap:12px;padding-top:16px;border-top:1px solid var(--bd)}
.tc-av{width:36px;height:36px;border-radius:50%;background:var(--ag);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.tc-name{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--w)}
.tc-role{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--wm)}
@media(max-width:768px){.tc{width:300px;padding:20px}.tmi-fade-l,.tmi-fade-r{width:60px}}

/* ═══════════ CTA ═══════════ */
.ab-cta-sec{background:var(--bg);padding:80px 0}
.ab-cta-inner{
  text-align:center;
  max-width:640px;margin:0 auto;
}
.ab-cta-sub {
  font-size:16px;color:var(--wd);
  max-width:440px;margin:20px auto 36px;
  line-height:1.75;
}
.ab-cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:28px}
.ab-cta-trust {
  display:flex;align-items:center;justify-content:center;gap:10px;
  flex-wrap:wrap;
  font-family:'JetBrains Mono',monospace;
  font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--wm);
}
.ab-cta-trust span:nth-child(even){color:var(--bd)}

/* ═══════════ FOOTER (shared with homepage) ═══════════ */
.site-footer{background:var(--s1);border-top:1px solid var(--bd);padding:80px 0 0;position:relative;z-index:1}
.ft-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1.4fr;gap:48px;padding-bottom:64px;border-bottom:1px solid var(--bd)}
.ft-logo{font-size:20px;margin-bottom:12px;display:flex;align-items:baseline;gap:1px}
.ft-desc{font-size:13px;color:var(--wm);line-height:1.75;margin-bottom:16px;max-width:280px}
.ft-loc{display:flex;align-items:center;gap:7px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--wm)}
.ft-col-t{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--w);margin-bottom:16px}
.ft-links{display:flex;flex-direction:column;gap:8px}
.ft-links li a{font-size:13px;color:var(--wm);transition:color .2s}
.ft-links li a:hover{color:var(--w)}
.ft-socials{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px}
.ft-soc{width:36px;height:36px;border-radius:8px;border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;color:var(--wm);transition:border-color .2s,color .2s,background .2s}
.ft-soc:hover{border-color:var(--ac);color:var(--ac);background:var(--agl)}
.ft-ai-links{display:flex;gap:8px;flex-wrap:wrap}
.ft-ai-btn{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--wd);padding:6px 12px;border:1px solid var(--bd);border-radius:6px;transition:border-color .2s,color .2s,background .2s}
.ft-ai-btn:hover{border-color:var(--ac);color:var(--ac);background:var(--agl)}
.ft-bottom{display:flex;justify-content:space-between;padding:24px 0;flex-wrap:wrap;gap:8px}
.ft-copy{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--wd)}
.ft-mq{border-top:1px solid var(--bd);overflow:hidden;padding:16px 0;position:relative}
.ft-mq-track{display:flex;gap:40px;width:max-content;animation:mq 40s linear infinite}
.ft-mq-i{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--wd);opacity:.75;white-space:nowrap}

@media(max-width:1024px){.ft-grid{grid-template-columns:1fr 1fr;gap:32px}}
@media(max-width:600px){.ft-grid{grid-template-columns:1fr;gap:24px}.ft-bottom{flex-direction:column}}

/* ═══════════ LIGHT MODE OVERRIDES ═══════════ */
html.light .ab-chip{background:var(--s2);border-color:var(--bd)}
html.light .ab-photo-card,.html.light .ab-stat-card{background:var(--s1)}
html.light .ab-bento-sec{background:var(--bg)}
html.light .ab-fq-sec{background:var(--s1)}
html.light .ab-results-sec{background:var(--bg)}
html.light .ab-testi{background:var(--s1)}
html.light .ab-cta-sec{background:var(--bg)}
html.light .tc{background:var(--s2)}
html.light .tmi-fade-l{background:linear-gradient(90deg,var(--s1) 30%,transparent)}
html.light .tmi-fade-r{background:linear-gradient(270deg,var(--s1) 30%,transparent)}
html.light .ab-res-card{background:var(--s1)}
html.light .ab-cite-strip{background:var(--s1)}
html.light .ab-diff{background:var(--s2)}
html.light .site-footer{background:var(--s1)}

/* Mobile hero adjustments */
@media(max-width:768px){
  .ab-hero{padding:120px 24px 80px}
  .ab-name{font-size:clamp(44px,13vw,80px);gap:0.08em}
  .ab-chips{gap:6px;flex-wrap:wrap}
  .ab-chip{font-size:8px;padding:4px 10px}
  .ab-chip-dot{display:none}
  .ab-soc span{display:none}
  .ab-soc{padding:8px}
  .ab-hero-sub{font-size:16px;margin-bottom:32px;padding:0 8px}
  .ab-hero-socials{gap:6px}
}
@media(max-width:480px){
  .ab-name{font-size:clamp(38px,12vw,60px);letter-spacing:-.03em}
  .ab-hero-sub{font-size:15px}
  .ab-hero-label{font-size:9px}
}

/* ════════════════════════════════════════════════════════════
   02 EDITORIAL DOSSIER (replaces bento cards)
   ════════════════════════════════════════════════════════════ */
.ab-doss-sec{padding:120px 0 100px;position:relative;z-index:1;overflow-x:clip}
.ab-doss-mast{display:flex;align-items:center;gap:14px;margin-bottom:48px;padding-bottom:18px;border-bottom:1px solid var(--bd);flex-wrap:wrap;min-width:0}
.ab-doss-mast .stamp{font-family:var(--fm);font-size:9px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--ac);padding:5px 10px;border:1px solid rgba(79,142,247,.28);border-radius:3px;background:var(--agl)}
.ab-doss-mast-line{flex:1 1 auto;height:1px;background:var(--bd);min-width:24px}
.ab-doss-mast-meta{font-family:var(--fm);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--wm)}

.ab-doss-spread{
  display:grid;
  grid-template-columns:minmax(0,400px) minmax(0,1fr);
  gap:56px;
  align-items:start;
  min-width:0;
}

/* ─── Portrait (left) — STICKY, stays in view as stats scroll past ─── */
.ab-doss-portrait{
  margin:0;
  display:flex;flex-direction:column;gap:14px;
  position:sticky;
  top:96px;
  align-self:start;
}
.ab-doss-portrait-frame{
  position:relative;
  aspect-ratio:4/5;
  border-radius:14px;
  overflow:hidden;
  background:linear-gradient(180deg, var(--s2) 0%, var(--s1) 100%);
  border:1px solid var(--bd);
  box-shadow:0 32px 80px rgba(0,0,0,.45), inset 0 1px 0 rgba(255,255,255,.04);
}
.ab-doss-portrait-frame::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 80% 60% at 50% 20%, rgba(79,142,247,.10) 0%, transparent 60%);
  z-index:1;
}
.ab-doss-img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;position:relative;z-index:0;transition:transform 1.2s cubic-bezier(.16,1,.3,1)}
.ab-doss-portrait:hover .ab-doss-img{transform:scale(1.025)}
.ab-doss-portrait-init{
  position:absolute;inset:0;display:none;align-items:center;justify-content:center;
  font-family:var(--fd);font-size:120px;letter-spacing:-.04em;color:var(--w);font-weight:400;
  z-index:0;
}
.ab-doss-portrait-frame.no-img .ab-doss-portrait-init{display:flex}
.ab-doss-portrait-init span{}
.ab-doss-portrait-init em{
  font-style:italic;
  background:linear-gradient(135deg,var(--ac) 0%,var(--ac2) 100%);
  -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
  margin-left:4px;
}
.ab-doss-portrait-tag{
  position:absolute;top:16px;left:16px;z-index:2;
  display:inline-flex;align-items:center;gap:7px;
  font-family:var(--fm);font-size:9px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;
  color:rgba(255,255,255,.92);
  padding:6px 11px;border-radius:999px;
  background:rgba(0,0,0,.45);
  border:1px solid rgba(255,255,255,.12);
  backdrop-filter:blur(8px);
  max-width:calc(100% - 32px);
  flex-wrap:wrap;
  box-sizing:border-box;
}
html.light .ab-doss-portrait-tag{color:var(--w);border-color:rgba(26,23,20,.12);background:rgba(248,246,242,.88)}
.ab-doss-cap{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;flex-wrap:wrap;padding-top:6px;min-width:0}
.ab-doss-cap-name{font-family:var(--fd);font-size:22px;font-style:italic;color:var(--w);letter-spacing:-.015em}
.ab-doss-cap-meta{display:inline-flex;align-items:flex-start;gap:6px;font-family:var(--fm);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--wm);line-height:1.45;flex:1;min-width:0;flex-wrap:wrap}
.ab-doss-cap-meta svg{flex-shrink:0;margin-top:2px}

/* ─── Stats column (right) ─── */
.ab-doss-stats{display:flex;flex-direction:column;gap:32px;min-width:0}
.ab-doss-deck{
  font-family:var(--fu);
  font-size:15px;
  color:var(--wd);
  line-height:1.7;
  margin:0;max-width:560px;
  border-left:2px solid var(--ac);
  padding-left:16px;
  box-sizing:border-box;
  min-width:0;
}

.ab-doss-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column}
.ab-doss-row{
  display:grid;
  grid-template-columns:42px 1fr;
  gap:18px;
  padding:22px 0;
  border-bottom:1px dashed var(--bd);
  position:relative;
  transition:padding-left .45s cubic-bezier(.16,1,.3,1);
}
.ab-doss-row::before{
  content:'';position:absolute;left:-12px;right:-12px;top:0;width:0;height:100%;
  background:linear-gradient(90deg, var(--agl), transparent);
  transition:width .55s cubic-bezier(.16,1,.3,1);
  pointer-events:none;
  z-index:-1;
  border-radius:6px;
}
.ab-doss-row:hover{padding-left:10px}
.ab-doss-row:hover::before{width:calc(100% + 24px)}
.ab-doss-row:first-child{border-top:1px dashed var(--bd)}

.ab-doss-row-num{
  font-family:var(--fd);font-size:24px;font-style:italic;font-weight:400;
  line-height:.85;letter-spacing:-.02em;
  align-self:start;padding-top:14px;
  color:var(--wm);
}
.ab-doss-row-body{display:flex;flex-direction:column;gap:6px;min-width:0}

/* Inline header line: stat value + label + tick badge all in one row */
.ab-doss-row-line{
  display:flex;align-items:center;gap:14px;flex-wrap:wrap;
  min-width:0;
}
.ab-doss-row-val{
  font-family:var(--fd);font-size:clamp(34px,3.6vw,46px);font-weight:400;font-style:italic;
  line-height:1;letter-spacing:-.025em;
  display:inline-block;
  flex-shrink:0;
}
.ab-doss-row-label{
  font-family:var(--fm);font-size:10px;font-weight:600;
  letter-spacing:.18em;text-transform:uppercase;
  color:var(--w);
  flex-shrink:0;
}
.ab-doss-row-tick{
