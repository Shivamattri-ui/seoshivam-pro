---

<Layout
  title={SITE_ROUTE_META['/about'].title}
  description={SITE_ROUTE_META['/about'].description}
  canonical="https://seoshivam.pro/about"
  schema={aboutSchema}
>

<Nav />

<div class="grid-bg"></div>
<div class="rays-wrap">{Array.from({length:12}).map((_,i)=><div class="ray" style={`--i:${i}`}></div>)}</div>
<div class="scroll-prog" id="scrollProg"></div>
<div class="cur-dot" id="curDot"></div>
<div class="cur-ring" id="curRing"></div>

<main id="main-content" aria-label="Main content">

<!-- ═══════════ 01 HERO ═══════════ -->
<section class="ab-hero">
  <div class="ab-glow-1"></div>
  <div class="ab-glow-2"></div>
  <div class="container ab-hero-inner">

    <div class="label ab-hero-label">
      <span class="adot"></span>
      About · seoshivam.pro
    </div>

    <h1 class="ab-name">
      <span class="ab-name-s ub" style="--ud:0.05s">Shivam</span><em class="ab-name-e ub" style="--ud:0.25s"> Attri</em>
    </h1>

    <div class="ab-chips ub" style="--ud:0.5s">
      <span class="ab-chip">AEO Specialist</span>
      <span class="ab-chip-dot"></span>
      <span class="ab-chip">SEO Strategist</span>
      <span class="ab-chip-dot"></span>
      <span class="ab-chip">AI-Visible Web Designer</span>
