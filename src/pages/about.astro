<!-- ═══════════ 02 EDITORIAL DOSSIER (no cards) ═══════════ -->
<section class="ab-doss-sec">
  <div class="container">

    <!-- Section masthead -->
    <header class="ab-doss-mast rv">
      <span class="stamp">FILE / OPERATOR DOSSIER</span>
      <span class="ab-doss-mast-line"></span>
      <span class="ab-doss-mast-meta">Active &middot; Updated weekly</span>
    </header>

    <!-- Editorial spread: portrait + asymmetric stats column -->
    <div class="ab-doss-spread">

      <!-- LEFT: portrait + caption -->
      <figure class="ab-doss-portrait rv">
        <div class="ab-doss-portrait-frame">
          <img src="/images/shivam-portrait-square.jpg" width="520" height="640" alt="Shivam Attri, AEO Specialist and SEO Strategist based in India" class="ab-doss-img" loading="eager" onerror="this.onerror=null;this.src='/shivam-attri.jpg';">
          <div class="ab-doss-portrait-init" aria-hidden="true"><span>S</span><em>A</em></div>
          <span class="ab-doss-portrait-tag">
            <span class="adot" style="width:6px;height:6px"></span>
            Available globally
          </span>
        </div>
        <figcaption class="ab-doss-cap">
          <span class="ab-doss-cap-name">Shivam Attri</span>
          <span class="ab-doss-cap-meta">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            India &middot; Worldwide
          </span>
        </figcaption>
      </figure>

      <!-- RIGHT: editorial running stats (no cards) -->
      <div class="ab-doss-stats">

        <p class="ab-doss-deck rv">
          The numbers below are pulled from Google Search Console screenshots and direct client communication.
          Names withheld under NDA. Every figure is verifiable on request.
        </p>

        <ol class="ab-doss-list">
          <li class="ab-doss-row rv d1" data-stat data-target="16" data-suffix="&times;">
            <span class="ab-doss-row-num grad-anim">01</span>
            <div class="ab-doss-row-body">
              <div class="ab-doss-row-line">
                <span class="ab-doss-row-val grad-anim">16&times;</span>
                <span class="ab-doss-row-label">click growth</span>
                <span class="ab-doss-row-tick"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><polyline points="20 6 9 17 4 12"/></svg>GSC verified</span>
              </div>
              <p class="ab-doss-row-note">63 to 1,010 organic clicks in 30 days. HealthTech SaaS, India. Position 48.5 to 31.5. Zero ad spend increase.</p>
            </div>
          </li>

          <li class="ab-doss-row rv d2" data-stat data-target="7" data-suffix="+">
            <span class="ab-doss-row-num grad-anim">02</span>
            <div class="ab-doss-row-body">
              <div class="ab-doss-row-line">
                <span class="ab-doss-row-val grad-anim">7+</span>
                <span class="ab-doss-row-label">years compounding</span>
                <span class="ab-doss-row-tick ab-doss-row-tick--blue">SEO &middot; AEO &middot; WEB</span>
              </div>
              <p class="ab-doss-row-note">SEO since 2018. AEO since 2022. Logistics, health tech, hospitality, ecommerce, B2B SaaS. The work that keeps paying past the engagement.</p>
            </div>
          </li>

          <li class="ab-doss-row rv d3" data-stat data-target="30" data-suffix="+">
            <span class="ab-doss-row-num grad-anim">03</span>
            <div class="ab-doss-row-body">
              <div class="ab-doss-row-line">
                <span class="ab-doss-row-val grad-anim">30+</span>
                <span class="ab-doss-row-label">brands shipped</span>
                <span class="ab-doss-row-tick ab-doss-row-tick--blue">US &middot; UK &middot; EU &middot; AU &middot; IN</span>
              </div>
              <p class="ab-doss-row-note">Across the US, UK, EU, Australia, and India. Async-friendly. English-first delivery. Every engagement begins with a 1-page audit, not a slide deck.</p>
            </div>
          </li>

          <li class="ab-doss-row rv d4" data-stat data-target="20" data-suffix="+">
            <span class="ab-doss-row-num grad-anim">04</span>
            <div class="ab-doss-row-body">
              <div class="ab-doss-row-line">
                <span class="ab-doss-row-val grad-anim">20+</span>
                <span class="ab-doss-row-label">AI citations tracked</span>
                <span class="ab-doss-row-tick"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><polyline points="20 6 9 17 4 12"/></svg>GSC verified</span>
              </div>
              <p class="ab-doss-row-note">For a single Health Tech client. Tracked across ChatGPT, Perplexity, Google AI Overviews, and Claude. The output of one content system, not a campaign.</p>
            </div>
          </li>
        </ol>

        <!-- Footer strip: BCA + skills (inline, no card) -->
        <div class="ab-doss-foot rv">
          <span class="ab-doss-foot-eye">BACKGROUND &middot; ENGINEERING FOUNDATION</span>
          <p class="ab-doss-foot-line">
            <strong>Bachelor of Computer Applications.</strong>
            <span>Code first. Then content. Then schema. Then distribution. The rare combination that lets one person ship the website, write the words, and structure the markup AI engines can actually parse.</span>
          </p>
          <div class="ab-doss-foot-stack">
            {['HTML/CSS','JavaScript','PHP','SQL','WordPress','Webflow','Framer','Astro','JSON-LD','n8n'].map((s,i)=>(
              <span class="ab-doss-stack-tag" style={`--di:${i}`}>{s}</span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ═══════════ 03 ORIGIN STORY (editorial essay) ═══════════ -->
<section class="ab-story-sec">
  <div class="container">

    <!-- Section masthead -->
    <header class="ab-st-hdr rv">
      <div class="hair left">ORIGIN STORY / 2018 &rarr; PRESENT</div>
      <h2 class="ab-st-h">
        From <em class="grad-anim">code</em> to content<br>
