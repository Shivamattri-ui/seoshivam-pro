---
import Layout from '../layouts/Layout.astro';
import { SITE_ROUTE_META } from '../lib/site-route-meta';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FaqBlock from '../components/FaqBlock.astro';
import ContactCta from '../components/ContactCta.astro';

const aboutFaqs = [
  { q: 'Who is Shivam Attri and what does he actually do?', a: 'Shivam Attri is an AEO Specialist and SEO Strategist based in India, working with B2B SaaS founders and growing brands across the US, UK, EU, Australia, and India. The work covers Answer Engine Optimization, SEO architecture, programmatic SEO, and AI-visible web design on Webflow, Framer, Astro, and WordPress. Seven years across 150+ shipped websites and 50+ landing pages.' },
  { q: 'How is this different from hiring a typical SEO agency?', a: 'Most agencies deliver reports. The work here delivers a content and schema architecture that compounds. One person owns the build, the writing, the schema, and the search outcome. No 8-week ramp, no junior team, no monthly deliverables decoupled from the actual ranking trajectory. The output is a system, not a slide deck.' },
  { q: 'What does "AI-visible" actually mean?', a: 'A website that AI engines understand confidently and cite consistently. That means: technical crawlability (AI bots can actually access the content, Bingbot indexes the site), entity clarity (JSON-LD schema that establishes who you are and what you do), semantic structure (content organized so AI systems can extract clean answers), and answer-first writing (the direct response is in the first two sentences, not paragraph six). When all four layers are working, AI engines cite your brand for the queries your buyers actually type.' },
  { q: 'Do you take on clients globally?', a: 'Yes. Engagements run async-friendly across the US, UK, EU, Australia, Canada, and India. All work in English. Time-zone coverage spans most US business hours into European late afternoon comfortably. India clients get same-day response. US clients get 4-hour reply windows during their business day.' },
  { q: 'What is the typical engagement structure?', a: 'Most engagements start with a one-page audit (free) to confirm fit. From there, scopes range from a 4-week schema retrofit, to a 12-week topical-authority build, to ongoing AEO content systems. Web design builds run separately on a project basis. No retainer model where work and outcomes are decoupled.' },
  { q: 'How do I work with you?', a: 'Send a URL and a one-line description of the goal via the contact page. A reply with the audit and a clear next step lands in your inbox within 4 hours during India business hours, 24 hours otherwise. If the fit is right, a 20-minute intro call happens before any contract. No long sales process.' },
];

const aboutSchema = {
