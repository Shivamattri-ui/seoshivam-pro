        "JSON-LD Schema Markup",
        "Entity Optimization",
        "E-E-A-T",
        "Webflow Development",
        "Framer Development",
        "Astro Development",
        "WordPress Development",
        "Content Architecture",
        "B2B SaaS Marketing"
      ],
      "hasOccupation": {
        "@type": "Occupation",
        "name": "AEO Specialist and SEO Strategist",
        "description": "Specializes in Answer Engine Optimization — making brands visible and citable across AI search platforms including ChatGPT, Perplexity, Google AI Overviews, and Claude."
      },
      "worksFor": {
        "@type": "Organization",
        "name": "seoshivam.pro",
        "url": "https://seoshivam.pro"
      },
