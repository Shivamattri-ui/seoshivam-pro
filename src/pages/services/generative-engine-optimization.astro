---
import Layout from '../../layouts/Layout.astro';
import { SITE_ROUTE_META } from '../../lib/site-route-meta';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ContactCta from '../../components/ContactCta.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Generative Engine Optimization (GEO)",
      "description": "Generative engine optimization that gets your brand named in AI-generated answers across ChatGPT, Perplexity, Google AI, Claude, Copilot, and Grok. Entity architecture, original-data assets, answer-first content, and earned off-site authority.",
      "provider": { "@type": "Person", "@id": "https://seoshivam.pro/#shivam" },
      "url": "https://seoshivam.pro/services/generative-engine-optimization",
      "areaServed": ["US", "UK", "AU", "CA", "DE", "IN"]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://seoshivam.pro"},
        {"@type":"ListItem","position":2,"name":"Services","item":"https://seoshivam.pro/services"},
        {"@type":"ListItem","position":3,"name":"Generative Engine Optimization","item":"https://seoshivam.pro/services/generative-engine-optimization"}
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is generative engine optimization (GEO)?", "acceptedAnswer": { "@type": "Answer", "text": "Getting your brand named when AI engines answer a buyer's question. Not buying your way onto a listicle. It is making the engines trust you enough to name you: clear entity signals, original data, answer-first content, and mentions on sources they already trust." } },
        { "@type": "Question", "name": "How is GEO different from SEO and AEO?", "acceptedAnswer": { "@type": "Answer", "text": "SEO gets you ranked in a list of links. AEO gets you extracted into a direct answer. GEO is the broader job of making AI recommend your brand everywhere it answers. Same foundation, so you do all three from one architecture and they compound." } },
        { "@type": "Question", "name": "How much do GEO services cost?", "acceptedAnswer": { "@type": "Answer", "text": "Depends where you start and how fast you want to move. Market rate runs roughly 2,000 to 25,000 US dollars a month by scope. I scope to what you actually need, no bloated retainer, and you get a real number after a free audit, not a guess up front." } },
        { "@type": "Question", "name": "How long does GEO take to work?", "acceptedAnswer": { "@type": "Answer", "text": "First citations usually land in 30 to 90 days with some authority, 60 to 120 on a newer domain. Fastest wins come from fixing crawl access and entity signals, then earning a few trusted mentions. Pages get maintained, not published once and forgotten." } },
        { "@type": "Question", "name": "Which AI engines do you optimize for?", "acceptedAnswer": { "@type": "Answer", "text": "ChatGPT, Perplexity, Google AI, Claude, Copilot, and Grok. Each weighs signals differently. Copilot leans on Bing, Perplexity on freshness, Claude on verifiable credibility and a non-promotional tone. Tracked across all six every month." } },
        { "@type": "Question", "name": "Do you work with brands outside SaaS?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Growth-stage startups, marketing, IT and software, SaaS, logistics, healthtech, manufacturing, ecommerce, hospitality, consultancies. The fundamentals are the same everywhere. What changes is the buyer query set and the sources each field's answers pull from." } }
      ]
    }
  ]
};

const engines = [
  { f: 'chatgpt-icon',    n: 'ChatGPT' },
  { f: 'perplexity-icon', n: 'Perplexity' },
  { f: 'google-gemini',   n: 'Google AI' },
  { f: 'claude-icon',     n: 'Claude' },
  { f: 'copilot-icon',    n: 'Copilot' },
  { f: 'grok-icon',       n: 'Grok' },
];

const included = [
  { n: '01', t: 'Multi-engine visibility audit', d: 'Start with the truth. Where your brand actually shows up across six AI engines for your 20 real buyer queries. Most brands find they are missing from half of them while ranking fine on Google.' },
  { n: '02', t: 'Entity architecture', d: 'AI names brands it can identify. Organization and Person schema, consistent naming, sameAs signals across the profiles models cross-reference. Get this wrong and nothing else lands.' },
  { n: '03', t: 'Original-data assets', d: 'The lever nobody uses. One benchmark from your own data makes you a primary source, and primary sources get cited far more than pages recycling everyone else’s numbers.' },
  { n: '04', t: 'Answer-first content', d: 'Restructured so the answer leads, backed by a specific number, in a format engines lift cleanly. Not more blog posts. The few pages AI actually pulls from.' },
  { n: '05', t: 'Earned off-site authority', d: 'Most citation weight lives off your site. Real contributions where AI keeps citing, listings where your category gets reviewed, mentions on pages that already rank as sources. Earned, not bought.' },
  { n: '06', t: 'Multi-engine citation tracking', d: 'Monthly, manual, per query, across every engine. You see who cites you, for what, and what to fix next. No vanity dashboard, just what moved.' },
];

const stats = [
  { v: 6,  suf: '',    l: 'AI engines tracked every month, manually, per query' },
  { v: 90, suf: '',    pre: '30–', l: 'Days to first citations on a site with some authority' },
  { v: 10, suf: '',    l: 'Industries shipped across, from SaaS to logistics to healthtech' },
];

const industries = ['Growth strategy','Marketing','IT & Software','SaaS','Logistics','HealthTech','Manufacturing','Ecommerce','Hospitality','Consultancies'];

const faqs = [
  { q: "What is generative engine optimization (GEO)?", a: "Getting your brand named when AI engines answer a buyer's question. Not buying your way onto a listicle. It is making the engines trust you enough to name you: clear entity signals, original data, answer-first content, and mentions on sources they already trust." },
  { q: "How is GEO different from SEO and AEO?", a: "SEO gets you ranked in a list of links. AEO gets you extracted into a direct answer. GEO is the broader job of making AI recommend your brand everywhere it answers. Same foundation, so you do all three from one architecture and they compound." },
  { q: "How much do GEO services cost?", a: "Depends where you start and how fast you want to move. Market rate runs roughly $2K to $25K a month by scope. I scope to what you actually need, no bloated retainer, and you get a real number after a free audit, not a guess up front." },
  { q: "How long does GEO take to work?", a: "First citations usually land in 30 to 90 days with some authority, 60 to 120 on a newer domain. Fastest wins come from fixing crawl access and entity signals, then earning a few trusted mentions. Pages get maintained, not published once and forgotten." },
  { q: "Which AI engines do you optimize for?", a: "ChatGPT, Perplexity, Google AI, Claude, Copilot, and Grok. Each weighs signals differently. Copilot leans on Bing, Perplexity on freshness, Claude on verifiable credibility and a non-promotional tone. Tracked across all six every month." },
  { q: "Do you work with brands outside SaaS?", a: "Yes. Growth-stage startups, marketing, IT and software, SaaS, logistics, healthtech, manufacturing, ecommerce, hospitality, consultancies. The fundamentals are the same everywhere. What changes is the buyer query set and the sources each field's answers pull from." },
];
---

<Layout
  title={SITE_ROUTE_META['/services/generative-engine-optimization'].title}
  description={SITE_ROUTE_META['/services/generative-engine-optimization'].description}
  canonical="https://seoshivam.pro/services/generative-engine-optimization"
  schema={schema}
>
  <Nav />
  <div class="scroll-prog" id="scrollProg"></div>
  <div class="cur-dot" id="curDot"></div>
  <div class="cur-ring" id="curRing"></div>

  <main class="geo">

    <!-- ============ HERO (locked) ============ -->
    <section class="gh">
      <div class="gh-grid" aria-hidden="true"></div>
      <div class="gh-blob gh-blob-1" aria-hidden="true"></div>
      <div class="gh-blob gh-blob-2" aria-hidden="true"></div>

      <div class="container gh-inner">
        <div class="gh-eyebrow rv">
          <span class="gh-dot"></span>
          Generative Engine Optimization
          <span class="gh-eyebrow-sep">/</span>
          <span class="gh-eyebrow-dim">GEO</span>
        </div>

        <h1 class="gh-h1">
          <span class="gh-line rv d1">Generative engine optimization</span>
          <span class="gh-line rv d2">that puts your brand</span>
          <span class="gh-line gh-line-em rv d3"><em>in the answer.</em></span>
        </h1>

        <div class="gh-foot rv d4">
          <p class="gh-deck">A buyer asks ChatGPT, Perplexity, or Google AI who’s best in your space. One brand gets named. My GEO work makes sure it’s yours. Entity, real data, and earned authority. Not bought placements.</p>
          <div class="gh-actions">
            <a href="/contact" class="gh-btn gh-btn-primary mag">Book a GEO audit<span class="gh-btn-arr">↗</span></a>
            <a href="#next" class="gh-btn gh-btn-ghost">See how it works</a>
          </div>
        </div>

        <div class="gh-proof rv d5">
          <span class="gh-proof-label">Getting brands named across</span>
          <div class="gh-logos">
            {engines.map(e => (
              <span class="gh-logo" title={e.n}>
                <img src={`/icons/${e.f}.svg`} alt={`${e.n} logo`} width="22" height="22" loading="lazy" decoding="async" />
              </span>
            ))}
          </div>
        </div>
      </div>

      <a href="#next" class="gh-scroll" aria-label="Scroll to continue"><span class="gh-scroll-line"></span></a>
    </section>

    <div id="next"></div>

    <!-- ============ WEDGE ============ -->
    <section class="gs gs-wedge">
      <div class="container">
        <div class="gs-head gs-head-wide rv">
          <span class="gs-tag">The difference</span>
          <h2 class="gs-h2">GEO is not<br><em>buying placements.</em></h2>
          <p class="gs-lead">Half the agencies selling GEO just pay to slot you onto a listicle and call it strategy. That works until the model stops trusting the list. It is rented, and it does not compound. Real GEO makes the engines trust you on your own merits.</p>
        </div>
        <div class="gs-cmp">
          <div class="gs-cmp-col gs-cmp-rented rv">
            <span class="gs-cmp-k">Rented</span>
            <ul>
              <li>Bought listicle slots</li>
              <li>Thin AI-spun articles</li>
              <li>One-off mentions</li>
              <li>Gone when the budget stops</li>
            </ul>
          </div>
          <div class="gs-cmp-col gs-cmp-earned rv d1">
            <span class="gs-cmp-k">Earned</span>
            <ul>
              <li>A clear, trusted entity</li>
              <li>Original data worth quoting</li>
              <li>Authority AI already reads</li>
              <li>Compounds every month</li>
            </ul>
          </div>
        </div>
        <p class="gs-note rv d1">Runs alongside <a href="/services/aeo" class="ilink">AEO</a> and <a href="/services/seo" class="ilink">SEO</a>, not instead of them. Same foundation, three surfaces. Full mechanics: <a href="/insights/aeo-vs-seo-difference" class="ilink">AEO vs SEO</a>.</p>
      </div>
    </section>

    <!-- ============ WHAT'S INSIDE (bento + GSAP) ============ -->
    <section class="gs gs-alt gs-inc">
      <div class="container">
        <div class="gs-head rv">
          <span class="gs-tag">What’s inside</span>
          <h2 class="gs-h2">The system,<br><em>not a checklist.</em></h2>
        </div>
        <div class="gs-bento" data-bento>
          {included.map((s, i) => (
            <article class={`gs-bcard gs-bcard-${i+1}`}>
              <span class="gs-bcard-glow" aria-hidden="true"></span>
              {i === 0 && (
                <div class="gfx gfx-scan" aria-hidden="true">
                  <span class="gfx-ring gfx-ring-1"></span>
                  <span class="gfx-ring gfx-ring-2"></span>
                  <span class="gfx-ring gfx-ring-3"></span>
                  <span class="gfx-sweep"></span>
                  <span class="gfx-chip gfx-chip-lit" style="top:24%;left:20%"><img src="/icons/chatgpt-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip gfx-chip-lit" style="top:20%;left:66%"><img src="/icons/perplexity-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip gfx-chip-lit" style="top:50%;left:44%"><img src="/icons/claude-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip gfx-chip-lit" style="top:70%;left:24%"><img src="/icons/google-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip gfx-chip-dim" style="top:66%;left:62%"><img src="/icons/copilot-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip gfx-chip-dim" style="top:30%;left:85%"><img src="/icons/grok-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-badge"><span class="gfx-badge-dot"></span>4 / 6 cited</span>
                </div>
              )}

              {i === 1 && (
                <div class="gfx gfx-ent" aria-hidden="true">
                  <svg class="gfx-svg" viewBox="0 0 340 184">
                    <g class="gfx-ent-link">
                      <line x1="170" y1="94" x2="72" y2="50"></line>
                      <line x1="170" y1="94" x2="268" y2="48"></line>
                      <line x1="170" y1="94" x2="76" y2="140"></line>
                      <line x1="170" y1="94" x2="264" y2="138"></line>
                    </g>
                    <g class="gfx-ent-sat"><circle cx="72" cy="50" r="20"></circle><text x="72" y="50">Org</text></g>
                    <g class="gfx-ent-sat"><circle cx="268" cy="48" r="20"></circle><text x="268" y="48">Person</text></g>
                    <g class="gfx-ent-sat"><circle cx="76" cy="140" r="20"></circle><text x="76" y="140">sameAs</text></g>
                    <g class="gfx-ent-sat"><circle cx="264" cy="138" r="20"></circle><text x="264" y="138">Author</text></g>
                    <circle class="gfx-ent-halo" cx="170" cy="94" r="31"></circle>
                    <circle class="gfx-ent-core" cx="170" cy="94" r="22"></circle>
                    <text class="gfx-ent-brand" x="170" y="94">SA</text>
                  </svg>
                </div>
              )}

              {i === 2 && (
                <div class="gfx gfx-bars" aria-hidden="true">
                  <div class="gfx-bars-row">
                    <span class="gfx-bar" style="--h:36%"></span>
                    <span class="gfx-bar" style="--h:54%"></span>
                    <span class="gfx-bar" style="--h:44%"></span>
                    <span class="gfx-bar gfx-bar-you" style="--h:94%"><span class="gfx-bar-tag">your data</span></span>
                    <span class="gfx-bar" style="--h:60%"></span>
                    <span class="gfx-bar" style="--h:40%"></span>
                  </div>
                </div>
              )}

              {i === 3 && (
                <div class="gfx gfx-ans" aria-hidden="true">
                  <div class="gfx-ans-card">
                    <div class="gfx-ans-head"><span class="gfx-ans-dot"></span>AI answer</div>
                    <p class="gfx-ans-lead">The best option here is <b>your brand</b>.<span class="gfx-ans-cursor"></span></p>
                    <span class="gfx-ans-line"></span>
                    <span class="gfx-ans-line gfx-ans-line-sh"></span>
                    <span class="gfx-ans-cite"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"></path></svg>cited · seoshivam.pro</span>
                  </div>
                </div>
              )}

              {i === 4 && (
                <div class="gfx gfx-ment" aria-hidden="true">
                  <svg class="gfx-svg" viewBox="0 0 340 184" preserveAspectRatio="none">
                    <g class="gfx-ent-link">
                      <line x1="54" y1="40" x2="212" y2="94"></line>
                      <line x1="27" y1="85" x2="212" y2="94"></line>
                      <line x1="61" y1="132" x2="212" y2="94"></line>
                      <line x1="150" y1="155" x2="212" y2="94"></line>
                    </g>
                  </svg>
                  <span class="gfx-chip" style="top:22%;left:16%"><img src="/icons/reddit-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip" style="top:46%;left:8%"><img src="/icons/substack-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip" style="top:72%;left:18%"><img src="/icons/linkedin-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-chip" style="top:84%;left:44%"><img src="/icons/x-icon.svg" alt="" width="17" height="17" loading="lazy" /></span>
                  <span class="gfx-ment-center" style="top:51%;left:62%">
                    <span class="gfx-ment-halo"></span>
                    <span class="gfx-ment-sa">SA</span>
                  </span>
                </div>
              )}

              {i === 5 && (
                <div class="gfx gfx-trend" aria-hidden="true">
                  <svg class="gfx-svg" viewBox="0 0 900 184" preserveAspectRatio="none">
                    <defs>
                      <linearGradient id="gfxTrendFill" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0" class="gfx-tf-0"></stop>
                        <stop offset="1" class="gfx-tf-1"></stop>
                      </linearGradient>
                    </defs>
                    <path class="gfx-trend-area" d="M0 150 C120 150 160 120 260 118 C380 116 420 92 540 82 C660 72 700 44 900 30 L900 184 L0 184 Z" fill="url(#gfxTrendFill)"></path>
                    <path class="gfx-trend-line" d="M0 150 C120 150 160 120 260 118 C380 116 420 92 540 82 C660 72 700 44 900 30"></path>
                  </svg>
                  <span class="gfx-tmark" style="left:9%;top:79%"><img src="/icons/google-icon.svg" alt="" width="16" height="16" loading="lazy" /></span>
                  <span class="gfx-tmark" style="left:40%;top:62%"><img src="/icons/perplexity-icon.svg" alt="" width="16" height="16" loading="lazy" /></span>
                  <span class="gfx-tmark" style="left:70%;top:41%"><img src="/icons/claude-icon.svg" alt="" width="16" height="16" loading="lazy" /></span>
                  <span class="gfx-tmark gfx-tmark-end" style="left:93%;top:14%"><img src="/icons/chatgpt-icon.svg" alt="" width="16" height="16" loading="lazy" /></span>
                  <span class="gfx-badge"><span class="gfx-badge-dot"></span>citations trending</span>
                </div>
              )}

              <span class="gs-bnum">{s.n}</span>
              <h3 class="gs-bt">{s.t}</h3>
              <p class="gs-bd">{s.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ ORBIT: model dome (half-circle, gradient arcs) ============ -->
    <section class="gs gs-orbit">
      <div class="go-glow" aria-hidden="true"></div>
      <div class="container go-head rv">
        <span class="gs-tag">Every engine, one brand</span>
        <h2 class="gs-h2">One GEO system.<br><em>Named across every model.</em></h2>
        <p class="gs-lead">ChatGPT, Perplexity, Google AI, Claude, Copilot, Grok. GEO gets your brand into the answer on all of them, not just Google.</p>
      </div>
      <div class="go-dome">
        <svg class="go-arcs" viewBox="0 0 1000 520" fill="none" aria-hidden="true">
          <defs>
            <linearGradient id="goArcGrad" x1="0" y1="0" x2="1000" y2="0" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="currentColor" stop-opacity="0"></stop>
              <stop offset="0.3" stop-color="currentColor" stop-opacity="0.5"></stop>
              <stop offset="0.5" stop-color="currentColor" stop-opacity="0.95"></stop>
              <stop offset="0.7" stop-color="currentColor" stop-opacity="0.5"></stop>
              <stop offset="1" stop-color="currentColor" stop-opacity="0"></stop>
            </linearGradient>
          </defs>
          <path d="M40 500 A460 460 0 0 1 960 500" stroke="url(#goArcGrad)" stroke-width="1.6"></path>
          <path d="M160 500 A340 340 0 0 1 840 500" stroke="url(#goArcGrad)" stroke-width="1.6"></path>
          <path d="M280 500 A220 220 0 0 1 720 500" stroke="url(#goArcGrad)" stroke-width="1.6"></path>
        </svg>
        <span class="go-node" style="left:71.6%;top:18.1%"><span class="go-chip"><img src="/icons/chatgpt-icon.svg" alt="ChatGPT" width="24" height="24" loading="lazy" decoding="async" /></span></span>
        <span class="go-node" style="left:28.4%;top:18.1%"><span class="go-chip"><img src="/icons/google-icon.svg" alt="Google AI" width="24" height="24" loading="lazy" decoding="async" /></span></span>
        <span class="go-node" style="left:6.8%;top:66%"><span class="go-chip"><img src="/icons/grok-icon.svg" alt="Grok" width="24" height="24" loading="lazy" decoding="async" /></span></span>
        <span class="go-node" style="left:77.8%;top:58.6%"><span class="go-chip"><img src="/icons/perplexity-icon.svg" alt="Perplexity" width="24" height="24" loading="lazy" decoding="async" /></span></span>
        <span class="go-node" style="left:47%;top:31%"><span class="go-chip go-chip-lg"><img src="/icons/claude-icon.svg" alt="Claude" width="26" height="26" loading="lazy" decoding="async" /></span></span>
        <span class="go-node" style="left:32%;top:71.9%"><span class="go-chip"><img src="/icons/copilot-icon.svg" alt="Copilot" width="24" height="24" loading="lazy" decoding="async" /></span></span>
      </div>
    </section>

    <!-- ============ INDUSTRIES ============ -->
    <section class="gs gs-alt gs-ind">
      <div class="container gs-head rv">
        <span class="gs-tag">Who it’s for</span>
        <h2 class="gs-h2 gs-h2-sm">The fundamentals travel.<br><em>The queries change.</em></h2>
      </div>
      <div class="gs-ind-marq" aria-hidden="true">
        <div class="gs-ind-track">
          {[...industries, ...industries].map(x => (<span class="gs-ind-i">{x}<span class="gs-ind-sep">✦</span></span>))}
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="gs gs-faq">
      <div class="container gs-faq-grid">
        <div class="gs-faq-l rv">
          <span class="gs-tag">FAQ</span>
          <h2 class="gs-h2 gs-h2-sm">Everything you’d ask<br><em>before starting.</em></h2>
          <p class="gs-faq-note">Still guessing? Run the <a href="/tools/ai-visibility-score" class="ilink">AI Visibility Score</a>, read <a href="/insights/how-to-get-cited-by-perplexity" class="ilink">how to get cited by Perplexity</a>, or just <a href="/ai-seo-consultant" class="ilink">hire an AEO consultant</a> and skip the DIY.</p>
        </div>
        <div class="gs-faq-r">
          <div class="faq-list">
            {faqs.map((f) => (
              <div class="faq-item">
                <button class="faq-btn" aria-expanded="false"><span>{f.q}</span><i class="faq-icon">+</i></button>
                <div class="faq-ans" hidden>{f.a}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <ContactCta
      id="geo-cta"
      source="services-geo"
      eyebrow="START WITH A FREE GEO AUDIT"
      heading="See why AI names your competitor"
      headingEm="and not you, yet."
      deck="The audit shows where you show up across the engines, where you don’t, and the shortest path to getting cited. Free, no commitment, replied within 4 hours."
    />

  </main>
  <Footer />

  <style>
  /* Accent flips site-wide: clay #DA7756 in light, brand blue in dark. */
  .geo{--gh-line:rgba(255,255,255,.075)}
  :global(html.light) .geo{--gh-line:rgba(20,16,12,.08)}

  /* ---------- HERO (locked) ---------- */
  .gh{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;padding:120px 0 80px}
  .gh-grid{position:absolute;inset:0;z-index:0;pointer-events:none;
    background-image:linear-gradient(var(--gh-line) 1px,transparent 1px),linear-gradient(90deg,var(--gh-line) 1px,transparent 1px);
    background-size:60px 60px;
    -webkit-mask:radial-gradient(150% 135% at 60% 34%,#000 50%,transparent 94%);
            mask:radial-gradient(150% 135% at 60% 34%,#000 50%,transparent 94%);
    animation:ghGridPulse 9s ease-in-out infinite}
