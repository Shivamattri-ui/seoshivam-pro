  }
  .seo-case-engines-l{font-family:'JetBrains Mono', monospace;font-size:9px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--wm)}
  .seo-case-engines-row{display:flex;flex-wrap:wrap;gap:5px}
  .seo-case-engine{
    font-family:'JetBrains Mono', monospace;font-size:9.5px;font-weight:600;letter-spacing:.08em;
    color:var(--ac);
    padding:4px 8px;border-radius:4px;
    background:var(--agl);border:1px solid rgba(79,142,247,.24);
  }

  .seo-case-tagline{
    margin-top:8px;padding-top:18px;
    border-top:1px solid var(--bd);
    display:flex;flex-direction:column;gap:8px;
  }
  .seo-case-tagline-eye{font-family:'JetBrains Mono', monospace;font-size:9px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--wm)}
  .seo-case-tagline p{
    font-family:'Instrument Serif',serif;font-size:22px;line-height:1.25;letter-spacing:-.018em;
    color:var(--w);margin:0;
