  .seo-case-row-v{display:inline-flex;align-items:center;gap:8px;flex-wrap:wrap}
  .seo-case-from{font-family:'JetBrains Mono', monospace;font-size:13px;color:var(--wm);font-variant-numeric:tabular-nums}
  .seo-case-row-v svg{color:var(--wm);flex-shrink:0}
  .seo-case-to{
    font-family:'Instrument Serif',serif;font-size:24px;font-style:italic;font-weight:400;
