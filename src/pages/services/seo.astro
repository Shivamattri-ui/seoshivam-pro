    border-radius:4px;padding:3px 7px;
    white-space:nowrap;
  }
  .seo-case-delta.up{color:var(--green)}
  .seo-case-row--hi .seo-case-to{font-size:28px}

  .seo-case-engines{
    margin-top:6px;padding:14px 0;
    border-top:1px solid var(--bd);
