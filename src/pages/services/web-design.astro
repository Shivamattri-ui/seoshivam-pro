  <script>
  const prog=document.getElementById('scrollProg');
  window.addEventListener('scroll',()=>{if(prog){const s=document.documentElement;prog.style.width=(s.scrollTop/(s.scrollHeight-s.clientHeight)*100)+'%'}},{passive:true});
  // Cursor handled globally by the .bcur system in Nav.astro (legacy loop removed).
  document.querySelectorAll('.faq-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const isOpen=btn.getAttribute('aria-expanded')==='true';
      document.querySelectorAll('.faq-btn').forEach(b=>{b.setAttribute('aria-expanded','false');const a=b.closest('.faq-item')?.querySelector('.faq-ans') as HTMLElement|null;if(a)a.hidden=true});
      if(!isOpen){btn.setAttribute('aria-expanded','true');const ans=btn.closest('.faq-item')?.querySelector('.faq-ans') as HTMLElement|null;if(ans)ans.hidden=false}
    });
  });

  const diffStage=document.getElementById('wd-diff-stage');
  if(diffStage){
    diffStage.dataset.tab='bad';
    const clearLinked=()=>{
      delete diffStage.dataset.activeRow;
      diffStage.querySelectorAll('.wd-diff-row.is-linked').forEach((r)=>r.classList.remove('is-linked'));
    };
    diffStage.querySelectorAll('.wd-diff-row').forEach((row)=>{
      row.addEventListener('mouseenter',()=>{
        const i=row.getAttribute('data-wd-diff-row');
        if(i==null)return;
        diffStage.dataset.activeRow=i;
        diffStage.querySelectorAll(`.wd-diff-row[data-wd-diff-row="${i}"]`).forEach((r)=>r.classList.add('is-linked'));
      });
      row.addEventListener('mouseleave',clearLinked);
    });
    document.querySelectorAll('[data-wd-diff-tab]').forEach((btn)=>{
      btn.addEventListener('click',()=>{
        const tab=btn.getAttribute('data-wd-diff-tab')||'bad';
        document.querySelectorAll('.wd-diff-tab').forEach((b)=>{
          const on=b===btn;
          b.classList.toggle('is-on',on);
          b.setAttribute('aria-selected',on?'true':'false');
        });
        diffStage.dataset.tab=tab;
        clearLinked();
      });
    });
  }
  </script>
</Layout>
