  .ah-cb{background:var(--s1);border:1px solid var(--bd);border-radius:10px;padding:clamp(10px,1.5vh,14px) 12px}
  .ah-cb-l{display:block;font-family:var(--fm);font-size:7.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--wm);margin-bottom:clamp(8px,1.2vh,12px)}
  .ah-cols{display:grid;grid-template-columns:repeat(6,1fr);gap:clamp(8px,1.6vw,18px);height:clamp(76px,11.5vh,116px)}
  .ah-col{display:grid;grid-template-rows:1fr auto;gap:8px;justify-items:center;height:100%}
  .ah-colb{width:100%;max-width:38px;height:var(--h);align-self:end;border-radius:5px 5px 3px 3px;transform-origin:bottom center;
