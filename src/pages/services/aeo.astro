  .ah-col img{opacity:.92;object-fit:contain}
  /* grok-icon.svg is solid #000000, invisible on the dark dashboard surface */
  :global(html:not(.light)) .ah-inv{filter:invert(1)}

  /* ══ THE SHIFT: rounded inset panel matching the hero, engine card slider ══ */
  .shift{
    --sc-sh:rgba(0,0,0,.55);
    position:relative;margin:14px 14px 0;border-radius:32px;overflow:hidden;isolation:isolate;
    min-height:calc(100vh - 28px);
    min-height:calc(100svh - 28px);
    display:grid;align-content:center;
    padding:clamp(44px,6vh,76px) 0;
    background:var(--s1);
  }
  :global(html.light) .shift{--sc-sh:rgba(60,52,40,.16)}
  .shift-in{display:grid;grid-template-columns:minmax(0,.88fr) minmax(0,1.12fr);gap:clamp(26px,3.4vw,54px);align-items:center}
  /* Capped below the global .sec-h size so "The strategy must too." stays on ONE
     line inside this narrower column instead of wrapping to a third line. */
  .shift .sec-h{font-size:clamp(28px,3vw,44px);line-height:1.04}
  .shift-p{font-family:var(--fu);font-size:clamp(13.5px,1.4vw,15px);color:var(--wd);line-height:1.78;margin:0 0 14px;max-width:44ch}

  .shift-nav{display:flex;gap:10px;margin-top:clamp(16px,2.4vh,26px)}
  .shift-btn{width:44px;height:44px;border-radius:50%;display:grid;place-items:center;flex-shrink:0;
    background:var(--s2);border:1px solid var(--bd);color:var(--w);cursor:pointer;
    transition:background .2s,border-color .2s,transform .2s,opacity .2s}
  .shift-btn:hover:not(:disabled){background:var(--agl);border-color:var(--ac);transform:translateY(-2px)}
  .shift-btn:disabled{opacity:.3;cursor:default}

  /* Native scroll-snap does the sliding: momentum on touch, smooth programmatic
     scroll from the arrows, and no JS running per frame. */
  .shift-track{display:flex;gap:14px;overflow-x:auto;overflow-y:hidden;
    scroll-snap-type:x mandatory;scroll-behavior:smooth;overscroll-behavior-x:contain;
    padding:8px;margin:-8px;scrollbar-width:none;-ms-overflow-style:none;
    cursor:grab;
    /* Cards fade out at the right instead of being hard-chopped by the column
       edge. Removed once scrolled to the end so the last card is never dimmed. */
    -webkit-mask-image:linear-gradient(90deg,#000 0,#000 calc(100% - 92px),transparent 100%);
    mask-image:linear-gradient(90deg,#000 0,#000 calc(100% - 92px),transparent 100%)}
  .shift-track.at-end{-webkit-mask-image:none;mask-image:none}
  .shift-track::-webkit-scrollbar{display:none}
  .shift-track:active{cursor:grabbing}
  .shift-track:focus-visible{outline:2px solid var(--ac);outline-offset:4px;border-radius:22px}

  .sc{position:relative;flex:0 0 auto;scroll-snap-align:start;overflow:hidden;
    /* Sized to sit level with the text column instead of floating in dead space. */
    width:clamp(218px,23vw,278px);
