     dashboard ever being clipped. Worst case checked: 1920x700. */
  @media(max-height:780px){
    .ah-bc{display:none}
    .ah-h1{font-size:clamp(28px,3.4vw,44px);margin-bottom:12px}
    .ah-sub{max-width:520px}
  }
  @media(max-height:660px){
    .ah-sub{font-size:13px;line-height:1.6;margin-bottom:14px}
    .ah-cta{margin-bottom:14px}
    .ah-card-l{display:none}
    .ah-cols{height:clamp(64px,10vh,90px)}
  }
  @media(max-width:720px){
    .aeo-vs-row{grid-template-columns:1fr}
    .aeo-vs-head{display:none}
    .aeo-results-grid{grid-template-columns:1fr 1fr}
  }
  @media(max-width:640px){
    .ah-bc{display:none}
    .ah-sub{font-size:13.5px;line-height:1.66}
    .ah-cta .btn-p,.ah-cta .btn-s{padding:11px 20px;font-size:13px}
    .aeo-del-row,.aeo-how-step{grid-template-columns:48px 1fr}
    .aeo-del-num,.aeo-how-num{font-size:18px}
    .aeo-results-grid{grid-template-columns:1fr}
  }
  @media(max-width:520px){
    .ah-card{gap:6px;padding:8px 7px}
    .ah-ring{width:24px}
    .ah-card-v{font-size:16px}
    .ah-card-l{font-size:6.5px;letter-spacing:.05em}
    .ah-dt{font-size:11.5px}
    .ah-cols{gap:7px}
    .ah-col img{width:13px;height:13px}
  }
  </style>

  <script>
  const prog=document.getElementById('scrollProg');
  window.addEventListener('scroll',()=>{if(prog){const s=document.documentElement;prog.style.width=(s.scrollTop/(s.scrollHeight-s.clientHeight)*100)+'%'}},{passive:true});
  // Cursor handled globally by the .bcur system in Nav.astro (legacy loop removed).
  const ro=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');ro.unobserve(e.target)}})},{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.rv').forEach(el=>ro.observe(el));

  // ── Hero dashboard motion ──────────────────────────────────────────────────
  // The markup renders in its FINAL state (bars full, line drawn, number set), so
  // if GSAP never loads or motion is reduced the hero is still correct and complete.
  // GSAP only rewinds to a "from" state once it has actually loaded, then plays.
  const reduceMo=matchMedia('(prefers-reduced-motion: reduce)').matches;
  const stage=document.getElementById('ahStage');

  if(stage&&!reduceMo){
    import('gsap').then(m=>{
      const g=(m as any).gsap||(m as any).default;if(!g)return;

      const win=stage.querySelector('.ah-win');
      const cards=stage.querySelectorAll('.ah-card');
      const rings=stage.querySelectorAll('.ah-ring-v');
      const bars=stage.querySelectorAll('.ah-colb');
      const chartBox=stage.querySelector('.ah-cb');
      const nums=stage.querySelectorAll('.ah-card-v');

      const fmt=(el:HTMLElement,v:number)=>{
        const dec=parseInt(el.dataset.dec||'0',10);
        const s=dec>0?v.toFixed(dec):Math.round(v).toString();
        el.textContent=el.dataset.fmt?Number(s).toLocaleString('en-US'):s;
      };

      // rewind to start state
      g.set(win,{autoAlpha:0,y:20});
      g.set(cards,{autoAlpha:0,y:10});
      g.set(chartBox,{autoAlpha:0,y:10});
      g.set(bars,{scaleY:0});
      rings.forEach((r:any)=>g.set(r,{strokeDashoffset:parseFloat(getComputedStyle(r).getPropertyValue('--dash'))||75.4}));
      nums.forEach((n:any)=>{n.textContent=n.dataset.dec?'0.0':'0'});

      const play=()=>{
        const tl=g.timeline({defaults:{ease:'power3.out'}});
        tl.to(win,{autoAlpha:1,y:0,duration:.6})
          .to(cards,{autoAlpha:1,y:0,duration:.5,stagger:.09,clearProps:'transform'},'-=.3');

        rings.forEach((r:any,i:number)=>{
          const off=parseFloat(getComputedStyle(r).getPropertyValue('--off'))||0;
          tl.to(r,{strokeDashoffset:off,duration:1,ease:'power2.inOut'},'-=' + (i===0?'.35':'.92'));
        });

        nums.forEach((n:any,i:number)=>{
          const o={v:0},t=parseFloat(n.dataset.count||'0');
          tl.to(o,{v:t,duration:1.1,ease:'power2.out',onUpdate:()=>fmt(n,o.v)},'-=' + (i===0?'.95':'1.1'));
        });

        tl.to(chartBox,{autoAlpha:1,y:0,duration:.5,clearProps:'transform'},'-=.85')
          .to(bars,{scaleY:1,duration:.62,stagger:.07,ease:'back.out(1.4)'},'-=.35');
      };

      const sObs=new IntersectionObserver(es=>{es.forEach(e=>{
        if(e.isIntersecting){play();sObs.unobserve(e.target)}
      })},{threshold:.15});
      sObs.observe(stage);
    }).catch(()=>{});
  }

  // ── Engine card slider ─────────────────────────────────────────────────────
  // Sliding is native scroll-snap, so touch keeps its momentum and nothing runs
  // per frame. JS only reads scroll position (rAF-throttled) to sync the counter.
  const track=document.getElementById('shiftTrack');
  if(track){
    const cards=Array.from(track.querySelectorAll('.sc')) as HTMLElement[];
    const idxEl=document.getElementById('shiftIdx');
    const fillEl=document.getElementById('shiftFill');
    const btns=Array.from(document.querySelectorAll('.shift-btn')) as HTMLButtonElement[];
    const step=()=>cards.length>1?cards[1].offsetLeft-cards[0].offsetLeft:track.clientWidth;

    btns.forEach(b=>b.addEventListener('click',()=>{
      track.scrollBy({left:step()*Number(b.dataset.dir||'1'),behavior:'smooth'});
    }));

    let raf=0;
    const sync=()=>{
      raf=0;
      const max=track.scrollWidth-track.clientWidth;
      const i=Math.max(0,Math.min(cards.length-1,Math.round(track.scrollLeft/step())));
      if(idxEl)idxEl.textContent=String(i+1).padStart(2,'0');
      const unit=100/cards.length;
      if(fillEl)fillEl.style.width=(max<=0?100:unit+(track.scrollLeft/max)*(100-unit))+'%';
      // drop the right-edge fade once there is nothing further to reveal
      track.classList.toggle('at-end',max<=0||track.scrollLeft>=max-2);
      btns.forEach(b=>{
        b.disabled=Number(b.dataset.dir||'1')<0?track.scrollLeft<=1:track.scrollLeft>=max-1;
      });
    };
    track.addEventListener('scroll',()=>{if(!raf)raf=requestAnimationFrame(sync)},{passive:true});
    window.addEventListener('resize',()=>{if(!raf)raf=requestAnimationFrame(sync)},{passive:true});
    sync();

    // Mouse drag. Snap and smooth scrolling are disabled mid-drag so the track
    // tracks the pointer 1:1 instead of easing behind it.
    let down=false,sx=0,sl=0;
    track.addEventListener('pointerdown',e=>{
      if(e.pointerType!=='mouse')return;
      down=true;sx=e.clientX;sl=track.scrollLeft;
      track.style.scrollSnapType='none';track.style.scrollBehavior='auto';
      track.setPointerCapture(e.pointerId);
    });
    track.addEventListener('pointermove',e=>{if(down)track.scrollLeft=sl-(e.clientX-sx)});
    const endDrag=()=>{
      if(!down)return;
      down=false;track.style.scrollBehavior='';track.style.scrollSnapType='';
    };
    track.addEventListener('pointerup',endDrag);
    track.addEventListener('pointercancel',endDrag);
  }

  document.querySelectorAll('.faq-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const isOpen=btn.getAttribute('aria-expanded')==='true';
      document.querySelectorAll('.faq-btn').forEach(b=>{b.setAttribute('aria-expanded','false');const a=b.closest('.faq-item')?.querySelector('.faq-ans') as HTMLElement|null;if(a)a.hidden=true});
      if(!isOpen){btn.setAttribute('aria-expanded','true');const ans=btn.closest('.faq-item')?.querySelector('.faq-ans') as HTMLElement|null;if(ans)ans.hidden=false}
    });
  });
  </script>
</Layout>
