  <style>
  .pg-bc{display:flex;align-items:center;gap:8px;font-family:var(--fm);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--wm);margin-bottom:32px}
  .pg-bc a{color:var(--wm);transition:color .2s}.pg-bc a:hover{color:var(--w)}.pg-bc span:not(:last-child){opacity:.4}

  /* ══ HERO: rounded panel, gradient mesh, grid, engine orbit ══ */
  .ah{
    /* Two theme-aware locals so no raw colour is repeated anywhere below.
       Shadows stay neutral-black by codebase convention (see .go-chip in
       generative-engine-optimization.astro); everything tinted derives from --ac/--w. */
    --ah-sh:rgba(0,0,0,.72);
    --ah-line:color-mix(in srgb,var(--w) 5%,transparent);
    position:relative;margin:0 14px;border-radius:32px;overflow:hidden;isolation:isolate;
    min-height:calc(100vh - 16px);
    min-height:calc(100svh - 16px);
    display:grid;align-content:center;
    padding:clamp(96px,11.5vh,128px) 0 clamp(24px,3.4vh,40px);
    box-shadow:0 40px 120px -50px var(--ah-sh);
  }
  :global(html.light) .ah{--ah-sh:rgba(60,52,40,.24)}
  .ah-skin{position:absolute;inset:0;z-index:0}
  .ah-in{position:relative;z-index:1;text-align:center;display:flex;flex-direction:column;align-items:center}
  /* Bloom is derived from --ac via color-mix, so it is brand-blue in dark and
     terracotta in light automatically. Never hardcode channel values here: that
     is what previously leaked a blue glow into the cream theme. */
  /* Blooms are raised and widened so tint reaches the upper hero, not just the
     bottom strip. Base is the plain --bg token: no hardcoded hex. */
  .ah-mesh{position:absolute;inset:0;
    background:
      radial-gradient(ellipse 56% 44% at 50% 92%,color-mix(in srgb,var(--ac) 58%,transparent) 0%,transparent 72%),
      radial-gradient(ellipse 84% 64% at 50% 100%,color-mix(in srgb,var(--ac) 32%,transparent) 0%,transparent 74%),
      radial-gradient(ellipse 118% 92% at 50% 108%,color-mix(in srgb,var(--ac) 17%,transparent) 0%,transparent 78%),
      radial-gradient(ellipse 104% 76% at 50% 24%,color-mix(in srgb,var(--ac) 11%,transparent) 0%,transparent 72%),
      var(--bg);
  }
  .ah-lines{position:absolute;inset:0;
    background-image:linear-gradient(var(--ah-line) 1px,transparent 1px),linear-gradient(90deg,var(--ah-line) 1px,transparent 1px);
    background-size:64px 64px;
    -webkit-mask-image:radial-gradient(ellipse 86% 82% at 50% 42%,#000 26%,transparent 100%);
    mask-image:radial-gradient(ellipse 86% 82% at 50% 42%,#000 26%,transparent 100%);
  }
  :global(html.light) .ah-mesh{
    background:
      radial-gradient(ellipse 56% 44% at 50% 92%,color-mix(in srgb,var(--ac) 30%,transparent) 0%,transparent 72%),
      radial-gradient(ellipse 84% 64% at 50% 100%,color-mix(in srgb,var(--ac) 17%,transparent) 0%,transparent 74%),
      radial-gradient(ellipse 118% 92% at 50% 108%,color-mix(in srgb,var(--ac) 9%,transparent) 0%,transparent 78%),
      radial-gradient(ellipse 104% 76% at 50% 24%,color-mix(in srgb,var(--ac) 6%,transparent) 0%,transparent 72%),
      var(--bg);
  }

  .ah-bc{justify-content:center;margin-bottom:16px}
  .ah-h1{font-family:var(--fd);font-size:clamp(30px,4vw,52px);font-weight:400;line-height:1.04;letter-spacing:-.022em;color:var(--w);margin:12px auto 14px;max-width:780px;text-wrap:balance}
