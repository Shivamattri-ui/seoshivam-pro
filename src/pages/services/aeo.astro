    transition:transform .3s cubic-bezier(.4,0,.2,1),box-shadow .3s,border-color .3s}
  .sc:hover{transform:translateY(-4px);border-color:color-mix(in srgb,var(--ac) 40%,var(--bd));
    box-shadow:0 26px 56px -24px var(--sc-sh)}
  /* corner shading, brand-tinted, derived from --ac */
  .sc::before{content:'';position:absolute;inset:0;pointer-events:none;border-radius:inherit;z-index:0;
    background:
      radial-gradient(58% 46% at 0% 0%,color-mix(in srgb,var(--ac) 15%,transparent),transparent 70%),
      radial-gradient(58% 46% at 100% 100%,color-mix(in srgb,var(--ac) 11%,transparent),transparent 70%)}
  .sc-mark{position:absolute;right:-24px;bottom:-20px;width:clamp(116px,13vw,164px);height:auto;
    opacity:.10;pointer-events:none;z-index:0}
  :global(html:not(.light)) .sc-inv{filter:invert(1)}

