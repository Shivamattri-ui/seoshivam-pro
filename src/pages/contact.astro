---
import Layout from '../layouts/Layout.astro';
import { SITE_ROUTE_META } from '../lib/site-route-meta';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactCta from '../components/ContactCta.astro';
import CoverageMap from '../components/CoverageMap.astro';
import FaqBlock from '../components/FaqBlock.astro';

const contactFaqs = [
  {
    q: 'How fast do you reply to contact form submissions?',
    a: 'Within 4 hours during India business hours (IST), and within 24 hours otherwise. Every submission routes through the same secure form used across the site. You get a real reply from shivamattri27@gmail.com, not an auto-sequence.',
  },
  {
    q: 'Do you work with founders outside India?',
    a: 'Yes. Most engagements are remote across the US, UK, EU, Germany, Ireland, Canada, Singapore, and Australia. All work is in English. Time zones are covered async: US mornings overlap with India afternoons, and EU afternoons land comfortably in the same window.',
  },
  {
    q: 'What should I include in the first message?',
    a: 'Your URL, the primary buyer you are trying to reach, and one sentence on what success looks like in 90 days. If you already know whether you need AEO, SEO, or a full site build, select it in the form. The more specific the message, the more useful the first reply.',
  },
  {
    q: 'Is the first audit really free?',
    a: 'Yes. The first reply includes a one-page read on where your brand stands for AI citations and organic visibility: bot access, schema gaps, and the highest-leverage fix. No commitment required before a 20-minute intro call if the fit is right.',
  },
  {
    q: 'What budget range do you typically work in?',
    a: 'Most B2B SaaS engagements sit between $5K and $50K depending on scope: a schema retrofit, a 12-week topical authority build, or a full AI-visible site plus content system. The form includes budget ranges so the first reply can address fit honestly.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      '@id': 'https://seoshivam.pro/contact/#page',
      name: 'Contact Shivam Attri',
      description: SITE_ROUTE_META['/contact'].description,
      url: 'https://seoshivam.pro/contact',
      author: { '@type': 'Person', '@id': 'https://seoshivam.pro/#shivam' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://seoshivam.pro' },
        { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://seoshivam.pro/contact' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: contactFaqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Layout
  title={SITE_ROUTE_META['/contact'].title}
  description={SITE_ROUTE_META['/contact'].description}
  canonical="https://seoshivam.pro/contact"
  schema={schema}
>
  <Nav />
  <div class="grid-bg"></DIV>
  <div class="rays-wrap">{Array.from({ length: 12 }).map((_, i) => <div class="ray" style={`--i:${i}`} />)}</DIV>
  <div class="scroll-prog" id="scrollProg"></DIV>

  <main>
    <section class="ct-hero">
      <div class="ct-hero-glow" aria-hidden="true"></DIV>
      <div class="container">
        <nav class="pg-bc rv" aria-label="Breadcrumb">
          <a href="/">Home</a><span>›</span><span>Contact</span>
        </nav>

        <div class="ct-hero-grid">
          <div class="ct-hero-copy">
            <div class="rv">
              <span class="hair left">CONTACT / START A PROJECT</span>
            </DIV>
            <h1 class="ct-h1 rv d1">
              You are not invisible<br />because of SEO.<br /><em class="grad-anim">AI does not understand you yet.</em>
            </h1>
            <p class="ct-lead rv d2">
              Tell me what you are building, where you sell, and what organic or AI visibility should look like in 90 days. I reply from <strong>shivamattri27@gmail.com</strong> with a one-page audit and a clear next step. No agency handoff. No junior team.
            </p>

            <div class="ct-avail rv d3">
              <span class="adot"></span>
              <span>Available for new projects · replies within 4 hours (IST business hours)</span>
            </DIV>

            <div class="ct-stats rv d4">
              <div class="ct-stat">
                <span class="ct-stat-n">7+</span>
                <span class="ct-stat-l">Years compounding</span>
              </DIV>
              <div class="ct-stat-div" aria-hidden="true"></DIV>
              <div class="ct-stat">
                <span class="ct-stat-n">40+</span>
                <span class="ct-stat-l">International clients</span>
              </DIV>
              <div class="ct-stat-div" aria-hidden="true"></DIV>
              <div class="ct-stat">
                <span class="ct-stat-n">16×</span>
                <span class="ct-stat-l">Fastest click growth (30 days)</span>
              </DIV>
            </DIV>

            <div class="ct-social rv d5">
              <span class="ct-social-lbl">Also on</span>
              <div class="ct-social-row">
                <a href="https://www.linkedin.com/in/seoshivampro/" class="ct-soc" target="_blank" rel="noopener noreferrer" data-cursor="LinkedIn">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
                <a href="https://substack.com/@seoshivampro" class="ct-soc" target="_blank" rel="noopener noreferrer" data-cursor="Substack">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
                  Substack
                </a>
                <a href="https://www.instagram.com/seoshivam.pro/" class="ct-soc" target="_blank" rel="noopener noreferrer" data-cursor="Instagram">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  Instagram
                </a>
              </DIV>
            </DIV>
          </DIV>

          <aside class="ct-hero-aside rv d2">
            <div class="ct-card">
              <div class="ct-card-top">
                <span class="ct-card-k">Best fit</span>
                <p class="ct-card-t">B2B SaaS founders · $500K–$3M ARR · spending on ads but organic and AI visibility still flat.</p>
              </DIV>
              <ul class="ct-card-list">
                <li><a href="/services/aeo" class="ilink">AEO strategy</a> for ChatGPT, Perplexity, Google AI Overviews</li>
                <li><a href="/services/seo" class="ilink">SEO architecture</a> that compounds month over month</li>
                <li><a href="/services/web-design" class="ilink">AI-visible web design</a> on Webflow, Framer, Astro, WordPress</li>
              </ul>
              <a href="#contact-form" class="btn-p ct-card-cta" data-cursor="Jump to form">Go to the form ↓</a>
            </DIV>
          </aside>
        </DIV>
      </DIV>
    </section>

    <div id="contact-form">
      <ContactCta
        id="contact-page-cta"
        source="contact-page"
        eyebrow="WORK TOGETHER / SECURE LEAD FORM"
        heading="Tell me about your brand"
        headingEm="and where you need to show up."
        deck="Same form used across seoshivam.pro: eight fields, honeypot protection, server-side delivery to Brevo. I reply within 4 hours with a one-page audit of your AI visibility and organic gaps."
      />
    </DIV>

    <CoverageMap />

    <FaqBlock
      faqs={contactFaqs}
      eyebrow="CONTACT FAQ"
      heading="Before you hit send,"
      headingEm="common questions."
      deck="Scope, response time, budgets, and what happens after you submit."
      id="contact-faq"
      emitSchema={false}
    />
  </main>

  <Footer />

  <style>
    .ct-hero {
      position: relative;
      padding: 148px 0 56px;
      overflow: hidden;
    }
    .ct-hero-glow {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 50% 40% at 18% 20%, rgba(79, 142, 247, 0.12) 0%, transparent 55%),
        radial-gradient(ellipse 40% 35% at 85% 60%, rgba(26, 58, 143, 0.08) 0%, transparent 50%);
    }
    html.light .ct-hero-glow {
      background:
        radial-gradient(ellipse 50% 40% at 18% 20%, rgba(43, 91, 224, 0.08) 0%, transparent 55%),
        radial-gradient(ellipse 40% 35% at 85% 60%, rgba(26, 58, 143, 0.05) 0%, transparent 50%);
    }

    .pg-bc {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--fm);
      font-size: 10px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--wm);
      margin-bottom: 28px;
    }
    .pg-bc a {
      color: var(--wm);
      transition: color 0.2s;
    }
    .pg-bc a:hover {
      color: var(--w);
    }
    .pg-bc span:not(:last-child) {
      opacity: 0.4;
    }

    .ct-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: 56px;
      align-items: start;
    }

    .ct-h1 {
      font-family: var(--fd);
      font-size: clamp(36px, 5.4vw, 72px);
      font-weight: 400;
      line-height: 0.96;
      letter-spacing: -0.022em;
      color: var(--w);
      margin: 12px 0 24px;
    }
    .ct-h1 em {
      font-style: italic;
    }

    .ct-lead {
      font-family: var(--fu);
      font-size: clamp(15px, 1.6vw, 17px);
      color: var(--wd);
      line-height: 1.78;
      max-width: 560px;
      margin: 0 0 28px;
    }
    .ct-lead strong {
      color: var(--w);
      font-weight: 600;
    }

    .ct-avail {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--fm);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green);
      background: rgba(34, 197, 94, 0.08);
      border: 1px solid rgba(34, 197, 94, 0.22);
      border-radius: 999px;
      padding: 8px 16px;
      margin-bottom: 32px;
    }

    .ct-stats {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 20px 28px;
      margin-bottom: 36px;
    }
    .ct-stat-n {
      display: block;
      font-family: var(--fd);
      font-size: clamp(28px, 3.5vw, 40px);
      font-style: italic;
      background: var(--ag);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1;
    }
    .ct-stat-l {
      display: block;
      font-family: var(--fm);
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--wm);
      margin-top: 6px;
    }
    .ct-stat-div {
      width: 1px;
      height: 36px;
      background: var(--bd);
    }

    .ct-social-lbl {
      display: block;
      font-family: var(--fm);
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--wm);
      margin-bottom: 12px;
    }
    .ct-social-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .ct-soc {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--fu);
      font-size: 13px;
      font-weight: 600;
      color: var(--wd);
      background: var(--s1);
      border: 1px solid var(--bd);
      border-radius: 999px;
      padding: 8px 16px;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }
    .ct-soc:hover {
      color: var(--w);
      border-color: var(--ac);
      background: var(--agl);
    }

    .ct-card {
      background: var(--s1);
      border: 1px solid var(--bd);
      border-radius: 20px;
      padding: 28px;
      position: relative;
      overflow: hidden;
    }
    .ct-card::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(ellipse 80% 60% at 100% 0%, rgba(79, 142, 247, 0.1) 0%, transparent 55%);
    }
    .ct-card-k {
      font-family: var(--fm);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ac);
    }
    .ct-card-t {
      font-family: var(--fu);
      font-size: 14px;
      color: var(--wd);
      line-height: 1.65;
      margin: 10px 0 20px;
    }
    .ct-card-list {
      list-style: none;
      margin: 0 0 24px;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .ct-card-list li {
      font-family: var(--fu);
      font-size: 13px;
      color: var(--wd);
      line-height: 1.55;
      padding-left: 16px;
      position: relative;
    }
    .ct-card-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 6px;
      height: 6px;
      border-radius: 1px;
      background: var(--ag);
    }
    .ct-card-cta {
      width: 100%;
      justify-content: center;
    }

    #contact-form {
      scroll-margin-top: 100px;
    }
    #contact-form .ccta {
      padding-top: 24px;
    }

    @media (max-width: 960px) {
      .ct-hero-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      .ct-hero-aside {
        order: -1;
      }
    }
    @media (max-width: 640px) {
      .ct-hero {
        padding: 128px 0 40px;
      }
      .ct-stat-div {
        display: none;
      }
      .ct-stats {
        gap: 16px;
      }
    }
  </style>
</Layout>
