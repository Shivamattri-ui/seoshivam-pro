---
/**
 * FaqBlock — reusable FAQ accordion.
 *
 * Drops anywhere on the site (work, resources, tools, about, services).
 * Renders schema-friendly markup (microdata + a JSON-LD script) so
 * AI engines and Google's rich-result tester both pick it up.
 *
 * Usage:
 *   <FaqBlock
 *     eyebrow="QUESTIONS / BEFORE YOU REACH OUT"
 *     heading="Common questions,"
 *     headingEm="direct answers."
 *     deck="Short context line below the heading."
 *     faqs={[{q, a}, ...]}
 *     id="page-faq"
 *   />
 */
interface Faq { q: string; a: string }

interface Props {
  faqs: Faq[];
  eyebrow?: string;
  heading?: string;
  headingEm?: string;
  deck?: string;
  id?: string;
  /** when true, the JSON-LD script is emitted by this component.
   *  Set false on pages that already include FAQPage schema in their
   *  page-level Layout schema prop to avoid duplicates. */
  emitSchema?: boolean;
}

const {
  faqs,
  eyebrow = 'FREQUENTLY ASKED / AI-CITABLE Q&A',
  heading = 'Common questions,',
  headingEm = 'direct answers.',
  deck = 'Direct answers to the questions buyers and AI engines ask. Each answer is structured for citation in ChatGPT, Perplexity, and Google AI Overviews.',
  id = 'page-faq',
  emitSchema = true,
} = Astro.props;

const faqSchema = emitSchema && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      'mainEntity': faqs.map(f => ({
        '@type': 'Question',
        'name': f.q,
        'acceptedAnswer': { '@type': 'Answer', 'text': f.a },
      })),
    }
  : null;
---

{faqs.length > 0 && (
  <section class="fbq" id={id}>
    <header class="fbq-hdr">
      <span class="hair left">{eyebrow}</span>
      <h2 class="fbq-h">
        {heading}<br>
        <em class="grad-anim">{headingEm}</em>
      </h2>
      {deck && <p class="fbq-deck">{deck}</p>}
    </header>

    <div class="fbq-list">
      {faqs.map((f, i) => (
        <details class={`fbq-item${i===0?' is-open':''}`} open={i===0}>
          <summary class="fbq-q">
            <span class="fbq-num">{String(i+1).padStart(2,'0')}</span>
            <span class="fbq-q-text">{f.q}</span>
            <span class="fbq-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </summary>
          <div class="fbq-a">
            <p>{f.a}</p>
          </div>
        </details>
      ))}
    </div>

    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </section>
)}

<style is:global>
.fbq{
  margin:80px auto;
  max-width:880px;
  padding:48px 52px;
  background:linear-gradient(180deg, var(--s1) 0%, rgba(15,15,15,.6) 100%);
  border:1px solid var(--bd);
  border-radius:24px;
  position:relative;overflow:hidden;
}
.fbq::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 50% 70% at 100% 0%, rgba(79,142,247,.08) 0%, transparent 60%);
}
.fbq-hdr{position:relative;display:flex;flex-direction:column;gap:14px;margin-bottom:32px;align-items:flex-start}
.fbq-h{
  font-family:var(--fd);
  font-size:clamp(30px,3.6vw,52px);
  font-weight:400;line-height:1.02;letter-spacing:-.022em;
  color:var(--w);margin:0;
}
.fbq-h em{font-style:italic}
.fbq-deck{
  font-family:var(--fu);font-size:14.5px;color:var(--wd);
  line-height:1.7;margin:0;max-width:600px;
}

.fbq-list{position:relative;display:flex;flex-direction:column;gap:10px}
.fbq-item{
  background:var(--s2);
  border:1px solid var(--bd);
  border-radius:12px;
  overflow:hidden;
  transition:border-color .25s, background .25s;
}
.fbq-item:hover{border-color:rgba(79,142,247,.35)}
.fbq-item[open]{border-color:rgba(79,142,247,.45);background:var(--agl)}

.fbq-q{
  list-style:none;cursor:pointer;
  display:grid;
  grid-template-columns:42px 1fr 28px;
  gap:18px;align-items:center;
  padding:20px 24px;
  font-family:var(--fu);font-size:16px;font-weight:600;
  color:var(--w);letter-spacing:-.012em;
  line-height:1.4;
  user-select:none;
}
.fbq-q::-webkit-details-marker{display:none}
.fbq-num{
  font-family:var(--fd);font-size:22px;font-style:italic;font-weight:400;
  line-height:1;letter-spacing:-.02em;
  color:var(--ac);
  background:var(--agl);
  border:1px solid rgba(79,142,247,.24);
  border-radius:6px;
  padding:6px 0;
  text-align:center;
  align-self:start;margin-top:1px;
  transition:background .25s, border-color .25s;
}
.fbq-item[open] .fbq-num{background:rgba(79,142,247,.18);border-color:rgba(79,142,247,.4)}
.fbq-q-text{min-width:0}
.fbq-icon{
  width:30px;height:30px;border-radius:999px;
  background:var(--s3);
  border:1px solid var(--bd);
  display:flex;align-items:center;justify-content:center;
  color:var(--ac);
  transition:transform .35s cubic-bezier(.16,1,.3,1), background .25s, border-color .25s;
  align-self:center;
}
.fbq-item[open] .fbq-icon{
  transform:rotate(45deg);
  background:var(--ac);
  border-color:var(--ac);
  color:#fff;
}
.fbq-a{
  padding:0 24px 22px 84px;
  border-top:1px solid var(--bd);
}
.fbq-item[open] .fbq-a{padding-top:18px}
.fbq-a p{
  font-family:var(--fu);font-size:14.5px;
  color:var(--wd);
  line-height:1.75;
  margin:0;
}

@media(max-width:680px){
  .fbq{padding:32px 24px;margin:48px auto}
  .fbq-q{grid-template-columns:36px 1fr 24px;gap:12px;padding:16px 18px;font-size:14.5px}
  .fbq-num{font-size:18px;padding:5px 0}
  .fbq-a{padding:0 18px 18px 66px}
}
</style>
