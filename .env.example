# Copy to ".env" in this folder (never commit .env).
# Restart `npm run dev` after creating or editing .env.
#
# Get a key: Brevo → SMTP & API → API Keys → Create a new API key (v3).
# Scopes: enough for Contacts + Transactional emails.

BREVO_API_KEY=
